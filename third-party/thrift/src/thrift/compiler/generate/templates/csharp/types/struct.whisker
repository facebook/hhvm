{{#import "common/types" as types}}
{{#import "common/defaults" as defaults}}
{{#import "types/struct_properties" as props}}
{{#import "types/struct_ctor" as ctor}}
{{#import "types/struct_clear" as clr}}
{{#import "types/struct_isempty" as empty}}
{{#import "types/struct_equals" as eq}}
{{#import "types/struct_tostring" as ts}}
{{#import "codec/write" as wr}}
{{#import "codec/read" as rd}}

{{#let export partial struct_type |structured| captures |types defaults props ctor clr empty eq ts wr rd|}}
{{#if (not structured.union?)}}
/// <summary>
/// Auto-generated from {{structured.name}}
/// </summary>
public class {{structured.csharp_name}} : {{#if structured.exception?}}Exception, {{/if structured.exception?}}IThriftSerializable
{
{{#if (not (string.empty? structured.uri))}}
    /// <summary>The Thrift URI for this type, used for type registration.</summary>
    public static readonly string __fbthrift_uri = "{{structured.uri}}";
{{/if (not (string.empty? structured.uri))}}
{{#each structured.fields as |field|}}
    {{#partial props.struct_properties field=field structured=structured}}

{{/each}}
{{#if (and structured.exception? (object.notnull? structured.message_field))}}
    /// <summary>Returns the exception message from the @thrift.ExceptionMessage field.</summary>
    public override string Message => {{structured.message_field.csharp_property_name}}{{#if structured.message_field.optional?}} ?? ""{{/if}};

{{/if (and structured.exception? (object.notnull? structured.message_field))}}
    {{#partial ctor.struct_ctor structured=structured}}

    {{#partial clr.struct_clear structured=structured}}

    {{#partial empty.struct_isempty structured=structured}}

    {{#partial wr.struct_write structured=structured}}

    {{#partial rd.struct_read structured=structured}}

    {{#partial eq.struct_equals structured=structured}}

    {{#partial ts.struct_tostring structured=structured}}
}
{{/if (not structured.union?)}}
{{#if structured.union?}}
{{> types/union}}
{{/if structured.union?}}
{{/let partial}}
