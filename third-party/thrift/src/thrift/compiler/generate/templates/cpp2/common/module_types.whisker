{{#import "common/fields" as fields}}

{{#let export partial forward_declare_structured_definitions |program|}}
// BEGIN forward_declare
  {{#if program.structs?}}
namespace {{program.cpp_qualified_namespace}} {
    {{#each program.structured_definitions as |struct|}}
      {{#if (object.notnull? struct.extra_namespace)}}
namespace {{struct.extra_namespace}} {
      {{/if (object.notnull? struct.extra_namespace)}}
class {{struct.cpp_underlying_name}};
      {{#if (object.notnull? struct.extra_namespace)}}
} // namespace {{struct.extra_namespace}}
      {{/if (object.notnull? struct.extra_namespace)}}
    {{/each}}
} // namespace {{program.cpp_qualified_namespace}}
  {{/if program.structs?}}
// END forward_declare
{{/let partial}}


{{#let export partial smart_ptr_constructor |field| captures |fields|}}
{{#pragma ignore-newlines}}
  {{#if field.cpp_ref_unique?}}
{{#if field.type.cpp_use_allocator?}}folly::allocate_unique{{#else}}std::make_unique{{/if field.type.cpp_use_allocator?}}
  {{#else}}
{{#if field.type.cpp_use_allocator?}}std::allocate_shared{{#else}}std::make_shared{{/if field.type.cpp_use_allocator?}}
  {{/if field.cpp_ref_unique?}}
<{{field.cpp_type}}>(
{{#if field.type.cpp_use_allocator?}}__fbthrift_alloc{{/if}}
{{#if (object.notnull? field.default_value)}}{{#partial fields.default_value field=field}}{{/if}}
)
{{/let partial}}


{{#let partial base_ctor_with_alloc_init_list |struct| captures |fields smart_ptr_constructor|}}
{{! Empty constructor, with 1 allocator,
    copied from alloc_extended_ctors.whisker ctor(const allocator_type& alloc) }}
{{struct.cpp_underlying_name}}() :
    __fbthrift_alloc(allocator_type()),
{{#each (array.enumerate struct.fields_in_layout_order with_last=true) as |i field is_last?|}}
    {{field.cpp_storage_name}}({{!
}}{{#if field.cpp_ref_not_boxed?}}{{#partial smart_ptr_constructor field=field}}{{!
}}{{#else if field.boxed_ref?}}{{#partial fields.default_value field=field}}{{!
}}{{#else if field.intern_boxed_ref?}}{{field.cpp_storage_type}}::fromStaticConstant(&::apache::thrift::op::getDefault<{{#partial fields.tag field=field struct=struct}}>()){{!
}}{{#else if (and (not field.cpp_ref?) field.type.cpp_use_allocator?)}}__fbthrift_alloc{{!
}}{{/if field.cpp_ref_not_boxed?}}){{#if (not is_last?)}},
{{/if (not is_last?)}}
{{/each}}
{{/let partial}}


{{#let partial base_ctor_no_alloc_init_list |struct| captures |fields smart_ptr_constructor|}}
{{#pragma ignore-newlines}}
{{! Empty constructor, no allocator, init list }}
{{struct.cpp_underlying_name}}()
{{#each (array.enumerate struct.explicitly_constructed_fields with_first=true with_last=true) as |i field first? last?|}}
{{> common/colon_newline}}    {{field.cpp_storage_name}}(
  {{#if field.cpp_ref_not_boxed?}}
{{#partial smart_ptr_constructor field=field}}
  {{#else if field.boxed_ref?}}
{{#partial fields.default_value field=field}}
  {{! TODO: Support custom default for intern boxed field. }}
  {{#else if field.intern_boxed_ref?}}
{{field.cpp_storage_type}}::fromStaticConstant(&::apache::thrift::op::getDefault<{{#partial fields.tag field=field struct=struct}}>())
  {{! Use value initialization when no custom default is provided. }}
  {{#else if (and (not field.cpp_ref?) (object.notnull? field.default_value))}}
{{#partial fields.default_value field=field}}
  {{/if field.cpp_ref_not_boxed?}}
){{> common/comma_newline}}
{{/each}}
{{/let partial}}


{{#let export partial base_ctor |struct| captures |base_ctor_with_alloc_init_list base_ctor_no_alloc_init_list|}}
{{#if (and (object.notnull? struct.cpp_allocator) (object.eq? null struct.cpp_allocator_via))}}{{!
}}{{#partial base_ctor_with_alloc_init_list struct=struct}}{{!
}}{{#else}}{{!
}}{{#partial base_ctor_no_alloc_init_list struct=struct}}{{!
}}{{/if (and (object.notnull? struct.cpp_allocator) (object.eq? null struct.cpp_allocator_via))}} {
  {{#each struct.fields as |field|}}
    {{#if (and (object.notnull? field.cpp_first_adapter) (not field.opt_cpp_ref?) (not field.intern_boxed_ref?))}}
  ::apache::thrift::adapt_detail::construct<{{field.cpp_first_adapter}}, {{field.id}}>({{#if field.cpp_ref?}}*{{/if}}{{field.cpp_storage_name}}, *this);
    {{/if (and (object.notnull? field.cpp_first_adapter) (not field.opt_cpp_ref?) (not field.intern_boxed_ref?))}}
  {{/each}}
}{{!
}}{{/let partial}}


{{#let export partial fragile_ctor_param_list |struct|}}
{{#pragma ignore-newlines}}
{{#each struct.fields as |field|}}, {{field.cpp_storage_type}} {{field.cpp_name}}__arg{{/each}}
{{/let partial}}


{{#let export partial eq_overload |struct|}}
bool {{struct.cpp_underlying_name}}::operator==([[maybe_unused]] const {{struct.cpp_underlying_name}}& rhs) const {
  return ::apache::thrift::op::detail::StructEquality{}(*this, rhs);
}{{!
}}{{/let partial}}


{{#let export partial struct_operator_less |struct|}}
bool {{struct.cpp_underlying_name}}::operator<([[maybe_unused]] const {{struct.cpp_underlying_name}}& rhs) const {
  return ::apache::thrift::op::detail::StructLessThan{}(*this, rhs);
}{{!
}}{{/let partial}}


{{#let export partial union_eq_overload |struct|}}
bool {{struct.cpp_underlying_name}}::operator==(const {{struct.cpp_underlying_name}}& rhs) const {
  return ::apache::thrift::op::detail::UnionEquality{}(*this, rhs);
}{{!
}}{{/let partial}}


{{#let export partial union_operator_less |struct|}}
bool {{struct.cpp_underlying_name}}::operator<([[maybe_unused]] const {{struct.cpp_underlying_name}}& rhs) const {
  return ::apache::thrift::op::detail::UnionLessThan{}(*this, rhs);
}{{!
}}{{/let partial}}


{{#let export partial union_swap |struct|}}
void swap({{struct.cpp_underlying_name}}& a, {{struct.cpp_underlying_name}}& b) {
  {{struct.cpp_underlying_name}} temp(std::move(a));
  a = std::move(b);
  b = std::move(temp);
}
{{!
}}{{/let partial}}


{{#let export partial assign_overload |struct|}}
static void __fbthrift_swap({{struct.cpp_underlying_name}}& lhs, {{struct.cpp_underlying_name}}& rhs) { swap(lhs, rhs); }
{{struct.cpp_underlying_name}}& {{struct.cpp_underlying_name}}::operator=(const {{struct.cpp_underlying_name}}& other) {
  {{struct.cpp_underlying_name}} tmp(other{{#if (object.notnull? struct.cpp_allocator)}}, get_allocator(){{/if}});
  __fbthrift_swap(*this, tmp);
  {{#if (and (object.notnull? struct.cpp_allocator) (object.eq? null struct.cpp_allocator_via))}}
  ::apache::thrift::detail::copy_allocator(__fbthrift_alloc, other.__fbthrift_alloc);
  {{/if (and (object.notnull? struct.cpp_allocator) (object.eq? null struct.cpp_allocator_via))}}
  return *this;
}{{!
}}{{/let partial}}


{{#let export partial declare_union_types |struct|}}
namespace apache { namespace thrift {

folly::Range<{{struct.cpp_fullname}}::Type const*> const TEnumTraits<{{struct.cpp_fullname}}::Type>::values = {{!
    }}folly::range(TEnumDataStorage<{{struct.cpp_fullname}}::Type>::values);
folly::Range<std::string_view const*> const TEnumTraits<{{struct.cpp_fullname}}::Type>::names = {{!
    }}folly::range(TEnumDataStorage<{{struct.cpp_fullname}}::Type>::names);

bool TEnumTraits<{{struct.cpp_fullname}}::Type>::findName(type value, std::string_view* out) noexcept {
  return ::apache::thrift::detail::st::enum_find_name(value, out);
}

bool TEnumTraits<{{struct.cpp_fullname}}::Type>::findValue(std::string_view name, type* out) noexcept {
  return ::apache::thrift::detail::st::enum_find_value(name, out);
}
}} // apache::thrift{{!
}}{{/let partial}}


{{#let export partial field_value_ref |field|}}
{{#pragma ignore-newlines}}
  {{#if field.cpp_ref?}}
{{field.cpp_storage_name}}
  {{#else if field.optional?}}
{{field.cpp_name}}_ref().value_unchecked()
  {{#else}}
{{field.cpp_name}}_ref().value()
  {{/if field.cpp_ref?}}
{{/let partial}}


{{#let export partial field_ref_args |field struct| captures |fields|}}
{{#pragma ignore-newlines}}
{{#if field.intern_boxed_ref?}}, ::apache::thrift::op::getDefault<{{#partial fields.tag field=field struct=struct}}>{{/if}}
{{#if field.has_isset?}}, __isset.at({{field.isset_index}}), __isset.bit({{field.isset_index}}){{/if}}
{{/let partial}}


{{#let export partial field_interceptor |field| captures |fields|}}
  {{#if (object.notnull? field.cpp_field_interceptor)}}
    {{field.cpp_field_interceptor}}::interceptThriftFieldAccess(this->{{#partial fields.field_value field=field}}, {{!
}}::apache::thrift::FieldContext<std::remove_reference<decltype(*this)>::type, {{field.id}}>{*this});
  {{/if (object.notnull? field.cpp_field_interceptor)}}
{{/let partial}}
