namespace apache::thrift {

std::unique_ptr<
    ::apache::thrift::fast_thrift::thrift::ThriftServerAppAdapter,
    folly::DelayedDestruction::Destructor>
FastServiceHandler<{{service.qualified_name}}>::getAppAdapter(
    std::shared_ptr<
        ::apache::thrift::fast_thrift::thrift::ThriftServerAppAdapterFactory>
        self) {
  // Aliasing-ctor: shares ownership with `self` but stores `this` as the
  // typed pointer. Avoids a runtime cast — the type is established at
  // compile time by being inside this override.
  std::shared_ptr<FastServiceHandler<{{service.qualified_name}}>> typed(
      std::move(self), this);
  return std::unique_ptr<
      ::apache::thrift::fast_thrift::thrift::ThriftServerAppAdapter,
      folly::DelayedDestruction::Destructor>(
      new ::{{service.cpp_qualified_namespace}}::{{service.cpp_name}}AppAdapter(
          std::move(typed)));
}

void FastServiceHandler<{{service.qualified_name}}>::getServiceMetadata(
    ::apache::thrift::metadata::ThriftServiceMetadataResponse& response) {
  ::apache::thrift::detail::md::ServiceMetadata<::apache::thrift::ServiceHandler<{{service.qualified_name}}>>::gen(response);
}
  {{#if service.program.has_schema_const?}}

std::optional<::apache::thrift::schema::DefinitionsSchema>
FastServiceHandler<{{service.qualified_name}}>::getServiceSchema() {
  std::optional<::apache::thrift::schema::DefinitionsSchema> ret =
      ::apache::thrift::schema::DefinitionsSchema{};
  ret->schema = ::apache::thrift::schema::detail::loadBundledSchema(::{{service.cpp_qualified_namespace}}::{{service.program.name}}_constants::{{service.program.schema_const_name}}_includes());
  ret->definitions = { {"{{service.definition_key.buffer}}", {{service.definition_key.length}}} };
  return ret;
}

std::vector<folly::not_null<const ::apache::thrift::syntax_graph::ServiceNode*>>
FastServiceHandler<{{service.qualified_name}}>::getServiceSchemaNodes() {
  return {&::apache::thrift::SchemaRegistry::get().getNode<{{service.qualified_name}}>()};
}
  {{/if service.program.has_schema_const?}}

} // namespace apache::thrift

namespace {{service.cpp_qualified_namespace}} {

{{service.cpp_name}}AppAdapter::{{service.cpp_name}}AppAdapter(
    std::shared_ptr<
        ::apache::thrift::FastServiceHandler<{{service.qualified_name}}>>
        handler)
    : handler_(std::move(handler)) {
  {{#each service.functions as |function|}}
  {{#if (and (not function.starts_interaction?) (not function.stream?) (not function.sink?) (not function.oneway?))}}
  addMethodHandler(
      "{{function.name}}",
      +[](::apache::thrift::fast_thrift::thrift::ThriftServerAppAdapter* a,
          uint32_t streamId,
          std::unique_ptr<folly::IOBuf> data,
          ::apache::thrift::ProtocolId p,
          std::unique_ptr<
              ::apache::thrift::fast_thrift::thrift::ThriftRequestContext>
              requestContext) noexcept {
        static_cast<{{service.cpp_name}}AppAdapter*>(a)
            ->process_{{function.cpp_name}}(
                streamId, std::move(data), p, std::move(requestContext));
      });
  {{/if (and (not function.starts_interaction?) (not function.stream?) (not function.sink?) (not function.oneway?))}}
  {{/each}}
}

{{#each service.functions as |function|}}
{{#if (and (not function.starts_interaction?) (not function.stream?) (not function.sink?) (not function.oneway?))}}
void {{service.cpp_name}}AppAdapter::process_{{function.cpp_name}}(
    uint32_t streamId,
    std::unique_ptr<folly::IOBuf> data,
    ::apache::thrift::ProtocolId protocolId,
    std::unique_ptr<::apache::thrift::fast_thrift::thrift::ThriftRequestContext>
        requestContext) noexcept {
  switch (protocolId) {
    case ::apache::thrift::ProtocolId::COMPACT:
      process_{{function.cpp_name}}_impl<
          ::apache::thrift::CompactProtocolReader,
          ::apache::thrift::CompactProtocolWriter>(
          streamId, std::move(data), std::move(requestContext));
      break;
    case ::apache::thrift::ProtocolId::BINARY:
      process_{{function.cpp_name}}_impl<
          ::apache::thrift::BinaryProtocolReader,
          ::apache::thrift::BinaryProtocolWriter>(
          streamId, std::move(data), std::move(requestContext));
      break;
    default:
      writeResponse(
          ::apache::thrift::fast_thrift::thrift::makeFrameworkErrorMessage(
              streamId,
              ::apache::thrift::ResponseRpcErrorCode::REQUEST_PARSING_FAILURE,
              "Unsupported protocol id for fast_thrift server"));
      break;
  }
}

template void {{service.cpp_name}}AppAdapter::process_{{function.cpp_name}}_impl<
    ::apache::thrift::CompactProtocolReader,
    ::apache::thrift::CompactProtocolWriter>(
    uint32_t,
    std::unique_ptr<folly::IOBuf>,
    std::unique_ptr<
        ::apache::thrift::fast_thrift::thrift::ThriftRequestContext>) noexcept;
template void {{service.cpp_name}}AppAdapter::process_{{function.cpp_name}}_impl<
    ::apache::thrift::BinaryProtocolReader,
    ::apache::thrift::BinaryProtocolWriter>(
    uint32_t,
    std::unique_ptr<folly::IOBuf>,
    std::unique_ptr<
        ::apache::thrift::fast_thrift::thrift::ThriftRequestContext>) noexcept;

{{/if (and (not function.starts_interaction?) (not function.stream?) (not function.sink?) (not function.oneway?))}}
{{/each}}

} // namespace {{service.cpp_qualified_namespace}}
