<?hh
<<file:
  __EnableUnstableFeatures(
    'expression_trees',
    'expression_tree_hack_arrays',
  )>>

function test_vec(): void {
  ExampleDsl::makeTree(
    darray[
      "path" => __FILE__,
      "start_line" => 5,
      "end_line" => 5,
      "start_column" => 13,
      "end_column" => 72,
    ],
    darray[
      "splices" => dict[],
      "functions" => vec[],
      "static_methods" => vec[],
      "variables" => vec[],
      "lexically_enclosing_tree" => NULL,
    ],
    (
      (ExampleDsl $v) ==> {
        return $v->visitLambda(
          darray[
            "path" => __FILE__,
            "start_line" => 5,
            "end_line" => 5,
            "start_column" => 13,
            "end_column" => 72,
          ],
          vec["$arr", "$idx"],
          vec[
            $v->visitReturn(
              darray[
                "path" => __FILE__,
                "start_line" => 5,
                "end_line" => 5,
                "start_column" => 57,
                "end_column" => 72,
              ],
              $v->visitVec(
                darray[
                  "path" => __FILE__,
                  "start_line" => 5,
                  "end_line" => 5,
                  "start_column" => 57,
                  "end_column" => 72,
                ],
                vec[
                  $v->visitLocal(
                    darray[
                      "path" => __FILE__,
                      "start_line" => 5,
                      "end_line" => 5,
                      "start_column" => 61,
                      "end_column" => 65,
                    ],
                    "$idx",
                  ),
                  $v->visitInt(
                    darray[
                      "path" => __FILE__,
                      "start_line" => 5,
                      "end_line" => 5,
                      "start_column" => 67,
                      "end_column" => 68,
                    ],
                    1,
                  ),
                  $v->visitInt(
                    darray[
                      "path" => __FILE__,
                      "start_line" => 5,
                      "end_line" => 5,
                      "start_column" => 70,
                      "end_column" => 71,
                    ],
                    2,
                  ),
                ],
              ),
            ),
          ],
        );
      }
    ),
  );
}

function test_dict_string_key(): void {
  ExampleDsl::makeTree(
    darray[
      "path" => __FILE__,
      "start_line" => 9,
      "end_line" => 9,
      "start_column" => 13,
      "end_column" => 73,
    ],
    darray[
      "splices" => dict[],
      "functions" => vec[],
      "static_methods" => vec[],
      "variables" => vec[],
      "lexically_enclosing_tree" => NULL,
    ],
    (
      (ExampleDsl $v) ==> {
        return $v->visitLambda(
          darray[
            "path" => __FILE__,
            "start_line" => 9,
            "end_line" => 9,
            "start_column" => 13,
            "end_column" => 73,
          ],
          vec["$key", "$val"],
          vec[
            $v->visitReturn(
              darray[
                "path" => __FILE__,
                "start_line" => 9,
                "end_line" => 9,
                "start_column" => 55,
                "end_column" => 73,
              ],
              $v->visitDict(
                darray[
                  "path" => __FILE__,
                  "start_line" => 9,
                  "end_line" => 9,
                  "start_column" => 55,
                  "end_column" => 73,
                ],
                vec[varray[
                  $v->visitLocal(
                    darray[
                      "path" => __FILE__,
                      "start_line" => 9,
                      "end_line" => 9,
                      "start_column" => 60,
                      "end_column" => 64,
                    ],
                    "$key",
                  ),
                  $v->visitLocal(
                    darray[
                      "path" => __FILE__,
                      "start_line" => 9,
                      "end_line" => 9,
                      "start_column" => 68,
                      "end_column" => 72,
                    ],
                    "$val",
                  ),
                ]],
              ),
            ),
          ],
        );
      }
    ),
  );
}

