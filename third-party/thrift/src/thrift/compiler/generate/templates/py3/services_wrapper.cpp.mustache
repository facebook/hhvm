}
  {{#each service.lifecycleFunctions as |function|}}
folly::SemiFuture<folly::Unit> {{service.name}}Wrapper::semifuture_{{function.cpp_name}}() {
  auto [promise, future] = folly::makePromiseContract<folly::Unit>();
  call_cy_{{service.name}}_{{function.cpp_name}}(
      this->if_object,
      std::move(promise)
  );
  return std::move(future);
}
