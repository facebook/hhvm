{{! Used to convert C++ `ckey` to python object. }}
{{#let export partial map_key_cpp_to_python |type| captures |container_from_cpp python_type cython_cpp_type cython_python_type|}}
{{#pragma ignore-newlines}}
{{#if type.iobuf?}}_fbthrift_iobuf.IOBuf.create(ckey.get(), self)
{{#else if type.iobufRef?}}_fbthrift_iobuf.IOBuf.create(ckey.get().get(), self)
{{#else if type.flexibleBinary?}}(<const char*>ckey.data())[:ckey.size()]
{{#else if type.string?}}__init_unicode_from_cpp(ckey)
{{#else if type.binary?}}bytes(<string>ckey)
{{#else if type.primitive?}}ckey
{{#else if type.container?}}{{#partial container_from_cpp type=type}}(ckey)
