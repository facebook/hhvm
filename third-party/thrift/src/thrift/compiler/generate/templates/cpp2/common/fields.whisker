}}
{{#import "common/const_value" as const_value}}
{{#import "common/types" as types}}

{{! Note: All adapted fields need to use field tag. }}
{{#let export partial tag |field struct|}}
{{#pragma ignore-newlines}}
  {{#if (object.notnull? field.cpp_adapter)}}
::apache::thrift::op::get_field_tag<{{struct.cpp_underlying_name}}, ::apache::thrift::field_id<{{field.id}}>>
  {{#else}}
{{field.type_tag}}
  {{/if (object.notnull? field.cpp_adapter)}}
{{/let partial}}

{{! Returns the intrinsic default value for base or enum fields. }}
{{#let export partial intrinsic_default |field| captures |types|}}
{{#pragma ignore-newlines}}
  {{#if field.type.string_or_binary?}}
apache::thrift::StringTraits<{{field.cpp_standard_type}}>::fromStringLiteral("")
  {{#else}}
{{field.cpp_standard_type}}()
  {{/if field.type.string_or_binary?}}
{{/let partial}}

{{#let export partial field_value |field|}}
{{#pragma ignore-newlines}}
{{#if field.lazy?}}__fbthrift_read_field_{{field.cpp_name}}(){{#else}}{{field.cpp_storage_name}}{{/if}}
{{/let partial}}

{{! The default value for a field. }}
{{#let export partial default_value |field| captures |const_value types intrinsic_default|}}
{{#pragma ignore-newlines}}
  {{#if (object.notnull? field.cpp_first_adapter)}}
::apache::thrift::adapt_detail::fromThriftField<{{field.cpp_first_adapter}}, {{field.id}}>(
{{#if field.cpp_exactly_one_adapter?}}{{field.cpp_standard_type}}({{#else}}{{#partial types.adapter_pre type=field.type}}{{/if}}
  {{/if (object.notnull? field.cpp_first_adapter)}}
  {{#if (object.notnull? field.default_value)}}
{{#partial const_value.iterate_const_values value=field.default_value root_const=null}}
  {{#else}}
{{#partial intrinsic_default field=field}}
  {{/if (object.notnull? field.default_value)}}
  {{#if (object.notnull? field.cpp_first_adapter)}}
{{#if field.cpp_exactly_one_adapter?}}){{#else}}{{#partial types.adapter_post type=field.type}}{{/if}}
, *this)
  {{/if (object.notnull? field.cpp_first_adapter)}}
{{/let partial}}

{{#let export partial member |field struct|}}
{{#pragma ignore-newlines}}
{{#if struct.union?}}value_.{{#else}}this->{{/if}}{{field.cpp_storage_name}}
{{/let partial}}

{{! A reference to the field's value. Dereferences pointers and wraps in (). }}
{{#let export partial field_ref |field struct| captures |member|}}
{{#pragma ignore-newlines}}
{{#if field.cpp_ref?}}(*{{#partial member field=field struct=struct}}){{#else}}{{#partial member field=field struct=struct}}{{/if}}
{{/let partial}}

{{! If an optional field is set. }}
{{#let export partial optional_has_value |field struct| captures |member|}}
{{#if field.cpp_ref?}}{{!
}}{{#if field.lazy?}}!(__fbthrift_isDeserialized_.{{field.cpp_name}} & ::apache::thrift::detail::LazyDeserializationState::DESERIALIZED) ||
    {{/if field.lazy?}}{{#partial member field=field struct=struct}}{{!
}}{{#else}}this->__isset.get({{field.isset_index}}){{/if field.cpp_ref?}}{{!
}}{{/let partial}}

{{! Whether a terse field has no value (is empty/default). }}
{{#let export partial terse_has_no_value |field struct| captures |member tag|}}
{{#pragma ignore-newlines}}
  {{#if field.intern_boxed_ref?}}
({{#partial member field=field struct=struct}}.get() == &::apache::thrift::op::getIntrinsicDefault<{{#partial tag field=field struct=struct}}>() || ::apache::thrift::op::isEmpty<{{#partial tag field=field struct=struct}}>(*{{#partial member field=field struct=struct}}))
  {{#else}}
{{#if field.cpp_ref?}}{{#partial member field=field struct=struct}} && {{/if}}::apache::thrift::op::isEmpty<{{#partial tag field=field struct=struct}}>({{#if field.cpp_ref?}}*{{/if}}{{#partial member field=field struct=struct}})
  {{/if field.intern_boxed_ref?}}
{{/let partial}}

{{! Whether a deprecated terse field has a value. }}
{{#let export partial deprecated_terse_has_value |field struct| captures |member tag field_ref default_value|}}
{{#pragma ignore-newlines}}
{{! Must not be null. }}
  {{#if field.cpp_ref?}}
{{#partial member field=field struct=struct}}
  {{/if field.cpp_ref?}}
{{! Must not be empty. }}
  {{#if field.type.container?}}
{{#if field.cpp_ref?}} && {{/if}}!::apache::thrift::op::isEmpty<{{#partial tag field=field struct=struct}}>({{#if field.cpp_ref?}}*{{/if}}{{#partial member field=field struct=struct}})
  {{/if field.type.container?}}
  {{#if field.raw_string_or_binary?}}
{{#if field.cpp_ref?}} && {{/if}}!::apache::thrift::op::isEmpty<{{#partial tag field=field struct=struct}}>({{#if field.cpp_ref?}}*{{/if}}{{#partial member field=field struct=struct}})
  {{/if field.raw_string_or_binary?}}
  {{#if (and (not field.cpp_ref?) (not field.type.container?) (not field.raw_string_or_binary?))}}
    {{#if (object.notnull? field.cpp_first_adapter)}}
{{! Must check against the default constructor (ignoring any IDL-specified default). }}
!::apache::thrift::op::equal<{{#partial tag field=field struct=struct}}>({{#partial member field=field struct=struct}}, {{field.cpp_type}}())
    {{#else}}
{{! For all other cases, must not equal the default. }}
{{#partial field_ref field=field struct=struct}} != {{#partial default_value field=field}}
    {{/if (object.notnull? field.cpp_first_adapter)}}
  {{/if (and (not field.cpp_ref?) (not field.type.container?) (not field.raw_string_or_binary?))}}
{{/let partial}}
