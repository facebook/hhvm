{{!
  Annotations on generated patch structs implicitly assume all dependencies
  of `thrift/annotation/patch.thrift` are immediately available in the
  crate, e.g. they require a dependency on `thrift/annotation/cpp.thrift`.

  This might be fine in C++, but Rust crates have isolated dependencies, so
  this doesn't work for us. Disable generating annotations on patch structs
  for now.
}}
  {{! Use a partial so we can apply standalone indentation to this whole line,
      propagating the indentation level to `const_value` even though that partial
      is not rendered on a standalone line. }}
  {{#let partial declare_annot_tmp_var |value| captures |constants|}}
let mut tmp = ::std::option::Option::Some({{#partial constants.const_value value=value}});
  {{/let partial}}
  {{#if (not structured.generated?)}}
impl ::fbthrift::metadata::ThriftAnnotations for {{structured.rust_name}} {
    fn get_structured_annotation<T: Sized + 'static>() -> ::std::option::Option<T> {
        {{! We can't use a match statement as `TypeId::of` must be const, which is blocked by
            https://github.com/rust-lang/rust/issues/77125.

            We assume there won't be a large number of annotations, so linear search should
            be fine here.
        }}
        #[allow(unused_variables)]
        let type_id = ::std::any::TypeId::of::<T>();
    {{#each structured.structured_annotations as |annot|}}

        {{#let underlying_type=(if annot.type.typedef? annot.type.inner_new_type annot.type)}}
        if type_id == ::std::any::TypeId::of::<{{#partial types.type_name type=underlying_type}}>() {
            {{#partial declare_annot_tmp_var value=annot.value}}
            let r: &mut dyn ::std::any::Any = &mut tmp;
            let r: &mut ::std::option::Option<T> = r.downcast_mut().unwrap();
            return r.take();
        }
      {{#if annot.type.transitive?}}

        if let ::std::option::Option::Some(r) = <{{#partial types.type_name type=annot.type}} as ::fbthrift::metadata::ThriftAnnotations>::get_structured_annotation::<T>() {
            return ::std::option::Option::Some(r);
        }
      {{/if annot.type.transitive?}}
    {{/each}}

        ::std::option::Option::None
    }

    fn get_field_structured_annotation<T: Sized + 'static>(field_id: ::std::primitive::i16) -> ::std::option::Option<T> {
        #[allow(unused_variables)]
        let type_id = ::std::any::TypeId::of::<T>();

        #[allow(clippy::match_single_binding)]
        match field_id {
    {{#each structured.fields as |field|}}
            {{field.id}} => {
      {{#each field.structured_annotations as |annot|}}

                {{#let underlying_type=(if annot.type.typedef? annot.type.inner_new_type annot.type)}}
                if type_id == ::std::any::TypeId::of::<{{#partial types.type_name type=underlying_type}}>() {
                    {{#partial declare_annot_tmp_var value=annot.value}}
                    let r: &mut dyn ::std::any::Any = &mut tmp;
                    let r: &mut ::std::option::Option<T> = r.downcast_mut().unwrap();
                    return r.take();
                }
        {{#if annot.type.transitive?}}

                if let ::std::option::Option::Some(r) = <{{#partial types.type_name type=annot.type}} as ::fbthrift::metadata::ThriftAnnotations>::get_structured_annotation::<T>() {
                    return ::std::option::Option::Some(r);
                }
        {{/if annot.type.transitive?}}
      {{/each}}
            },
    {{/each}}
            _ => {}
        }

        ::std::option::Option::None
    }
}
  {{/if (not structured.generated?)}}
