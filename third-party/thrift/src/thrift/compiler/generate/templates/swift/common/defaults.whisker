{{! Renders the intrinsic Swift default value for a non-optional field with no
    explicit Thrift default. Enums default to the case for raw value 0
    (`.init(rawValue: 0)`), matching the Object Model's Int32(0) default; for an
    enum with no declared 0 case this is `.unknown(0)`. Struct/list/set/map use
    leading-dot / literal syntax that infers the annotated property type. }}
{{#let export partial swift_default_value |type|}}
  {{#pragma ignore-newlines}}
{{#if type.typedef?}}{{#partial swift_default_value type=type.true_type}}
{{#else if type.bool?}}false
{{#else if type.byte?}}0
{{#else if type.i16?}}0
{{#else if type.i32?}}0
{{#else if type.i64?}}0
{{#else if type.float?}}0.0
{{#else if type.double?}}0.0
{{#else if type.string?}}""
{{#else if type.binary?}}Data()
{{#else if type.enum?}}.init(rawValue: 0)
{{#else if type.list?}}[]
{{#else if type.set?}}[]
{{#else if type.map?}}[:]
{{#else if type.structured?}}.init()
{{#else}}.init()
{{/if type.typedef?}}
{{/let partial}}
