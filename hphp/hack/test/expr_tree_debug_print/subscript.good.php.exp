abstract class PropVec {
  public vec<ExampleInt> $items;
}

abstract class PropNestedVec {
  public vec<vec<ExampleInt>> $nested;
}

abstract class PropVecOfObj {
  public vec<PropVec> $children;
}

abstract class PropBaz {
  public vec<vec<ExampleInt>> $baz;
}

abstract class PropBarOfBaz {
  public vec<vec<PropBaz>> $bar;
}

abstract class PropDict {
  public dict<ExampleInt, ExampleInt> $data;
}

abstract class PropDeepVecOfObj {
  public vec<vec<PropVec>> $deep;
}

abstract class PropDeepVecOfNested {
  public vec<vec<PropNestedVec>> $deep;
}

function test_mixed_read_prop_sub(): void {
  ExampleDsl::makeTree(
    darray[
      "path" => __FILE__,
      "start_line" => 62,
      "end_line" => 62,
      "start_column" => 13,
      "end_column" => 66,
    ],
    darray[
      "splices" => dict[],
      "functions" => vec[],
      "static_methods" => vec[],
      "variables" => vec[],
      "lexically_enclosing_tree" => NULL,
    ],
    (
      (ExampleDsl $v) ==> {
        return $v->visitLambda(
          darray[
            "path" => __FILE__,
            "start_line" => 62,
            "end_line" => 62,
            "start_column" => 13,
            "end_column" => 66,
          ],
          vec["$obj", "$idx"],
          vec[
            $v->visitReturn(
              darray[
                "path" => __FILE__,
                "start_line" => 62,
                "end_line" => 62,
                "start_column" => 49,
                "end_column" => 66,
              ],
              $v->visitSubscript(
                darray[
                  "path" => __FILE__,
                  "start_line" => 62,
                  "end_line" => 62,
                  "start_column" => 49,
                  "end_column" => 66,
                ],
                $v->visitPropertyAccess(
                  darray[
                    "path" => __FILE__,
                    "start_line" => 62,
                    "end_line" => 62,
                    "start_column" => 49,
                    "end_column" => 60,
                  ],
                  $v->visitLocal(
                    darray[
                      "path" => __FILE__,
                      "start_line" => 62,
                      "end_line" => 62,
                      "start_column" => 49,
                      "end_column" => 53,
                    ],
                    "$obj",
                  ),
                  "items",
                ),
                $v->visitLocal(
                  darray[
                    "path" => __FILE__,
                    "start_line" => 62,
                    "end_line" => 62,
                    "start_column" => 61,
                    "end_column" => 65,
                  ],
                  "$idx",
                ),
              ),
            ),
          ],
        );
      }
    ),
  );
}

