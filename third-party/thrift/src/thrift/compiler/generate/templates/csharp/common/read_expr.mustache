{{#import "common/types" as types}}

{{! Renders a C# reader method call expression for a given Thrift type.
    Maps primitive types to direct reader method calls.
    Enums are read as i32 and cast to the enum type.
    Structs use the generic ReadStruct<T>() method.
    Containers are not handled here — templates handle those inline
    with loop expansion. }}
{{#let export partial csharp_read_expr |type| captures |types|}}
  {{#pragma ignore-newlines}}
{{#if type.bool?}}reader.ReadBool()
{{#else if type.byte?}}reader.ReadByte()
{{#else if type.i16?}}reader.ReadI16()
{{#else if type.i32?}}reader.ReadI32()
{{#else if type.i64?}}reader.ReadI64()
{{#else if type.float?}}reader.ReadFloat()
{{#else if type.double?}}reader.ReadDouble()
{{#else if type.string?}}reader.ReadString()
{{#else if type.binary?}}reader.ReadBinary()
{{#else if type.enum?}}({{#partial types.csharp_type type=type}})reader.ReadI32()
{{#else if type.structured?}}reader.ReadStruct<{{#partial types.csharp_type type=type}}>()
{{#else if type.list?}}reader.ReadList<{{#partial types.csharp_type type=type.elem_type}}>()
{{#else if type.set?}}reader.ReadSet<{{#partial types.csharp_type type=type.elem_type}}>()
{{#else if type.map?}}reader.ReadMap<{{#partial types.csharp_type type=type.key_type}}, {{#partial types.csharp_type type=type.val_type}}>()
{{/if type.bool?}}
{{/let partial}}
