{{!
  Private implementation for type name partials, to encapsulate circular deps.

  If we ever add a type here which may not have a Send or Sync impl, the
  unsafe impls in structimpl.whisker need to be revisited.
}}
{{#let partial type_name_impl |type raw|}}
{{#pragma ignore-newlines}}
  {{#if (and (not raw) type.typedef? (not type.type_annotation?))}}
  {{! This first line is the only output for "non-raw" meeting the remaining conditions }}
{{type.package}}::{{type.rust_name}}
  {{#else}}
{{#if (not (string.empty? type.rust_type))}}::{{type.rust_type}}
{{#else if type.void?}}()
{{#else if type.bool?}}::std::primitive::bool
{{#else if type.byte?}}::std::primitive::i8
{{#else if type.i16?}}::std::primitive::i16
{{#else if type.i32?}}::std::primitive::i32
{{#else if type.i64?}}::std::primitive::i64
{{#else if type.double?}}::std::primitive::f64
{{#else if type.float?}}::std::primitive::f32
{{#else if type.string?}}::std::string::String
{{#else if type.binary?}}::std::vec::Vec<::std::primitive::u8>
{{#else if type.structured?}}{{type.true_type.package}}{{#if type.true_type.has_adapter?}}::unadapted{{/if}}::{{type.true_type.rust_name}}
{{#else if type.enum?}}{{type.true_type.package}}::{{type.true_type.rust_name}}
{{#else if type.list?}}::std::vec::Vec
{{#else if type.set?}}::std::collections::BTreeSet
{{#else if type.map?}}::std::collections::BTreeMap
    {{/if (not (string.empty? type.rust_type))}}
  {{! Type generic suffix for containers }}
    {{#if type.list?}}
<{{#partial type_name_impl type=type.true_type.elem_type raw=false}}>
    {{#else if type.set?}}
      {{#let elem_type = type.true_type.elem_type}}
      {{#if elem_type.floating_point?}}
<::fbthrift::export::OrderedFloat<{{#partial type_name_impl type=elem_type raw=false}}>>
      {{#else}}
<{{#partial type_name_impl type=elem_type raw=false}}>
    {{/if elem_type.floating_point?}}
    {{#else if type.map?}}
<
      {{#let key_type = type.true_type.key_type}}
      {{#if key_type.floating_point?}}
::fbthrift::export::OrderedFloat<{{#partial type_name_impl type=key_type raw=false}}>
      {{#else}}
{{#partial type_name_impl type=key_type raw=false}}
    {{/if key_type.floating_point?}}
, {{#partial type_name_impl type=type.true_type.val_type raw=false}}>
    {{/if type.list?}}
  {{/if (and (not raw) type.typedef? (not type.type_annotation?))}}
{{/let partial}}


{{! Externally visible partials for type name }}
{{#let export partial type_name |type| captures |type_name_impl|}}
{{#pragma ignore-newlines}}
{{#partial type_name_impl type=type raw=false}}
{{/let partial}}


{{#let export partial raw_type_name |type| captures |type_name_impl|}}
{{#pragma ignore-newlines}}
{{#partial type_name_impl type=type raw=true}}
{{/let partial}}


{{! Type generic suffix for containers }}
{{#let export partial type_generics |type| captures |type_name_impl|}}
{{#pragma ignore-newlines}}
  {{#if type.list?}}
<{{#partial type_name_impl type=type.true_type.elem_type raw=false}}>
  {{#else if type.set?}}
    {{#let elem_type = type.true_type.elem_type}}
    {{#if elem_type.floating_point?}}
<::fbthrift::export::OrderedFloat<{{#partial type_name_impl type=elem_type raw=false}}>>
    {{#else}}
<{{#partial type_name_impl type=elem_type raw=false}}>
    {{/if elem_type.floating_point?}}
  {{#else if type.map?}}
<
    {{#let key_type = type.true_type.key_type}}
    {{#if key_type.floating_point?}}
::fbthrift::export::OrderedFloat<{{#partial type_name_impl type=key_type raw=false}}>
    {{#else}}
{{#partial type_name_impl type=key_type raw=false}}
    {{/if key_type.floating_point?}}
, {{#partial type_name_impl type=type.true_type.val_type raw=false}}>
  {{/if type.list?}}
{{/let partial}}


{{#let export partial protocol_ttype |type|}}
{{#pragma ignore-newlines}}
::fbthrift::TType::
{{#if type.void?}}Void
{{#else if type.string?}}String
{{#else if type.binary?}}String
{{#else if type.bool?}}Bool
{{#else if type.byte?}}Byte
{{#else if type.i16?}}I16
{{#else if type.i32?}}I32
{{#else if type.i64?}}I64
{{#else if type.double?}}Double
{{#else if type.float?}}Float
{{#else if type.structured?}}Struct
{{#else if type.enum?}}I32
{{#else if type.list?}}List
{{#else if type.set?}}Set
{{#else if type.map?}}Map
{{/if type.void?}}
{{/let partial}}


{{#let export partial write |type|}}
{{#pragma ignore-newlines}}
  {{! Use non-standard write implementation if the type is non-standard, and isn't a new-type annotated typedef }}
  {{#let non_standard = (and type.nonstandard? (not (and type.typedef? type.newtype?)))}}
{{#if non_standard}}{{root_program.crate}}::r#impl{{#else}}::fbthrift::Serialize{{/if}}::rs_thrift_write
{{/let partial}}


{{#let export partial read |type|}}
{{#pragma ignore-newlines}}
  {{! Use non-standard read implementation if the type is non-standard, and isn't a new-type annotated typedef }}
  {{#let non_standard = (and type.nonstandard? (not (and type.typedef? type.newtype?)))}}
{{#if non_standard}}{{root_program.crate}}::r#impl{{#else}}::fbthrift::Deserialize{{/if}}::rs_thrift_read
{{/let partial}}
