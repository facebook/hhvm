}}{{!

This is used to resolve container converter prefix. The prefix used depends whether
referenced from types.pyx main file, field_setter, or container converter.

}}
{{! Non-simple types live in shared_ptr in containers }}
{{#let partial cython_cpp_container_item_type |type| captures |types|}}
{{#pragma ignore-newlines}}
  {{#let needs_shared_ptr=(or type.customBinaryType? (not (or type.primitive? type.enum? type.container?)))}}
  {{#if needs_shared_ptr}}
shared_ptr[{{#partial types.cython_cpp_type type=type}}]
  {{#else}}
{{#partial types.cython_cpp_type type=type}}
  {{/if needs_shared_ptr}}
{{/let partial}}
{{! Default value for number and bool types }}
{{#let partial type_default_value |type|}}
{{#pragma ignore-newlines}}
{{#if type.number?}} = 0{{#else if type.bool?}} = False{{/if}}
{{/let partial}}{{!

container to cpp converter }}
cdef {{#partial types.cython_cpp_type type=type}} {{type.flat_name}}__make_instance(object items) except *:
{{#partial types.make_instance type=type}}

  {{#if type.list?}}
    {{#let elem_type=type.true_type.elem_type}}
cdef object {{type.flat_name}}__from_cpp(const {{#partial types.cython_cpp_type type=type}}& c_vec) except *:
    cdef list py_list = []
    cdef int idx = 0
    for idx in range(c_vec.size()):
        py_list.append({{#partial types.vector_cpp_to_python elem_type=elem_type}})
    return {{type.flat_name}}(py_list, thrift.py3.types._fbthrift_list_private_ctor)
  {{#else if type.set?}}
    {{#let elem_type=type.true_type.elem_type}}
cdef object {{type.flat_name}}__from_cpp(const {{#partial types.cython_cpp_type type=type}}& c_set) except *:
    cdef list py_items = []
    cdef __set_iter[{{#partial types.cython_cpp_type type=type}}] iter = __set_iter[{{#partial types.cython_cpp_type type=type}}](c_set)
    cdef {{#partial cython_cpp_container_item_type type=elem_type}} citem{{#partial type_default_value type=elem_type}}
    for i in range(c_set.size()):
        iter.genNextItem(citem)
        py_items.append({{#partial types.set_cpp_to_python elem_type=elem_type}})
    return {{type.flat_name}}(frozenset(py_items), thrift.py3.types._fbthrift_set_private_ctor)
  {{#else if type.map?}}
    {{#let key_type=type.true_type.key_type}}
    {{#let val_type=type.true_type.val_type}}
cdef object {{type.flat_name}}__from_cpp(const {{#partial types.cython_cpp_type type=type}}& c_map) except *:
    cdef dict py_items = {}
    cdef __map_iter[{{#partial types.cython_cpp_type type=type}}] iter = __map_iter[{{#partial types.cython_cpp_type type=type}}](c_map)
    cdef {{#partial cython_cpp_container_item_type type=key_type}} ckey{{#partial type_default_value type=key_type}}
    cdef {{#partial cython_cpp_container_item_type type=val_type}} cval{{#partial type_default_value type=val_type}}
    for i in range(c_map.size()):
        iter.genNextKeyVal(ckey, cval)
        py_items[{{#partial types.map_key_cpp_to_python type=key_type}}] = {{#partial types.map_val_cpp_to_python type=val_type}}
    return {{type.flat_name}}(py_items, private_ctor_token=thrift.py3.types._fbthrift_map_private_ctor)
  {{/if type.list?}}
