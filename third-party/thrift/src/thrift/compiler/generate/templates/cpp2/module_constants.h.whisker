{{#import "common/const_value" as const_value}}
{{#import "common/glean" as glean}}
{{> Autogen}}
#pragma once

#include <thrift/lib/cpp2/gen/module_constants_h.h>

#include "{{program.include_prefix}}{{program.name}}_types.h"

namespace {{program.cpp_qualified_namespace}} {
{{#partial glean.program_docblock}}
namespace {{program.name}}_constants {

  {{#each program.consts as |const|}}
    {{#if const.outline_init?}}
  {{#partial glean.const_docblock const=const}}  {{const.cpp_type}} const& {{const.name}}();
    {{#else if const.generated?}}
      {{! The generated constants check is intended to cover the schema constant, where the _sinit.cpp target has to use external linkage to break a dependency cycle. }}
  FOLLY_EXPORT {{#partial const_value.const_value_type const=const}} {{const.name}}();
    {{#else}}
      {{#if const.type.binary?}}
  {{#partial glean.const_docblock const=const}}  constexpr ::std::string_view {{const.name}}_{"{{const.rendered_value.value.string_value}}", {{const.rendered_value.value.string_length}}};
      {{#else}}
  {{#partial glean.const_docblock const=const}}  constexpr {{#partial const_value.const_value_type const=const}} const {{const.name}}_ = {{#partial const_value.primitive value=const.rendered_value}};
      {{/if const.type.binary?}}
  {{#partial glean.const_docblock const=const}}  constexpr {{#partial const_value.const_value_type const=const}} {{const.name}}() {
    return {{const.name}}_;
  }
    {{/if const.outline_init?}}

  {{/each}}
{{! Generate empty schema const if none was injected. }}
  {{#if (not program.has_schema_const?)}}
  FOLLY_EXPORT ::std::string_view {{program.schema_const_name}}();
  {{/if (not program.has_schema_const?)}}
  FOLLY_EXPORT ::folly::Range<const ::std::string_view*> {{program.schema_const_name}}_includes();
  FOLLY_EXPORT ::folly::Range<const ::std::string_view*> {{program.schema_const_name}}_uris();

} // namespace {{program.name}}_constants
} // namespace {{program.cpp_qualified_namespace}}
