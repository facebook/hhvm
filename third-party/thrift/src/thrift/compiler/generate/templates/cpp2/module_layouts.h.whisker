#pragma once

#include <thrift/lib/cpp2/frozen/Frozen.h>
#include "{{program.include_prefix}}{{program.name}}_types.h"
  {{#each program.includes_for_codegen as |include|}}
#include "{{include.program.include_prefix}}{{include.program.name}}_layouts.h"
  {{/each}}
namespace apache::thrift::frozen {

  {{#each program.type_definitions_topological_order as |def|}}
    {{#if (and (not def.typedef?) def.cpp_frozen2_exclude?)}}
FROZEN_EXCLUDE_TYPE({{def.cpp_fullname}})
    {{/if (and (not def.typedef?) def.cpp_frozen2_exclude?)}}
  {{/each}}

  {{#each program.type_definitions_topological_order as |def|}}
    {{#if (not (or def.typedef? def.cpp_frozen2_exclude?))}}
      {{#if (not def.union?)}}
FROZEN_TYPE({{def.cpp_fullname}},{{!
}}{{#each def.fields as |field|}}
  FROZEN_FIELD{{#partial module_layouts.field_suffix field=field}}({{field.cpp_name}}, {{field.id}}, {{field.cpp_storage_type}}){{!
}}{{/each}}
  FROZEN_VIEW({{!
}}{{#each def.fields as |field|}}
    FROZEN_VIEW_FIELD{{#partial module_layouts.field_suffix field=field}}({{field.cpp_name}}, {{field.cpp_storage_type}}){{!
}}{{/each}})
  FROZEN_SAVE_INLINE({{!
}}{{#each def.fields as |field|}}
    FROZEN_SAVE_FIELD({{field.cpp_name}}){{!
}}{{/each}})
  FROZEN_LOAD_INLINE({{!
}}{{#each def.fields as |field|}}
    FROZEN_LOAD_FIELD({{field.cpp_name}}, {{field.id}}){{!
}}{{/each}}));
      {{#else}}
FROZEN_TYPE({{def.cpp_fullname}},{{!
}}
  FROZEN_FIELD(fbthrift_type_, 0, {{def.cpp_fullname}}::Type){{!
}}{{#each def.fields as |field|}}
  FROZEN_FIELD{{#partial module_layouts.frozen2_union_field_suffix field=field}}({{field.cpp_name}}, {{field.id}}, {{field.cpp_storage_type}}){{!
}}{{/each}}
  struct View : public ViewBase<View, LayoutSelf, {{def.cpp_fullname}}> {
    {{def.cpp_fullname}}::Type fbthrift_type_;
    View() : fbthrift_type_({{def.cpp_fullname}}::Type::__EMPTY__) {}
    View(const LayoutSelf* layout, ViewPosition position)
        : ViewBase<View, LayoutSelf, {{def.cpp_fullname}}>(layout, position) {
      fbthrift_type_ = this->layout_->fbthrift_type_Field.layout.view(this->position_(this->layout_->fbthrift_type_Field.pos));
      switch (fbthrift_type_) {
        {{#each def.fields as |field|}}
        case {{def.cpp_fullname}}::Type::{{field.cpp_name}}: {
          break;
        }
        {{/each}}
        default: {
          fbthrift_type_ = {{def.cpp_fullname}}::Type::__EMPTY__;
        }
      }
    }

    {{def.cpp_fullname}}::Type getType() {return fbthrift_type_;}

    {{#each def.fields as |field|}}
    auto get_{{field.cpp_name}}() const {
      assert(fbthrift_type_ == {{def.cpp_fullname}}::Type::{{field.cpp_name}});
      return this->layout_->{{field.cpp_name}}Field.layout.view(
          this->position_(this->layout_->{{field.cpp_name}}Field.pos));
    }
    {{/each}}
  };

  View view(ViewPosition self) const {
    return View(this, self);
  }
  FROZEN_SAVE_INLINE({{!
}}
    FROZEN_SAVE_FIELD(fbthrift_type_){{!
}}{{#each def.fields as |field|}}
    FROZEN_SAVE_FIELD({{field.cpp_name}}){{!
}}{{/each}})
  FROZEN_LOAD_INLINE({{!
}}
    FROZEN_LOAD_FIELD(fbthrift_type_, 0){{!
}}{{#each def.fields as |field|}}
    FROZEN_LOAD_FIELD({{field.cpp_name}}, {{field.id}}){{!
}}{{/each}}));
      {{/if (not def.union?)}}

    {{/if (not (or def.typedef? def.cpp_frozen2_exclude?))}}
  {{/each}}
} // apache::thrift::frozen
