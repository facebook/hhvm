}}{{!

Python wrappers of the structs defined in the services files. This file is
compiled into it's own module to be included by clients and services and
end-user code. It's one of the more complicated files, as it has to map
Pythonic APIs to C++ objects and back.

One of the nastier things in this file is the definition of containers.
A separate container wrapper has to be defined for each type of contained
attribute because Cython can't template C++ classes. So, for example, we need
a List__int16 or a List__string or a Map__string_mystruct instance for each
container/type combination. Consider that containers can contain other containers
or structs that contain containers and you realize how messy this can get.
Further, we'd prefer to have the end user freed from having to know about these
container types, so we'll need to define factories for them based on what they
want to include.

}}
{{#import "common/types" as types}}
{{#import "common/common" as common}}
{{! Additional information for number types }}
{{#let partial thrift_number_type |type|}}
{{#pragma ignore-newlines}}
{{#if type.byte?}}__NumberType.BYTE
{{#else if type.i16?}}__NumberType.I16
{{#else if type.i32?}}__NumberType.I32
{{#else if type.i64?}}__NumberType.I64
{{#else if type.double?}}__NumberType.DOUBLE
{{#else if type.float?}}__NumberType.FLOAT
{{#else if (not type.number?)}}__NumberType.NOT_A_NUMBER
{{/if type.byte?}}
{{/let partial}}{{!

}}
{{> common/auto_generated_py}}


import folly.iobuf as _fbthrift_iobuf

from thrift.py3.reflection import (
    NumberType as __NumberType,
    StructType as __StructType,
    Qualifier as __Qualifier,
    StructSpec as __StructSpec,
    ListSpec as __ListSpec,
    SetSpec as __SetSpec,
    MapSpec as __MapSpec,
    FieldSpec as __FieldSpec,
)

{{#each program.includeNamespaces as |include|}}
  {{#if include.has_types?}}
try:
    import {{include.modulePathPeriodSeparated}}.types as _{{include.modulePathUnderscoreSeparated}}_types
except ModuleNotFoundError:
    import {{include.modulePathPeriodSeparated}}.thrift_types as _{{include.modulePathUnderscoreSeparated}}_types
  {{/if include.has_types?}}
{{/each}}

try:
    import {{#each program.py3Namespaces as |ns|}}{{ns}}.{{/each}}{{program.name}}.types as _{{#each program.py3Namespaces as |ns|}}{{ns}}_{{/each}}{{program.name}}_types
except ModuleNotFoundError:
    import {{#each program.py3Namespaces as |ns|}}{{ns}}.{{/each}}{{program.name}}.thrift_types as _{{#each program.py3Namespaces as |ns|}}{{ns}}_{{/each}}{{program.name}}_types



{{#each program.py3_visible_structured_definitions as |struct|}}
def get_reflection__{{struct.name}}() -> __StructSpec:
    spec: __StructSpec = __StructSpec._fbthrift_create(
        name="{{struct.name}}",
        kind=__StructType.{{!
            }}{{#if struct.exception?}}EXCEPTION{{!
            }}{{#else if struct.union?}}UNION{{!
            }}{{#else}}STRUCT{{/if struct.exception?}},
        annotations={
            {{#each struct.unstructured_annotations as |annot|}}
            {{#partial common.annotation annot=annot}}
            {{/each}}
        },
    )
  {{#each (array.enumerate struct.py3_fields with_first=true) as |i field is_first_field?|}}
    {{#if (and is_first_field? struct.has_defaulted_fields?)}}
    defaults = _{{#each program.py3Namespaces as |ns|}}{{ns}}_{{/each}}{{program.name}}_types.{{struct.name}}()
    {{/if (and is_first_field? struct.has_defaulted_fields?)}}
    spec.add_field(
        __FieldSpec._fbthrift_create(
            id={{field.id}},
            name="{{field.name}}",
            py_name="{{field.py_name}}",
            type={{#partial types.python_type type=field.type}},
            kind={{#partial thrift_number_type type=field.type}},
            qualifier=__Qualifier.{{!
                }}{{#if field.required?}}REQUIRED{{!
                }}{{#else if field.optional?}}OPTIONAL{{!
                }}{{#else}}UNQUALIFIED{{/if field.required?}},
            default={{!
            }}{{#if struct.union?}}None{{!
            }}{{#else if (object.notnull? field.default_value)}}defaults.{{field.name}}{{!
            }}{{#else}}None{{/if struct.union?}},
            annotations={
                {{#each field.unstructured_annotations as |annot|}}
                {{#partial common.annotation annot=annot}}
                {{/each}}
            },
        ),
    )
  {{/each}}
    return spec
{{/each}}
{{#each program.container_types as |type|}}
  {{#if type.list?}}
def get_reflection__{{type.flat_name}}() -> __ListSpec :
    return __ListSpec._fbthrift_create(
        value={{#partial types.python_type type=type.true_type.elem_type}},
        kind={{#partial thrift_number_type type=type.true_type.elem_type}},
    )
  {{#else if type.set?}}
def get_reflection__{{type.flat_name}}() -> __SetSpec:
    return __SetSpec._fbthrift_create(
        value={{#partial types.python_type type=type.true_type.elem_type}},
        kind={{#partial thrift_number_type type=type.true_type.elem_type}},
     )
  {{#else if type.map?}}
def get_reflection__{{type.flat_name}}() -> __MapSpec:
    return __MapSpec._fbthrift_create(
        key={{#partial types.python_type type=type.true_type.key_type}},
        key_kind={{#partial thrift_number_type type=type.true_type.key_type}},
        value={{#partial types.python_type type=type.true_type.val_type}},
        value_kind={{#partial thrift_number_type type=type.true_type.val_type}},
    )
  {{/if type.list?}}

{{/each}}
