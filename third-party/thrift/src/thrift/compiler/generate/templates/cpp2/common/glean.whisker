{{! Program docblock - Glean annotation for identifying thrift sources }}
{{#let export partial program_docblock}}
/** Glean {"file": "{{root_program.autogen_path}}"} */
{{/let partial}}

{{! Constant docblock - Glean annotation for mapping generated constants to thrift constants }}
{{#let export partial const_docblock |const|}}
/** Glean {"constant": "{{const.name}}"} */
{{/let partial}}

{{! Field docblock - Glean annotation for mapping generated methods to thrift fields }}
{{#let export partial field_docblock |field|}}
/** Glean { "field": "{{field.cpp_name}}" } */
{{/let partial}}

{{! Glean annotation to map generated functions to thrift enums. }}
{{#let export partial enum_docblock |enum|}}
/** Glean {"file": "{{enum.program.autogen_path}}", "name": "{{enum.cpp_name}}", "kind": "enum" } */
{{/let partial}}

{{! Class docblock - Glean annotation for mapping generated classes to thrift structs/unions/exceptions }}
{{#let export partial class_docblock |struct|}}
/** Glean {"file": "{{struct.program.autogen_path}}", "name": "{{struct.cpp_underlying_name}}", "kind": "{{#if struct.exception?}}exception{{#else if struct.union?}}union{{#else}}struct{{/if}}" } */
{{/let partial}}

{{! Typedef docblock - Glean annotation for mapping generated typedefs to thrift typedefs }}
{{#let export partial typedef_docblock |def|}}
/** Glean {"file": "{{def.program.autogen_path}}", "name": "{{def.name}}", "kind": "typedef" } */
{{/let partial}}

{{! Function docblock - Glean annotation for mapping generated functions to thrift definitions }}
{{#let export partial function_docblock |service function|}}
  /** Glean {"file": "{{service.program.autogen_path}}", "service": "{{service.name}}", "function": "{{function.name}}"} */
{{/let partial}}
