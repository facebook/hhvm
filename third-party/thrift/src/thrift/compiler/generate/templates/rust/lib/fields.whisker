{{#import "lib/types" as types}}

{{#let export partial annotated_type_name |field| captures |types|}}
{{#pragma ignore-newlines}}
{{#if (not (string.empty? field.rust_type))}}::{{field.rust_type}}
{{#else if field.type.string?}}::std::string::String
{{#else if field.type.structured?}}{{field.type.true_type.package}}{{#if field.type.true_type.has_adapter?}}::unadapted{{/if}}::{{field.type.true_type.rust_name}}
{{#else if field.type.enum?}}{{field.type.true_type.package}}::{{field.type.true_type.rust_name}}
{{#else if field.type.list?}}::std::vec::Vec
{{/if (not (string.empty? field.rust_type))}}
{{#if field.type.container?}}{{#partial types.type_generics type=field.type}}{{/if}}
{{/let partial}}


{{#let export partial type_name |field| captures |types annotated_type_name|}}
{{#pragma ignore-newlines}}
{{#if field.optional?}}::std::option::Option<{{/if}}
{{#if field.box?}}::std::boxed::Box<{{/if}}
{{#if field.arc?}}::std::sync::Arc<{{/if}}
  {{#if field.type_annotation?}}
{{#partial annotated_type_name field=field}}
  {{#else if field.has_adapter?}}
{{field.adapter_qualified}}::AdaptedType
  {{#else}}
{{#partial types.type_name type=field.type}}
  {{/if field.type_annotation?}}
{{#if field.arc?}}>{{/if}}
{{#if field.box?}}>{{/if}}
{{#if field.optional?}}>{{/if}}
{{/let partial}}


{{#let export partial write |field| captures |types|}}
{{#pragma ignore-newlines}}
  {{#if field.type_annotation?}}
{{#if field.type_nonstandard?}}{{root_program.crate}}::r#impl{{#else}}::fbthrift::Serialize{{/if}}::rs_thrift_write
  {{#else}}
{{#partial types.write type=field.type}}
  {{/if field.type_annotation?}}
{{/let partial}}


{{#let export partial read |field| captures |types|}}
{{#pragma ignore-newlines}}
  {{#if field.type_annotation?}}
{{#if field.type_nonstandard?}}{{root_program.crate}}::r#impl{{#else}}::fbthrift::Deserialize{{/if}}::rs_thrift_read
  {{#else}}
{{#partial types.read type=field.type}}
  {{/if field.type_annotation?}}
{{/let partial}}
