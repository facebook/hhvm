{{#import "common/client" as client}}
{{#import "common/rpc" as rpc}}

{{#let export partial function_implementation |interface parent_service function| captures |client rpc|}}
  {{#let function_comma = (if function.params.fields? ", " "")}}
  {{#if (not function.sink?)}}
    {{#if function.legacy_client_methods?}}
void {{#partial client.client_class_name service=interface parent_service=parent_service}}::{{function.cpp_name}}(std::unique_ptr<apache::thrift::RequestCallback> callback{{function_comma}}{{#partial client.function_param_list function=function}}) {
  ::apache::thrift::RpcOptions rpcOptions;
  {{function.cpp_name}}(rpcOptions, std::move(callback){{function_comma}}{{#partial rpc.param_list function=function}});
}
    {{/if function.legacy_client_methods?}}

void {{#partial client.client_class_name service=interface parent_service=parent_service}}::{{function.cpp_name}}(apache::thrift::RpcOptions& rpcOptions, std::unique_ptr<apache::thrift::RequestCallback> callback{{#if function.creates_interaction?}}, const apache::thrift::InteractionHandle& handle{{/if}}{{function_comma}}{{#partial client.function_param_list function=function}}) {
  auto [ctx, header] = {{function.cpp_name}}Ctx(&rpcOptions);
  if (ctx != nullptr) {
    auto argsAsRefs = std::tie({{#partial rpc.param_list function=function}});
    ctx->processClientInterceptorsOnRequest(apache::thrift::ClientInterceptorOnRequestArguments(argsAsRefs), header.get(), rpcOptions).throwUnlessValue();
  }
  auto [wrappedCallback, contextStack] = apache::thrift::GeneratedAsyncClient::template prepareRequestClientCallback<{{#if function.oneway?}}true{{#else}}false{{/if}} /* kIsOneWay */>(std::move(callback), std::move(ctx));
    {{#if function.stream?}}
  auto streamCallback = apache::thrift::createStreamClientCallback(std::move(wrappedCallback), rpcOptions.getBufferOptions());
    {{/if function.stream?}}
  fbthrift_serialize_and_send_{{function.cpp_name}}(rpcOptions, std::move(header), contextStack, {{#if function.stream?}}std::move(streamCallback){{#else}}std::move(wrappedCallback){{/if}}{{#if function.creates_interaction?}}, handle{{/if}}{{function_comma}}{{#partial rpc.param_list function=function}});
}

  {{/if (not function.sink?)}}
apache::thrift::SerializedRequest {{#partial client.client_class_name service=interface parent_service=parent_service}}::fbthrift_serialize_{{function.cpp_name}}(const RpcOptions& rpcOptions, apache::thrift::transport::THeader& header, apache::thrift::ContextStack* contextStack{{function_comma}}{{#partial client.function_param_list function=function}}) {
  return apache::thrift::detail::ac::withProtocolWriter(apache::thrift::GeneratedAsyncClient::getChannel()->getProtocolId(), [&](auto&& prot) {
    using ProtocolWriter = std::decay_t<decltype(prot)>;
    ::{{interface.cpp_qualified_namespace}}::{{#if interface.interaction?}}{{parent_service.cpp_name}}{{#else}}{{interface.cpp_name}}{{/if}}_{{function.prefixed_name}}_pargs args;
    {{#each (array.enumerate function.params.fields) as |param_index param|}}
    args.get<{{param_index}}>().value = {{#if param.type.resolves_to_complex_return?}}const_cast<{{param.type.cpp_type}}*>(&p_{{param.cpp_name}}){{#else}}&p_{{param.cpp_name}}{{/if}};
    {{/each}}
    const auto sizer = [&](ProtocolWriter* p) { return args.serializedSizeZC(p); };
    const auto writer = [&](ProtocolWriter* p) { args.write(p); };
    return apache::thrift::preprocessSendT<ProtocolWriter>(
        &prot,
        rpcOptions,
        contextStack,
        header,
        "{{#partial rpc.function_name service=interface function=function}}",
        writer,
        sizer,
        channel_->getChecksumSamplingRate(),
        getIOBufFactory());
  });
}

void {{#partial client.client_class_name service=interface parent_service=parent_service}}::fbthrift_serialize_and_send_{{function.cpp_name}}(apache::thrift::RpcOptions& rpcOptions, std::shared_ptr<apache::thrift::transport::THeader> header, apache::thrift::ContextStack* contextStack, {{#partial client.callback_type function=function}} callback{{#if function.creates_interaction?}}, const apache::thrift::InteractionHandle& handle{{/if}}{{function_comma}}{{#partial client.function_param_list function=function}}, bool stealRpcOptions) {
  apache::thrift::SerializedRequest request = fbthrift_serialize_{{function.cpp_name}}(rpcOptions, *header, contextStack{{function_comma}}{{#partial rpc.param_list function=function}});
  std::unique_ptr<folly::IOBuf> interceptorFrameworkMetadata = nullptr;
  if (contextStack != nullptr) {
    interceptorFrameworkMetadata = detail::ContextStackUnsafeAPI(*contextStack).getInterceptorFrameworkMetadata(rpcOptions);
  }
  if (stealRpcOptions) {
    fbthrift_send_{{function.cpp_name}}(std::move(request), std::move(rpcOptions), std::move(header), std::move(callback), std::move(interceptorFrameworkMetadata){{#if function.creates_interaction?}}, handle{{/if}});
  } else {
    fbthrift_send_{{function.cpp_name}}(std::move(request), rpcOptions, std::move(header), std::move(callback), std::move(interceptorFrameworkMetadata){{#if function.creates_interaction?}}, handle{{/if}});
  }
}

std::pair<::apache::thrift::ContextStack::UniquePtr, std::shared_ptr<::apache::thrift::transport::THeader>> {{#partial client.client_class_name service=interface parent_service=parent_service}}::{{function.cpp_name}}Ctx(apache::thrift::RpcOptions* rpcOptions) {
  auto header = std::make_shared<apache::thrift::transport::THeader>(
      apache::thrift::transport::THeader::ALLOW_BIG_FRAMES);
  header->setProtocolId(channel_->getProtocolId());
  if (rpcOptions) {
    // Use getWriteHeaders() (non-destructive copy) instead of
    // releaseWriteHeaders() so that RpcOptions retains headers across retries.
    auto writeHeaders = rpcOptions->getWriteHeaders();
    header->setHeaders(std::move(writeHeaders));
  }

  auto ctx = apache::thrift::ContextStack::createWithClientContext(
      handlers_,
      interceptors_,
      getServiceName(),
      "{{#if interface.interaction?}}{{parent_service.name}}{{#else}}{{interface.name}}{{/if}}.{{#partial rpc.function_name service=interface function=function}}",
      *header);

  return {std::move(ctx), std::move(header)};
}
{{/let partial}}
