::folly::Range<const ::std::string_view*> {{program:schema_name}}_includes() {
{{#if program:schema_includes_const?}}
  {{#let schema_includes=program:transitive_schema_includes}}
  {{! Add 1 to length for the first entry (the current program), followed by all its transitive includes }}
  static const ::std::array<::std::string_view, {{(int.add 1 (array.len schema_includes))}}> includes = {
    {{program:schema_name}}(),
    {{#each schema_includes as |include|}}
    {{#partial read_include_schema include=include}},
    {{/each}}
  };
  return ::folly::range(includes);
{{#else}}
  return {};
{{/if program:schema_includes_const?}}
}
::folly::Range<const ::std::string_view*> {{program:schema_name}}_uris() {
{{#if program:schema_includes_const?}}
  static const ::std::array<::std::string_view, {{(array.len program:uris)}}> uris = {
    {{#program:uris}}
    "{{ . }}",
    {{/program:uris}}
  };
  return ::folly::range(uris);
{{#else}}
  return {};
{{/if program:schema_includes_const?}}
}

