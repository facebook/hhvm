template <class Protocol_>
unsigned long {{def.cpp_underlying_name}}::read(Protocol_* iprot) {
  auto _xferStart = iprot->getCursorPosition();
  readNoXfer(iprot);
  return iprot->getCursorPosition() - _xferStart;
