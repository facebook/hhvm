function test_keyset_string(): void {
  ExampleDsl::makeTree(
    darray[
      "path" => __FILE__,
      "start_line" => 33,
      "end_line" => 33,
      "start_column" => 13,
      "end_column" => 51,
    ],
    darray[
      "splices" => dict[],
      "functions" => vec[],
      "static_methods" => vec[],
      "variables" => vec[],
      "lexically_enclosing_tree" => NULL,
    ],
    (
      (ExampleDsl $v) ==> {
        return $v->visitLambda(
          darray[
            "path" => __FILE__,
            "start_line" => 33,
            "end_line" => 33,
            "start_column" => 13,
            "end_column" => 51,
          ],
          vec["$s"],
          vec[
            $v->visitReturn(
              darray[
                "path" => __FILE__,
                "start_line" => 33,
                "end_line" => 33,
                "start_column" => 36,
                "end_column" => 51,
              ],
              $v->visitKeyset(
                darray[
                  "path" => __FILE__,
                  "start_line" => 33,
                  "end_line" => 33,
                  "start_column" => 36,
                  "end_column" => 51,
                ],
                vec[
                  $v->visitLocal(
                    darray[
                      "path" => __FILE__,
                      "start_line" => 33,
                      "end_line" => 33,
                      "start_column" => 43,
                      "end_column" => 45,
                    ],
                    "$s",
                  ),
                  $v->visitString(
                    darray[
                      "path" => __FILE__,
                      "start_line" => 33,
                      "end_line" => 33,
                      "start_column" => 47,
                      "end_column" => 50,
                    ],
                    "a",
                  ),
                ],
              ),
            ),
          ],
        );
      }
    ),
  );
}
