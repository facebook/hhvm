{{#import "common/client" as client}}
{{#import "common/rpc" as rpc}}
{{#import "common/server" as server}}
{{#import "service_async_client_cpp/templated_received" as templated_received}}
{{#import "service_async_client_cpp/function_implementation" as function_implementation}}
{{#import "service_async_client_cpp/sync_functions" as sync_functions}}
{{#import "service_async_client_cpp/future_functions" as future_functions}}
{{#import "service_async_client_cpp/coroutine_functions" as coroutine_functions}}
{{#import "service_async_client_cpp/received_wrapped" as received_wrapped}}
{{#import "service_async_client_cpp/received" as received}}
namespace {{service.cpp_qualified_namespace}} {
{{#partial rpc.function_param_and_result_typedefs interface=service parent_service=null}}
} // namespace {{service.cpp_qualified_namespace}}
{{#partial templated_received.templated_received interface=service parent_service=null}}

  {{#each service.functions as |function|}}
    {{#if (not function.starts_interaction?)}}
{{#partial function_implementation.function_implementation interface=service parent_service=null function=function}}

      {{#if (not function.sink?)}}
{{#partial sync_functions.sync_functions interface=service parent_service=null function=function}}

{{#partial future_functions.future_functions interface=service parent_service=null function=function}}
        {{#if (and function.legacy_client_methods? (not function.stream?))}}
          {{#let function_comma = (if function.params.fields? ", " "")}}
void apache::thrift::Client<{{service.qualified_name}}>::{{function.cpp_name}}(folly::Function<void (::apache::thrift::ClientReceiveState&&)> callback{{function_comma}}{{#partial client.function_param_list function=function}}) {
  {{function.cpp_name}}(std::make_unique<apache::thrift::FunctionReplyCallback>(std::move(callback)){{function_comma}}{{#partial rpc.param_list function=function}});
}
        {{/if (and function.legacy_client_methods? (not function.stream?))}}
      {{/if (not function.sink?)}}

{{#partial coroutine_functions.coroutine_functions interface=service parent_service=null function=function}}
      {{#if (not function.oneway?)}}
{{#partial received_wrapped.received_wrapped interface=service parent_service=null function=function}}

{{#partial received.received interface=service parent_service=null function=function}}

        {{#if function.virtual_client_methods?}}
{{> service_async_client_cpp/received_instance}}
        {{/if function.virtual_client_methods?}}

      {{/if (not function.oneway?)}}
    {{#else}}
apache::thrift::Client<{{service.qualified_name}}>::{{function.created_interaction.name}} apache::thrift::Client<{{service.qualified_name}}>::{{function.cpp_name}}() {
  return {{function.created_interaction.name}}(channel_, "{{function.created_interaction.name}}", interceptors_);
}
    {{/if (not function.starts_interaction?)}}
  {{/each}}

  {{#each service.interactions as |interaction|}}

namespace {{interaction.cpp_qualified_namespace}} {
{{#partial rpc.function_param_and_result_typedefs interface=interaction parent_service=service}}
} // namespace {{interaction.cpp_qualified_namespace}}
{{#partial templated_received.templated_received interface=interaction parent_service=service}}
    {{#each interaction.functions as |function|}}
{{#partial function_implementation.function_implementation interface=interaction parent_service=service function=function}}
      {{#if (not function.sink?)}}
{{#partial sync_functions.sync_functions interface=interaction parent_service=service function=function}}

{{#partial future_functions.future_functions interface=interaction parent_service=service function=function}}
      {{/if (not function.sink?)}}
{{#partial coroutine_functions.coroutine_functions interface=interaction parent_service=service function=function}}
      {{#if (not function.oneway?)}}
{{#partial received_wrapped.received_wrapped interface=interaction parent_service=service function=function}}
{{#partial received.received interface=interaction parent_service=service function=function}}
      {{/if (not function.oneway?)}}
    {{/each}}

  {{/each}}
