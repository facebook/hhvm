{{#each service.supportedFunctions as |function|}}
void {{service.name}}Wrapper::async_{{#if function.eb?}}eb{{#else}}tm{{/if}}_{{function.cpp_name}}(
  {{> services/cpp_handler_callback_type}} callback{{#each (array.enumerate function.params.fields with_last=true) as |fi field is_last_field?|}}
    , {{#if function.stack_arguments?}}{{#partial types.cpp_stack_arg_type type=field.type}}{{!
        }}{{#else}}{{#partial types.cpp_arg_type type=field.type}}{{/if function.stack_arguments?}}{{!
        }} {{field.cpp_name}}{{#if is_last_field?}}
{{/if is_last_field?}}{{/each}}) {
  auto ctx = callback->getRequestContext();
  folly::via(
    this->executor,
    [this, ctx,
     callback = std::move(callback){{!
     }}{{#each function.params.fields as |field|}},
     {{> services/cpp_field_capture}}{{/each}}

    ]() mutable {
        auto [promise, future] = folly::makePromiseContract<{{!
            }}{{#partial services.cpp_return_type function=function}}>();
        call_cy_{{service.name}}_{{function.name}}(
            this->if_object,
            ctx,
            std::move(promise){{#each function.params.fields as |field|}},
            {{> services/cpp_pass_field}}
{{/each}}
        );
        std::move(future).via(this->executor).thenTry([callback = std::move(callback)](folly::Try<{{!
            }}{{#partial services.cpp_return_type function=function}}>&& t) {
          (void)t;
          {{#if (not function.oneway?)}}callback->complete(std::move(t));{{/if}}
        });
    });
}
