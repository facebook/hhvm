{{#partial glean.function_docblock service=interface function=function}}
  template <int = 0>
  folly::coro::Task<{{#partial client.return_type function=function service=interface}}> co_{{function.cpp_name}}(apache::thrift::RpcOptions& rpcOptions{{function_comma}}{{#partial client.function_param_list function=function}}) {
    return co_{{function.cpp_name}}<true>(&rpcOptions{{function_comma}}{{#partial rpc.param_list function=function}});
  }
 private:
  template <bool hasRpcOptions>
  folly::coro::Task<{{#partial client.return_type function=function service=interface}}> co_{{function.cpp_name}}(apache::thrift::RpcOptions* rpcOptions{{function_comma}}{{#partial client.function_param_list function=function}}) {
    const folly::CancellationToken& cancelToken =
        co_await folly::coro::co_current_cancellation_token;
    const bool cancellable = cancelToken.canBeCancelled();
    apache::thrift::ClientReceiveState returnState;
    apache::thrift::ClientCoroCallback<{{#if function.oneway?}}true{{#else}}false{{/if}}> callback(&returnState, co_await folly::coro::co_current_executor);
    {{#if (not function.oneway?)}}
    auto protocolId = apache::thrift::GeneratedAsyncClient::getChannel()->getProtocolId();
    {{/if (not function.oneway?)}}
    auto [ctx, header] = {{function.cpp_name}}Ctx(rpcOptions);
    using CancellableCallback = apache::thrift::CancellableRequestClientCallback<{{#if function.oneway?}}true{{#else}}false{{/if}}>;
    auto cancellableCallback = cancellable ? CancellableCallback::create(&callback, channel_) : nullptr;
    static apache::thrift::RpcOptions* defaultRpcOptions = new apache::thrift::RpcOptions();
    {{#if function.stream?}}
    auto wrappedCallback = apache::thrift::createStreamClientCallback(
        apache::thrift::RequestClientCallback::Ptr(cancellableCallback ? (apache::thrift::RequestClientCallback*)cancellableCallback.get() : &callback),
      hasRpcOptions ? rpcOptions->getBufferOptions() : defaultRpcOptions->getBufferOptions());
    {{#else}}
    auto wrappedCallback = apache::thrift::RequestClientCallback::Ptr(cancellableCallback ? (apache::thrift::RequestClientCallback*)cancellableCallback.get() : &callback);
    {{/if function.stream?}}
    {{#if function.creates_interaction?}}
    {{function.created_interaction.cpp_name}} interactionHandle(channel_, "{{function.created_interaction.cpp_name}}", ctx ? ctx->getClientInterceptors() : nullptr);
    {{/if function.creates_interaction?}}
    if (ctx != nullptr) {
      auto argsAsRefs = std::tie({{#partial rpc.param_list function=function}});
      auto interceptorTry = ctx->processClientInterceptorsOnRequest(apache::thrift::ClientInterceptorOnRequestArguments(argsAsRefs), header.get(), hasRpcOptions ? *rpcOptions : *defaultRpcOptions);
      if (interceptorTry.hasException()) {
        co_yield folly::coro::co_error(std::move(interceptorTry.exception()));
      }
    }
    if constexpr (hasRpcOptions) {
      fbthrift_serialize_and_send_{{function.cpp_name}}(*rpcOptions, header, ctx.get(), std::move(wrappedCallback){{#if function.creates_interaction?}}, interactionHandle{{/if}}{{function_comma}}{{#partial rpc.param_list function=function}});
    } else {
      fbthrift_serialize_and_send_{{function.cpp_name}}(*defaultRpcOptions, header, ctx.get(), std::move(wrappedCallback){{#if function.creates_interaction?}}, interactionHandle{{/if}}{{function_comma}}{{#partial rpc.param_list function=function}});
    }
    if (cancellable) {
      folly::CancellationCallback cb(cancelToken, [&] { CancellableCallback::cancel(std::move(cancellableCallback)); });
      co_await callback.co_waitUntilDone();
    } else {
      co_await callback.co_waitUntilDone();
    }
    if (returnState.isException()) {
      co_yield folly::coro::co_error(std::move(returnState.exception()));
    }
    {{#if (not function.oneway?)}}
    returnState.resetProtocolId(protocolId);
    returnState.resetCtx(std::move(ctx));
      {{#if (or function.stream? (not function.return_type.void?))}}
    {{#partial client.return_type_no_handle function=function}} _return;
      {{/if (or function.stream? (not function.return_type.void?))}}
    SCOPE_EXIT {
      if (hasRpcOptions && returnState.header()) {
        auto* rheader = returnState.header();
        if (!rheader->getHeaders().empty()) {
          rpcOptions->setReadHeaders(rheader->releaseHeaders());
        }
        rpcOptions->setRoutingData(rheader->releaseRoutingData());
      }
    };
      {{#if (or function.stream? (not function.return_type.void?))}}
    auto ew = recv_wrapped_{{function.cpp_name}}(_return, returnState);
    if (returnState.ctx()) {
      returnState.ctx()->processClientInterceptorsOnResponse(returnState.header(), ew, _return).throwUnlessValue();
    }
        {{#if function.stream?}}
    // Attach interceptor context to stream for automatic interception
    if (returnState.ctx()) {
      _return.{{#if function.stream_has_first_response?}}stream.{{/if}}setInterceptorContext(
          apache::thrift::makeClientStreamInterceptorContextFromContextStack(
              *returnState.ctx()));
    }
        {{/if function.stream?}}
      {{#else}}
    auto ew = recv_wrapped_{{function.cpp_name}}(returnState);
    if (returnState.ctx()) {
      auto tryObj = returnState.ctx()->processClientInterceptorsOnResponse(returnState.header(), ew);
      if (tryObj.hasException()) {
        ew = std::move(tryObj.exception());
      }
    }
      {{/if (or function.stream? (not function.return_type.void?))}}
    if (ew) {
      co_yield folly::coro::co_error(std::move(ew));
    }
      {{#if function.creates_interaction?}}
        {{#if (not function.return_type.void?)}}
    co_return std::make_pair(std::move(interactionHandle), std::move(_return));
        {{#else if function.stream?}}
    co_return std::make_pair(std::move(interactionHandle), std::move(_return));
        {{#else}}
    co_return interactionHandle;
        {{/if (not function.return_type.void?)}}
      {{#else if (or function.stream? (not function.return_type.void?))}}
    co_return _return;
      {{/if function.creates_interaction?}}
    {{/if (not function.oneway?)}}
  }
