{{#import "common/rpc" as rpc}}
{{#import "service_fast_client_cpp/function_implementation" as function_implementation}}
namespace {{service.cpp_qualified_namespace}} {
{{#partial rpc.function_param_and_result_typedefs interface=service parent_service=null}}

{{#each service.functions as |function|}}
{{#if (and (not function.starts_interaction?) (not function.stream?) (not function.sink?) (not function.oneway?))}}
{{#partial function_implementation.fbthrift_serialize interface=service parent_service=null function=function}}

{{#partial function_implementation.fbthrift_deserialize interface=service parent_service=null function=function}}

{{/if (and (not function.starts_interaction?) (not function.stream?) (not function.sink?) (not function.oneway?))}}
{{/each}}
} // namespace {{service.cpp_qualified_namespace}}
