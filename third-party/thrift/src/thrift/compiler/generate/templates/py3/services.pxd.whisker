}}{{!

Cython wrappers of the C++ service classes that were generated by thrift.
By convention, service classes have a c in front of them to differentiate them
from the Python classes, which have no differentiation. That allows the Python
calling code to call into the code without any awkward prefixes or suffixes.

This is a top-level file that gets imported by the CythonServices.pyx file. That
file exposes Python wrappers of the services to the end user.

}}
{{#let partial service_base |service|}}
{{#pragma ignore-newlines}}
  {{#if (object.notnull? service.extends)}}
    {{#if service.extends.externalProgram?}}
{{service.extends.program.module_path_for_alias}}_services.
    {{/if service.extends.externalProgram?}}
{{service.extends.name}}Interface
  {{#else}}
ServiceInterface
  {{/if (object.notnull? service.extends)}}
{{/let partial}}
{{> common/auto_generated_py}}
{{#if (not program.auto_migrate?)}}

from thrift.py3.server cimport ServiceInterface

{{#each program.includeNamespaces as |include|}}
  {{#if include.import_services?}}
cimport {{include.program.module_path}}.services as {{include.program.module_path_for_alias}}_services
  {{/if include.import_services?}}
{{/each}}

  {{#each program.services as |service|}}
cdef class {{service.name}}Interface({{#partial service_base service=service}}):
    {{#if (not (array.empty? service.functions))}}
    # these are to avoid weird Cython multiple inheritance issue
    {{/if (not (array.empty? service.functions))}}
    {{#each service.supportedFunctions as |function|}}
    cdef bint _for_cython_{{function.name}}
    {{/each}}
    pass

  {{/each}}
{{/if (not program.auto_migrate?)}}
