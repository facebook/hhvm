        {{#partial write.csharp_write_expr type=field.type.true_type.key_type value=key_val}};
        {{#partial write.csharp_write_expr type=field.type.true_type.val_type value=val_val}};
    }
}
{{#else if field.type.string?}}
if ({{field.csharp_property_name}} != null && {{field.csharp_property_name}}.Length != 0)
{
    writer.WriteFieldBegin({{#partial ttype.csharp_ttype_name type=field.type}}, {{field.id}});
    {{#partial write.csharp_write_expr type=field.type value=field.csharp_property_name}};
}
{{#else if field.type.binary?}}
if ({{field.csharp_property_name}} != null && {{field.csharp_property_name}}.Length != 0)
{
    writer.WriteFieldBegin({{#partial ttype.csharp_ttype_name type=field.type}}, {{field.id}});
    {{#partial write.csharp_write_expr type=field.type value=field.csharp_property_name}};
}
{{#else}}
if ({{field.csharp_property_name}} != default)
{
    writer.WriteFieldBegin({{#partial ttype.csharp_ttype_name type=field.type}}, {{field.id}});
    {{#partial write.csharp_write_expr type=field.type value=field.csharp_property_name}};
}
{{/if field.type.structured?}}
{{#else}}
{{! Unqualified or required — always write }}
{{#if field.type.structured?}}
writer.WriteFieldBegin({{#partial ttype.csharp_ttype_name type=field.type}}, {{field.id}});
writer.WriteStruct({{field.csharp_property_name}});
{{#else if field.type.list?}}
