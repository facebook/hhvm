{{!
  Inline partials that map a t_exception's blame/kind/safety enum string
  (as emitted by t_whisker_generator) to the matching Go runtime constant.
  Unknown values fall back to the Unspecified constant.
}}

{{#let export partial blame |exception|}}
  {{#pragma ignore-newlines}}
{{#if (object.eq? exception.blame "SERVER")}}thrift.ErrorBlameServer
{{#else if (object.eq? exception.blame "CLIENT")}}thrift.ErrorBlameClient
{{#else}}thrift.ErrorBlameUnspecified
{{/if (object.eq? exception.blame "SERVER")}}
{{/let partial}}

{{#let export partial kind |exception|}}
  {{#pragma ignore-newlines}}
{{#if (object.eq? exception.kind "TRANSIENT")}}thrift.ErrorKindTransient
{{#else if (object.eq? exception.kind "STATEFUL")}}thrift.ErrorKindStateful
{{#else if (object.eq? exception.kind "PERMANENT")}}thrift.ErrorKindPermanent
{{#else}}thrift.ErrorKindUnspecified
{{/if (object.eq? exception.kind "TRANSIENT")}}
{{/let partial}}

{{#let export partial safety |exception|}}
  {{#pragma ignore-newlines}}
{{#if (object.eq? exception.safety "SAFE")}}thrift.ErrorSafetySafe
{{#else}}thrift.ErrorSafetyUnspecified
{{/if (object.eq? exception.safety "SAFE")}}
{{/let partial}}
