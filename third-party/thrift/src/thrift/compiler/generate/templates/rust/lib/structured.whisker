{{#let partial struct_derive_attribute |struct|}}
{{#pragma ignore-newlines}}
#[derive(
{{#if struct.copy?}}Copy, {{/if}}
Clone, PartialEq
{{#if struct.ord?}}, Eq, PartialOrd, Ord, Hash{{/if}}
{{#if struct.union?}}, Debug{{/if}}
{{#if struct.serde?}}, ::serde_derive::Serialize, ::serde_derive::Deserialize{{/if}}
{{#if struct.program.valuable?}}, ::valuable::Valuable{{/if}}
{{#if (not (string.empty? struct.derive))}}, {{struct.derive}}{{/if}}
)]
{{/let partial}}

{{#partial struct_derive_attribute struct=structured}}

  {{#if structured.docs?}}
#[doc = {{structured.docs}}]
  {{/if structured.docs?}}
  {{#if structured.union?}}
pub enum {{structured.rust_name}} {
  {{#each structured.fields as |field|}}
    {{#if field.docs?}}
    #[doc = {{field.docs}}]
    {{/if field.docs?}}
    {{#if field.deprecated?}}
    #[deprecated(note = "{{field.deprecation_message}}")]
    {{/if field.deprecated?}}
    {{field.rust_name}}({{#partial fields.type_name field=field}}),
  {{/each}}
    UnknownField(::std::primitive::i32),
}
  {{#else}}
pub struct {{structured.rust_name}} {
  {{#each structured.fields as |field|}}
    {{#if structured.serde?}}
      {{#if field.rename?}}
    #[serde(rename = "{{field.name}}")]
      {{/if field.rename?}}
      {{#if (not field.optional?)}}
    #[serde(default)]
      {{#else if root_program.skip_none_serialization?}}
    #[serde(skip_serializing_if = "::std::option::Option::is_none")]
      {{/if (not field.optional?)}}
    {{/if structured.serde?}}
    {{#if field.docs?}}
    #[doc = {{field.docs}}]
    {{/if field.docs?}}
    {{#if field.deprecated?}}
    #[deprecated(note = "{{field.deprecation_message}}")]
    {{/if field.deprecated?}}
    pub {{field.rust_name}}: {{#partial fields.type_name field=field}},
  {{/each}}
    {{#if (not structured.exhaustive?)}}
    // This field forces `..Default::default()` when instantiating this
    // struct, to make code future-proof against new fields added later to
    // the definition in Thrift. If you don't want this, add the annotation
    // `@rust.Exhaustive` to the Thrift struct to eliminate this field.
    #[doc(hidden)]
      {{#if structured.serde?}}
    #[serde(skip, default = "self::dot_dot::default_for_serde_deserialize")]
      {{/if structured.serde?}}
    pub _dot_dot_Default_default: {{#if structured.has_adapter?}}super{{#else}}self{{/if}}::dot_dot::OtherFields,
    {{/if (not structured.exhaustive?)}}
}
    {{#if structured.exception?}}

impl ::fbthrift::ExceptionInfo for {{structured.rust_name}} {
    fn exn_value(&self) -> String {
        format!("{:?}", self)
    }

    #[inline]
    fn exn_is_declared(&self) -> bool { true }
}

impl ::std::error::Error for {{structured.rust_name}} {}

impl ::std::fmt::Display for {{structured.rust_name}} {
    fn fmt(&self, f: &mut ::std::fmt::Formatter) -> ::std::fmt::Result {
      {{#if (object.notnull? structured.message_field)}}
        {{#let format_spec = (if structured.message_field.optional? "{:?}" "{}")}}
        write!(f, "{{structured.rust_name}}: {{format_spec}}", self.{{structured.message_field.name}})
      {{#else}}
        write!(f, "{:?}", self)
      {{/if (object.notnull? structured.message_field)}}
    }
}
    {{/if structured.exception?}}
  {{/if structured.union?}}
