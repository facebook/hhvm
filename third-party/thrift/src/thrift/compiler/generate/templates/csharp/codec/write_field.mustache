{{#import "common/ttype" as ttype}}
{{#import "common/types" as types}}
{{#import "common/write_expr" as write}}

{{#let export partial write_field |field| captures |ttype types write|}}
{{#let elem_val = "_elem"}}
{{#let key_val = "_entry.Key"}}
{{#let val_val = "_entry.Value"}}
// Field {{field.id}}: {{field.name}} ({{#partial types.csharp_type type=field.type}})
{{#if field.optional?}}
if ({{field.csharp_property_name}} != null)
{
    writer.WriteFieldBegin({{#partial ttype.csharp_ttype_name type=field.type}}, {{field.id}});
{{#if field.type.structured?}}
    writer.WriteStruct({{field.csharp_property_name}});
{{#else if field.type.list?}}
    writer.WriteListBegin({{#partial ttype.csharp_ttype_name type=field.type.true_type.elem_type}}, {{field.csharp_property_name}}.Count);
    foreach (var _elem in {{field.csharp_property_name}})
    {
        {{#partial write.csharp_write_expr type=field.type.true_type.elem_type value=elem_val}};
    }
{{#else if field.type.set?}}
    writer.WriteSetBegin({{#partial ttype.csharp_ttype_name type=field.type.true_type.elem_type}}, {{field.csharp_property_name}}.Count);
    foreach (var _elem in {{field.csharp_property_name}})
    {
        {{#partial write.csharp_write_expr type=field.type.true_type.elem_type value=elem_val}};
    }
{{#else if field.type.map?}}
    writer.WriteMapBegin({{#partial ttype.csharp_ttype_name type=field.type.true_type.key_type}}, {{#partial ttype.csharp_ttype_name type=field.type.true_type.val_type}}, {{field.csharp_property_name}}.Count);
    foreach (var _entry in {{field.csharp_property_name}})
    {
        {{#partial write.csharp_write_expr type=field.type.true_type.key_type value=key_val}};
        {{#partial write.csharp_write_expr type=field.type.true_type.val_type value=val_val}};
    }
{{#else}}
{{#if field.type.csharp_primitive?}}
    writer.WriteValue({{field.csharp_property_name}}.Value);
{{#else if field.type.enum?}}
    writer.WriteI32((int){{field.csharp_property_name}}.Value);
{{#else}}
    {{#partial write.csharp_write_expr type=field.type value=field.csharp_property_name}};
{{/if field.type.csharp_primitive?}}
{{/if field.type.structured?}}
}
{{#else if field.terse?}}
{{#if field.type.structured?}}
if ({{field.csharp_property_name}} != null && !{{field.csharp_property_name}}.__fbthrift_is_empty())
{
    writer.WriteFieldBegin({{#partial ttype.csharp_ttype_name type=field.type}}, {{field.id}});
    writer.WriteStruct({{field.csharp_property_name}});
}
{{#else if field.type.list?}}
if ({{field.csharp_property_name}} != null && {{field.csharp_property_name}}.Count != 0)
{
