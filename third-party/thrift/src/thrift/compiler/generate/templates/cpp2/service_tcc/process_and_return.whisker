template <typename ProtocolIn_, typename ProtocolOut_>
void {{service_cpp_name}}AsyncProcessor::setUpAndProcess_{{function.prefixed_name}}(
    apache::thrift::ResponseChannelRequest::UniquePtr req,
    apache::thrift::SerializedCompressedRequest&& serializedRequest,
    apache::thrift::Cpp2RequestContext* ctx,
    folly::EventBase* eb,
    [[maybe_unused]] apache::thrift::concurrency::ThreadManager* tm) {
  if (!setUpRequestProcessing(
          req, ctx, eb, {{#if function.event_based?}}nullptr{{#else}}tm{{/if}}, {{#partial rpc.function_kind function=function}}, {{!
          }}iface_{{#if interface.interaction?}}, "{{interface.name}}"{{/if}}{{#if function.creates_interaction?}}, "{{function.created_interaction.cpp_name}}", true{{/if}})) {
    return;
  }
      {{#if (not function.event_based?)}}
  auto scope = iface_->getRequestExecutionScope(
      ctx, apache::thrift::concurrency::{{function.priority}});
  ctx->setRequestExecutionScope(std::move(scope));
  processInThread(
      std::move(req),
      std::move(serializedRequest),
      ctx,
      eb,
      tm,
      {{#partial rpc.function_kind function=function}},
      &{{service_cpp_name}}AsyncProcessor::
          executeRequest_{{function.prefixed_name}}<ProtocolIn_, ProtocolOut_>,
      this);
      {{#else if in_or_creates_interaction?}}
  processInThread(
      std::move(req),
      std::move(serializedRequest),
      ctx,
      eb,
      nullptr,
      {{#partial rpc.function_kind function=function}},
      &{{service_cpp_name}}AsyncProcessor::
          executeRequest_{{function.prefixed_name}}<ProtocolIn_, ProtocolOut_>,
      this);
      {{#else}}
        {{#if (not function.oneway?)}}
  if (!req->getShouldStartProcessing()) {
    apache::thrift::HandlerCallbackBase::releaseRequest(
        std::move(req),
        eb);
    return;
  }
        {{/if (not function.oneway?)}}
  apache::thrift::ServerRequest serverRequest{
      std::move(req),
      std::move(serializedRequest),
      ctx,
      {},
      {},
      {},
      {}};
  executeRequest_{{function.prefixed_name}}<ProtocolIn_, ProtocolOut_>(std::move(serverRequest));
      {{/if (not function.event_based?)}}
}

template <typename ProtocolIn_, typename ProtocolOut_>
void {{service_cpp_name}}AsyncProcessor::executeRequest_{{#if interface.interaction?}}{{interface.name}}_{{/if}}{{function.cpp_name}}(
    apache::thrift::ServerRequest&& serverRequest) {
      {{#if in_or_creates_interaction?}}
  auto tile = serverRequest.requestContext()->releaseTile();
      {{/if in_or_creates_interaction?}}
  // make sure getRequestContext is null
  // so async calls don't accidentally use it
  iface_->setRequestContext(nullptr);
  struct ArgsState {
      {{#each function.params.fields as |param|}}
        {{#if (not param.type.resolves_to_complex_return?)}}
          {{#if param.type.enum?}}
    {{param.type.cpp_type}} uarg_{{param.cpp_name}}{static_cast<{{param.type.cpp_type}}>(0)};
          {{#else}}
    {{param.type.cpp_type}} uarg_{{param.cpp_name}}{0};
          {{/if param.type.enum?}}
        {{#else if function.stack_arguments?}}
    {{param.type.cpp_type}} uarg_{{param.cpp_name}};
        {{#else}}
    std::unique_ptr<{{param.type.cpp_type}}> uarg_{{param.cpp_name}} = std::make_unique<{{param.type.cpp_type}}>();
        {{/if (not param.type.resolves_to_complex_return?)}}
      {{/each}}
    {{service_cpp_name}}_{{#if interface.interaction?}}{{interface.name}}_{{/if}}{{function.cpp_name}}_pargs pargs() {
      {{service_cpp_name}}_{{#if interface.interaction?}}{{interface.name}}_{{/if}}{{function.cpp_name}}_pargs args;
      {{#each (array.enumerate function.params.fields) as |param_index param|}}
        {{#let is_smart_ptr=(and (not function.stack_arguments?) param.type.resolves_to_complex_return?)}}
      args.get<{{param_index}}>().value = {{#if is_smart_ptr}}uarg_{{param.cpp_name}}.get(){{#else}}&uarg_{{param.cpp_name}}{{/if}};
      {{/each}}
      return args;
    }

    auto asTupleOfRefs() & {
      return std::tie(
      {{#each (array.enumerate function.params.fields with_last=true) as |i param last?|}}
        {{#let is_smart_ptr=(and (not function.stack_arguments?) param.type.resolves_to_complex_return?)}}
        std::as_const({{#if is_smart_ptr}}*{{/if}}uarg_{{param.cpp_name}}){{#if (not last?)}},{{/if}}
      {{/each}}
      );
    }
  } args;

  auto ctxStack = apache::thrift::ContextStack::create(
      this->getEventHandlersSharedPtr(),
      this->getServiceName(),
      "{{service_name}}.{{#partial rpc.function_name service=interface function=function}}",
      serverRequest.requestContext());
      {{#if interface.interaction?}}
  auto& iface = static_cast<apache::thrift::ServiceHandler<{{service_cpp_name}}>::{{interface.name}}If&>(*tile);
      {{/if interface.interaction?}}
  apache::thrift::SerializedRequest serializedRequest{nullptr};
  try {
    auto pargs = args.pargs();
    serializedRequest = apache::thrift::detail::ServerRequestHelper::compressedRequest(
        std::move(serverRequest)).uncompress();
    deserializeRequest<ProtocolIn_>(
        pargs,
        "{{#partial rpc.function_name service=interface function=function}}",
        serializedRequest,
        ctxStack.get());
  } catch (...) {
      {{#if function.oneway?}}
    LOG(ERROR) << "exception in function {{#partial rpc.function_name service=interface function=function}}: " << folly::exceptionStr(std::current_exception());
    apache::thrift::detail::ServerRequestHelper::eventBase(serverRequest)->runInEventBaseThread(
        [req = apache::thrift::detail::ServerRequestHelper::request(std::move(serverRequest))] {});
    return;
  }
  auto requestPileNotification = apache::thrift::detail::ServerRequestHelper::moveRequestPileNotification(serverRequest);
  auto concurrencyControllerNotification =
      apache::thrift::detail::ServerRequestHelper::moveConcurrencyControllerNotification(
          serverRequest);
  apache::thrift::HandlerCallbackBase::MethodNameInfo methodNameInfo{
      /* .serviceName =*/ this->getServiceName(),
      /* .definingServiceName =*/ "{{service_name}}",
      /* .methodName =*/ "{{#partial rpc.function_name service=interface function=function}}",
      /* .qualifiedMethodName =*/ "{{service_name}}.{{#partial rpc.function_name service=interface function=function}}"};
        {{#if interface.interaction?}}
  apache::thrift::HandlerCallbackOneWay::DecoratorAfterCallback decoratorCallback{
    // apache::thrift::detail::TileInternalAPI(iface).getDecoratorIface(),
    static_cast<void*>(iface_),
    apache::thrift::ServiceHandler<{{parent_service.cpp_name}}>::fbthrift_invoke_decorator_after_{{interface.name}}_{{function.cpp_name}}};
        {{#else}}
  apache::thrift::HandlerCallbackOneWay::DecoratorAfterCallback decoratorCallback{
    static_cast<void*>(iface_),
    apache::thrift::ServiceHandler<{{interface.qualified_name}}>::fbthrift_invoke_decorator_after_{{function.cpp_name}}};
        {{/if interface.interaction?}}
  auto callback = std::make_unique<apache::thrift::HandlerCallbackOneWay>(
      apache::thrift::detail::ServerRequestHelper::request(std::move(serverRequest)),
      std::move(ctxStack),
      std::move(methodNameInfo),
      nullptr /* exceptionFuncPointer */,
      apache::thrift::detail::ServerRequestHelper::eventBase(serverRequest),
      apache::thrift::detail::ServerRequestHelper::executor(serverRequest),
      serverRequest.requestContext(),
      requestPileNotification,
      concurrencyControllerNotification,
      std::move(serverRequest.requestData()),
      {{#if in_or_creates_interaction?}}std::move(tile), {{#else}}apache::thrift::TilePtr(),{{/if}}
      std::move(decoratorCallback));
      {{#else}}
    folly::exception_wrapper ew(std::current_exception());
    apache::thrift::detail::ap::process_handle_exn_deserialization<
        ProtocolOut_>(
        ew,
        apache::thrift::detail::ServerRequestHelper::request(std::move(serverRequest)),
            serverRequest.requestContext(),
        apache::thrift::detail::ServerRequestHelper::eventBase(serverRequest),
        "{{#partial rpc.function_name service=interface function=function}}");
    return;
  }
  auto requestPileNotification =
      apache::thrift::detail::ServerRequestHelper::moveRequestPileNotification(
          serverRequest);
  auto concurrencyControllerNotification =
      apache::thrift::detail::ServerRequestHelper::moveConcurrencyControllerNotification(
          serverRequest);
  apache::thrift::HandlerCallbackBase::MethodNameInfo methodNameInfo{
      /* .serviceName =*/ this->getServiceName(),
      /* .definingServiceName =*/ "{{service_name}}",
      /* .methodName =*/ "{{#partial rpc.function_name service=interface function=function}}",
      /* .qualifiedMethodName =*/ "{{service_name}}.{{#partial rpc.function_name service=interface function=function}}"};
        {{#if interface.interaction?}}
  apache::thrift::HandlerCallback<{{#partial server.return_type function=function service=interface}}>::DecoratorAfterCallback decoratorCallback{
    static_cast<void*>(iface_),
    apache::thrift::ServiceHandler<{{parent_service.cpp_name}}>::fbthrift_invoke_decorator_after_{{interface.name}}_{{function.cpp_name}}};
        {{#else}}
  apache::thrift::HandlerCallback<{{#partial server.return_type function=function service=interface}}>::DecoratorAfterCallback decoratorCallback{
    static_cast<void*>(iface_),
    apache::thrift::ServiceHandler<{{interface.qualified_name}}>::fbthrift_invoke_decorator_after_{{function.cpp_name}}};
        {{/if interface.interaction?}}
 auto callback =
      apache::thrift::HandlerCallbackPtr<{{#partial server.return_type function=function service=interface}}>::make(
          apache::thrift::detail::ServerRequestHelper::request(
              std::move(serverRequest)),
          std::move(ctxStack),
          std::move(methodNameInfo),
          return_{{function.prefixed_name}}<ProtocolIn_, ProtocolOut_>,
          throw_wrapped_{{#if interface.interaction?}}{{interface.name}}_{{/if}}{{function.cpp_name}}<ProtocolIn_, ProtocolOut_>,
          serverRequest.requestContext()->getProtoSeqId(),
          apache::thrift::detail::ServerRequestHelper::eventBase(serverRequest),
          {{#if function.event_based?}}nullptr{{#else}}apache::thrift::detail::ServerRequestHelper::executor(serverRequest){{/if}},
          serverRequest.requestContext(),
          requestPileNotification,
          concurrencyControllerNotification,
          std::move(serverRequest.requestData()),
          {{#if in_or_creates_interaction?}}std::move(tile),{{#else}}apache::thrift::TilePtr(),{{/if}}
          std::move(decoratorCallback));
      {{/if function.oneway?}}
      {{#if interface.interaction?}}
  // Execute method decorator before_{{interface.name}}_{{function.cpp_name}}.
  iface_->fbthrift_execute_decorators_before_{{interface.name}}_{{function.cpp_name}}(*serverRequest.requestContext(){{#partial decorator_params.before_invocation_args function=function}});
      {{#else}}
  // Execute method decorator before_{{function.cpp_name}}.
  iface_->fbthrift_execute_decorators_before_{{function.cpp_name}}(*serverRequest.requestContext(){{#partial decorator_params.before_invocation_args function=function}});

      {{/if interface.interaction?}}
  const auto makeExecuteHandler = [&] {
    return [ifacePtr = {{#if interface.interaction?}}&iface{{#else}}iface_{{/if}}](auto&& cb, ArgsState args) mutable {
      (void)args;
      {{#if interface.interaction?}}
      if (ifacePtr == nullptr) {
        cb->complete(folly::Try<{{#partial server.return_type function=function service=interface}}>(apache::thrift::detail::si::create_app_exn_bad_interaction_state("{{interface.name}}", "{{function.name}}")));
        return;
      }
      {{/if interface.interaction?}}
      ifacePtr->{{#if function.event_based?}}async_eb{{#else}}async_tm{{/if}}_{{function.cpp_name}}(std::move(cb){{#partial server.get_args_ref function=function}});
    };
  };
#if FOLLY_HAS_COROUTINES
  if (apache::thrift::detail::shouldProcessServiceInterceptorsOnRequest(
          *callback)) {
    [](
        auto callback,
        auto executeHandler,
        ArgsState args,
        apache::thrift::SerializedRequest serializedRequest
    ) -> folly::coro::Task<void> {
      auto argRefs = args.asTupleOfRefs();
      co_await apache::thrift::detail::processServiceInterceptorsOnRequest(
          *callback,
          apache::thrift::detail::ServiceInterceptorOnRequestArguments(argRefs),
          serializedRequest);
      executeHandler(std::move(callback), std::move(args));
    }(
        std::move(callback),
        makeExecuteHandler(),
        std::move(args),
        std::move(serializedRequest))
      .scheduleOn(apache::thrift::detail::ServerRequestHelper::executor(serverRequest))
      .startInlineUnsafe();
  } else {
    makeExecuteHandler()(std::move(callback), std::move(args));
  }
#else
  makeExecuteHandler()(std::move(callback), std::move(args));
#endif // FOLLY_HAS_COROUTINES
}

