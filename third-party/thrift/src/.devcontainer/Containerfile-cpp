FROM ubuntu:jammy

RUN apt update \
    && apt upgrade -y \
    && apt install -y --no-install-recommends \
        build-essential \
        git \
        m4 \
        python3-pip \
        python3-dev \
        patchelf \
    && pip3 install --upgrade cython auditwheel \
    && apt clean \
    && rm -rf /var/lib/apt/lists/*

COPY build/fbcode_builder /tmp/fbcode_builder
COPY build/deps /tmp/deps

RUN apt-get update \
    && python3 /tmp/fbcode_builder/getdeps.py --allow-system-packages \
        --scratch-path /tmp/fbthrift-scratch \
        install-system-deps --recursive fbthrift \
    && python3 /tmp/fbcode_builder/getdeps.py --allow-system-packages \
        --scratch-path /tmp/fbthrift-scratch \
        build --only-deps --no-tests fbthrift \
    && rm -rf /tmp/fbcode_builder /tmp/deps /tmp/fbthrift-scratch \
    && apt clean \
    && rm -rf /var/lib/apt/lists/*
