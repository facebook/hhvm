}

folly::SemiFuture<{{#partial client.return_type_lift_unit function=function service=interface}}> {{#partial client.client_class_name service=interface parent_service=parent_service}}::semifuture_{{function.cpp_name}}(apache::thrift::RpcOptions& rpcOptions{{function_comma}}{{#partial client.function_param_list function=function}}) {
  {{#if function.oneway?}}
  using CallbackType = apache::thrift::OneWaySemiFutureCallback;
  {{#else}}
  using CallbackType = apache::thrift::SemiFutureCallback<{{#partial client.return_type_no_handle_lift_unit function=function}}>;
  {{/if function.oneway?}}
  return fbthrift_semifuture_{{function.cpp_name}}<CallbackType>(rpcOptions{{function_comma}}{{#partial rpc.param_list function=function}});
}

  {{#if function.creates_interaction?}}
std::pair<
  apache::thrift::Client<{{interface.qualified_name}}>::{{function.created_interaction.cpp_name}},
  folly::SemiFuture<{{#partial client.return_type_no_handle_lift_unit function=function}}>
> {{#partial client.client_class_name service=interface parent_service=parent_service}}::eager_semifuture_{{function.cpp_name}}(apache::thrift::RpcOptions& rpcOptions{{function_comma}}{{#partial client.function_param_list function=function}}) {
  auto callbackAndFuture = makeSemiFutureCallback(recv_wrapped_{{function.cpp_name}}, channel_);
  {{function.created_interaction.cpp_name}} interactionHandle(channel_, "{{function.created_interaction.cpp_name}}", interceptors_);
  auto callback = std::move(callbackAndFuture.first);
  {{function.cpp_name}}(rpcOptions, std::move(callback){{#if function.creates_interaction?}}, interactionHandle{{/if}}{{function_comma}}{{#partial rpc.param_list function=function}});
  return std::make_pair(std::move(interactionHandle), std::move(callbackAndFuture.second));
}

