{{!
This is for python types, used for typedefs aliases for use in python.

Structs and enums will be namespaced appropriately if they are either defined
in a different thrift file, or defined in the same thrift file but this is
in the client or server source rather than the type definition source.
}}
{{#let export partial python_type |type|}}
{{#pragma ignore-newlines}}
{{#if type.bool?}}bool
{{#else if type.byte?}}int
{{#else if type.i16?}}int
{{#else if type.i32?}}int
{{#else if type.i64?}}int
{{#else if type.double?}}float
{{#else if type.float?}}float
{{#else if type.void?}}object
{{#else if type.string?}}str
{{#else if type.binary?}}{{#if type.iobufWrapper?}}_fbthrift_iobuf.IOBuf{{#else}}bytes{{/if}}
{{#else if type.container?}}{{#if type.need_module_path?}}{{type.modulePath}}.{{/if}}{{type.flat_name}}
  {{#else if (or type.structured? type.enum?)}}
    {{#let ttype=type.true_type}}
{{#if ttype.need_module_path?}}{{ttype.modulePath}}.{{/if}}{{ttype.name}}
  {{/if type.bool?}}
{{/let partial}}


{{! This is a template for getting the c binding name for an AST node }}
{{#let export partial c_binding |node|}}
{{#pragma ignore-newlines}}
c{{node.name}}
{{/let partial}}

{{!
The expansion of ._cpp_obj to discourage non-thrift usage.
Non-thrift users should use the .converter private API wrappers.
}}
{{#let export partial cpp_obj}}
{{#pragma ignore-newlines}}
_cpp_obj_FBTHRIFT_ONLY_DO_NOT_USE
{{/let partial}}

{{!
This are used to resolve container converter prefix. The prefix used depends whether
referenced from types.pyx main file, field_setter, or container converter.
}}
{{#let export partial container_from_cpp |type|}}
{{#pragma ignore-newlines}}
{{#if type.need_module_path?}}{{type.modulePath}}.{{/if}}{{type.flat_name}}
__from_cpp
{{/let partial}}

{{#let export partial container_to_cpp |type|}}
{{#pragma ignore-newlines}}
{{#if type.need_module_path?}}{{type.modulePath}}.{{/if}}{{type.flat_name}}
__make_instance
{{/let partial}}


{{!
This is used to declare a cython type that is referring to or wrapping a
c++ object. This combined partial handles both the custom type override
(from the cpp.type annotation) and the basic type resolution.

When enable_custom_type_overrides is true, custom types are checked first.
When enable_custom_type_overrides is false, custom type overrides are skipped.
`enable_custom_type_overrides=false` only applies to the top-level type, and will
not apply recursively to nested types (e.g. container element types).
}}
{{#let export partial cython_cpp_type_resolved |type enable_custom_type_overrides| captures |c_binding|}}
{{#pragma ignore-newlines}}
  {{#if (and enable_custom_type_overrides type.customCppType?)}}
    {{#if type.iobuf?}}
_fbthrift_iobuf.cIOBuf
    {{#else if type.iobufRef?}}
unique_ptr[_fbthrift_iobuf.cIOBuf]
    {{#else}}
{{#if type.need_cbinding_path?}}{{type.cbinding_path}}.{{/if}}{{type.cythonCustomType}}
    {{/if type.iobuf?}}
{{#else if type.void?}}cFollyUnit
{{#else if type.bool?}}cbool
{{#else if type.byte?}}cint8_t
{{#else if type.i16?}}cint16_t
{{#else if type.i32?}}cint32_t
{{#else if type.i64?}}cint64_t
{{#else if type.double?}}double
{{#else if type.float?}}float
{{#else if type.string_or_binary?}}string

  {{#else if (or type.enum? type.structured?)}}
    {{#let ttype = type.true_type}}
{{#if ttype.need_cbinding_path?}}{{ttype.cbinding_path}}.{{/if}}
{{#partial c_binding node=ttype}}

  {{#else if type.container?}}
{{#if (and (not type.defaultTemplate?) type.need_cbinding_path?)}}{{type.cbinding_path}}.{{/if}}
    {{#let ttype = type.true_type}}
    {{#if type.map?}}
{{type.cythonTemplate}}[
{{#partial cython_cpp_type_resolved type=ttype.key_type enable_custom_type_overrides=true}},
{{#partial cython_cpp_type_resolved type=ttype.val_type enable_custom_type_overrides=true}}
]
    {{#else}}
{{type.cythonTemplate}}[{{#partial cython_cpp_type_resolved type=ttype.elem_type enable_custom_type_overrides=true}}]
    {{/if type.map?}}
  {{/if (and enable_custom_type_overrides type.customCppType?)}}
{{/let partial}}

{{! Exported partial for full cython cpp type (with custom type override) }}
{{#let export partial cython_cpp_type |type| captures |cython_cpp_type_resolved|}}
{{#pragma ignore-newlines}}
{{#partial cython_cpp_type_resolved type=type enable_custom_type_overrides=true}}
{{/let partial}}


{{!
This is used to declare a cython type that is referring to a Python value (ie,
something that will be returned to external Python code or just used in Cython).

Structs and enums will be namespaced appropriately if they are either defined
in a different thrift file, or defined in the same thrift file but this is
in the client or server source rather than the type definition source.
}}
{{#let export partial cython_python_type |type|}}
{{#pragma ignore-newlines}}
{{#if type.iobufWrapper?}}_fbthrift_iobuf.IOBuf
{{#else if type.bool?}}pbool
{{#else if type.byte?}}cint8_t
{{#else if type.i16?}}cint16_t
{{#else if type.i32?}}cint32_t
{{#else if type.i64?}}cint64_t
{{#else if type.double?}}double
{{#else if type.float?}}float
{{#else if type.string?}}str
{{#else if type.binary?}}bytes
{{#else if (or type.container? type.void? type.enum?)}}object
{{#else if type.structured?}}
  {{#let ttype=type.true_type}}
  {{#if ttype.program.inplace_migrate?}}
object
  {{#else}}
{{#if ttype.need_module_path?}}{{ttype.modulePath}}.{{/if}}{{ttype.name}}
  {{/if ttype.program.inplace_migrate?}}
{{/if type.iobufWrapper?}}
{{/let partial}}


{{! This is for python types, suitable for isinstance check_types }}
{{#let export partial python_is_instance_type |type| captures |cython_python_type|}}
{{#pragma ignore-newlines}}
{{#if type.bool?}}bool
{{#else if type.void?}}object
{{#else if type.integer?}}int
{{#else if type.floating_point?}}(float, int)
{{#else if type.string?}}str
{{#else if type.binary?}}{{#if type.iobufWrapper?}}_fbthrift_iobuf.IOBuf{{#else}}bytes{{/if}}
{{#else if type.container?}}{{#if type.need_module_path?}}{{type.modulePath}}.{{/if}}{{#partial cython_python_type type=type}}
{{#else if (or type.structured? type.enum?)}}{{#if type.need_module_path?}}{{type.modulePath}}.{{/if}}{{type.true_type.name}}
{{/if type.bool?}}
{{/let partial}}


{{! Called specifically from types.pyx when initializing the individual attributes on a struct. }}
{{#let export partial cython_field_value_for_assignment |field| captures |cython_cpp_type cython_python_type container_to_cpp cpp_obj|}}
{{#pragma ignore-newlines}}
  {{#let type=field.type}}
  {{! Cast a field to its Cython Python Type if not a container, otherwise create a container type with constructor. }}
  {{#let partial cython_cast_or_create_python_type captures |cython_python_type type|}}
    {{#pragma ignore-newlines}}
    {{#if type.container?}}
{{#partial cython_python_type type=type}}(_fbthrift_value)
    {{#else}}
(<{{#partial cython_python_type type=type}}?>_fbthrift_value)
    {{/if type.container?}}
  {{/let partial}}

  {{#if type.iobuf?}}
deref((<_fbthrift_iobuf.IOBuf?>_fbthrift_value).c_clone())
  {{#else if type.iobufRef?}}
(<_fbthrift_iobuf.IOBuf?>_fbthrift_value).c_clone()
  {{#else if type.flexibleBinary?}}
{{#partial cython_cpp_type type=type}}(cmove(<string>_fbthrift_value))
  {{#else if type.customBinaryType?}}
{{! BY DESIGN: No output for customBinaryType - this avoids an unnecessary nesting level for (not customBinaryType?) }}
  {{#else if (and field.reference? type.container? field.unique_ref?)}}
make_unique[{{#partial cython_cpp_type type=type}}]({{#partial container_to_cpp type=type}}(_fbthrift_value))
  {{#else if (and field.reference? type.container? field.shared_ref?)}}
make_shared[{{#partial cython_cpp_type type=type}}]({{#partial container_to_cpp type=type}}(_fbthrift_value))
  {{#else if (and field.reference? type.container? field.shared_const_ref?)}}
make_const_shared[{{#partial cython_cpp_type type=type}}]({{#partial container_to_cpp type=type}}(_fbthrift_value))
  {{#else if (and field.reference? field.unique_ref?)}}
make_unique[{{#partial cython_cpp_type type=type}}](deref({{#partial cython_cast_or_create_python_type}}.{{#partial cpp_obj}}))
  {{#else if (and field.reference? field.shared_ref?)}}
{{#partial cython_cast_or_create_python_type}}.{{#partial cpp_obj}}
  {{#else if (and field.reference? field.shared_const_ref?)}}
const_pointer_cast({{#partial cython_cast_or_create_python_type}}.{{#partial cpp_obj}})
  {{#else if type.string?}}
cmove(bytes_to_string(_fbthrift_value.encode('utf-8')))
  {{#else if type.binary?}}
cmove(bytes_to_string(_fbthrift_value))
  {{#else if type.enum?}}
<{{#partial cython_cpp_type type=type}}><int>_fbthrift_value
  {{#else if type.structured?}}
deref((<{{#partial cython_python_type type=type}}?> _fbthrift_value).{{#partial cpp_obj}})
  {{#else if type.container?}}
{{#partial container_to_cpp type=type}}(_fbthrift_value)
  {{#else}}
_fbthrift_value
  {{/if type.iobuf?}}
{{/let partial}}


{{!
Converts a Python object named 'item' to its C++ representation based on the type.
Used for sets, lists, map values, and stream first response items.
For map keys, use cython_python_to_cpp_key instead.
}}
{{#let export partial cython_python_to_cpp_item |type| captures |cython_cpp_type cython_python_type container_to_cpp cpp_obj|}}
{{#pragma ignore-newlines}}
{{#if type.iobuf?}}deref((<_fbthrift_iobuf.IOBuf?>item).c_clone())
{{#else if type.iobufRef?}}(<_fbthrift_iobuf.IOBuf?>item).c_clone()
{{#else if type.flexibleBinary?}}{{#partial cython_cpp_type type=type}}(cmove(<string>item))
{{#else if type.customBinaryType?}}{{! By design: no output for customBinaryType }}
{{#else if type.bool?}}item
{{#else if type.byte?}}item
{{#else if type.i16?}}item
{{#else if type.i32?}}item
{{#else if type.i64?}}item
{{#else if type.double?}}item
{{#else if type.float?}}item
{{#else if type.string?}}item.encode('UTF-8')
{{#else if type.binary?}}item
{{#else if type.enum?}}<{{#partial cython_cpp_type type=type}}><int>item

  {{#else if type.structured?}}
    {{#let ttype = type.true_type}}
    {{#if ttype.program.auto_migrate?}}
__deref_const[{{#partial cython_cpp_type type=type}}](
{{#if type.need_module_path?}}{{type.capi_converter_path}}.{{/if}}
{{ttype.name}}_convert_to_cpp(item))
    {{#else if root_program.inplace_migrate?}}
__deref_const[{{#partial cython_cpp_type type=type}}](
{{type.capi_converter_path}}.{{ttype.name}}_convert_to_cpp(item._to_python()))
    {{#else}}
deref((<{{#partial cython_python_type type=type}}>item).{{#partial cpp_obj}})
    {{/if ttype.program.auto_migrate?}}

  {{#else if type.container?}}
    {{#if (not root_program.auto_migrate?)}}
{{#partial container_to_cpp type=type}}(item)
    {{#else}}
{{type.flat_name}}__make_instance(item)
    {{/if (not root_program.auto_migrate?)}}
  {{/if type.iobuf?}}
{{/let partial}}
