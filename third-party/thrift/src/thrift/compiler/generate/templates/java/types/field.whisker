{{#else if field.type.string?}}com.facebook.thrift.util.IntrinsicDefaults.defaultString()
{{#else if field.type.map?}}com.facebook.thrift.util.IntrinsicDefaults.defaultMap()
{{#else if field.type.list?}}com.facebook.thrift.util.IntrinsicDefaults.defaultList()
{{#else if field.type.set?}}com.facebook.thrift.util.IntrinsicDefaults.defaultSet()
