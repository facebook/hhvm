  void {{function.cpp_name}}(std::unique_ptr<apache::thrift::RequestCallback> callback{{#each function.params.fields as |field|}}, {{#if field.type.resolves_to_complex_return?}}const {{field.type.cpp_type}}&{{#else}}{{field.type.cpp_type}}{{/if}} p_{{field.cpp_name}}{{/each}}) {
    apache::thrift::RpcOptions defaultOptions;
    {{function.cpp_name}}(defaultOptions, std::move(callback){{#each function.params.fields as |field|}}, p_{{field.cpp_name}}{{/each}});
  }

  void {{function.cpp_name}}(apache::thrift::RpcOptions& rpcOptions, std::unique_ptr<apache::thrift::RequestCallback> callback{{#each function.params.fields as |field|}}, {{#if field.type.resolves_to_complex_return?}}const {{field.type.cpp_type}}&{{#else}}{{field.type.cpp_type}}{{/if}} p_{{field.cpp_name}}{{/each}}) {
    auto serialized = ::{{interface.cpp_qualified_namespace}}::{{interface.cpp_name}}FastClientInternal::serialize_{{function.cpp_name}}(this->adapter_->getProtocolId(){{#each function.params.fields as |field|}}, p_{{field.cpp_name}}{{/each}});
    this->sendRequestResponse(
        rpcOptions,
        "{{function.name}}",
        apache::thrift::RpcKind::SINGLE_REQUEST_SINGLE_RESPONSE,
        std::move(serialized),
        std::move(callback));
  }

{{#if function.return_type.void?}}
  static folly::exception_wrapper recv_wrapped_{{function.cpp_name}}(
      ::apache::thrift::ClientReceiveState& state) {
    if (auto ew = apache::thrift::detail::ac::check_recv_state(state)) {
      return ew;
    }
    return ::{{interface.cpp_qualified_namespace}}::{{interface.cpp_name}}FastClientInternal::deserialize_{{function.cpp_name}}(
        state.protocolId(),
        state.serializedResponse().buffer.get());
  }
  static void recv_{{function.cpp_name}}(
      ::apache::thrift::ClientReceiveState& state) {
    auto ew = recv_wrapped_{{function.cpp_name}}(state);
    if (ew) {
      ew.throw_exception();
    }
  }
{{#else}}
  static folly::exception_wrapper recv_wrapped_{{function.cpp_name}}(
      {{function.return_type.cpp_type}}& _return,
      ::apache::thrift::ClientReceiveState& state) {
    if (auto ew = apache::thrift::detail::ac::check_recv_state(state)) {
      return ew;
    }
    return ::{{interface.cpp_qualified_namespace}}::{{interface.cpp_name}}FastClientInternal::deserialize_{{function.cpp_name}}(
        _return,
        state.protocolId(),
        state.serializedResponse().buffer.get());
  }
  static {{function.return_type.cpp_type}} recv_{{function.cpp_name}}(
      ::apache::thrift::ClientReceiveState& state) {
    {{function.return_type.cpp_type}} _return{};
    auto ew = recv_wrapped_{{function.cpp_name}}(_return, state);
    if (ew) {
      ew.throw_exception();
    }
    return _return;
  }
{{/if function.return_type.void?}}

 private:
  template <bool hasRpcOptions>
  folly::coro::Task<{{#if function.return_type.void?}}void{{#else}}{{function.return_type.cpp_type}}{{/if function.return_type.void?}}> co_{{function.cpp_name}}(apache::thrift::RpcOptions* rpcOptions{{#each function.params.fields as |field|}}, {{#if field.type.resolves_to_complex_return?}}const {{field.type.cpp_type}}&{{#else}}{{field.type.cpp_type}}{{/if}} p_{{field.cpp_name}}{{/each}}) {
    static apache::thrift::RpcOptions* defaultRpcOptions = new apache::thrift::RpcOptions();

    auto serialized = ::{{interface.cpp_qualified_namespace}}::{{interface.cpp_name}}FastClientInternal::serialize_{{function.cpp_name}}(
        this->adapter_->getProtocolId(){{#each function.params.fields as |field|}},
        p_{{field.cpp_name}}{{/each}});

    auto response = co_await this->co_sendRequestResponse(
        hasRpcOptions ? *rpcOptions : *defaultRpcOptions,
        "{{function.name}}",
        apache::thrift::RpcKind::SINGLE_REQUEST_SINGLE_RESPONSE,
        std::move(serialized));

    auto data = std::move(response);
{{#if function.return_type.void?}}
    auto ew = ::{{interface.cpp_qualified_namespace}}::{{interface.cpp_name}}FastClientInternal::deserialize_{{function.cpp_name}}(
        this->adapter_->getProtocolId(), data.get());
    if (ew) {
      co_yield folly::coro::co_error(std::move(ew));
    }
{{#else}}
    {{function.return_type.cpp_type}} _return{};
    auto ew = ::{{interface.cpp_qualified_namespace}}::{{interface.cpp_name}}FastClientInternal::deserialize_{{function.cpp_name}}(
        _return, this->adapter_->getProtocolId(), data.get());
    if (ew) {
      co_yield folly::coro::co_error(std::move(ew));
    }
    co_return std::move(_return);
{{/if function.return_type.void?}}
  }
