}}
{{#let partial python_type |type| captures |m_common m_types|}}
{{#pragma ignore-newlines}}
{{#if type.void?}}None
{{#else if type.bool?}}bool
{{#else if type.integer?}}int
{{#else if type.floating_point?}}float
{{#else if type.string?}}str
  {{#else if type.binary?}}
{{#if type.iobuf?}}_fbthrift_iobuf.IOBuf{{#else}}bytes{{/if}}
  {{#else if (or type.structured? type.enum?)}}
    {{#let t = type.true_type}}
{{#if t.need_module_path?}}{{t.module_mangle}}.{{#else}}{{#partial m_common.private_alias_prefix}}{{/if}}
{{t.py_name}}
  {{#else if type.list?}}
{{#if python.generate_immutable_types?}}_fbthrift_python_types.ListTypeFactory{{#else if python.generate_mutable_types?}}_fbthrift_python_mutable_containers.MutableListTypeFactory{{/if}}
({{#partial m_types.typeinfo type=type.true_type.elem_type}})
  {{#else if type.set?}}
{{#if python.generate_immutable_types?}}_fbthrift_python_types.SetTypeFactory{{#else if python.generate_mutable_types?}}_fbthrift_python_mutable_containers.MutableSetTypeFactory{{/if}}
({{#partial m_types.typeinfo type=type.true_type.elem_type}})
  {{#else if type.map?}}
    {{#let map = type.true_type}}
{{#if python.generate_immutable_types?}}_fbthrift_python_types.MapTypeFactory{{#else if python.generate_mutable_types?}}_fbthrift_python_mutable_containers.MutableMapTypeFactory{{/if}}
({{#partial m_types.typeinfo type=map.key_type}}, {{#partial m_types.typeinfo type=map.val_type}})
  {{/if type.void?}}
{{/let partial}}
{{#if program.typedefs?}}

  {{#each program.typedefs as |typedef|}}
    {{#if (not typedef.enum?)}}
      {{#if typedef.has_adapter?}}
        {{#let adapter = typedef.adapter}}
{{typedef.py_name}} = {{adapter.type_hint}}{{#if adapter.is_generic?}}[{{#partial python_type type=typedef.resolved}}]{{/if}}
      {{#else if (and typedef.binary? typedef.iobuf?)}}
{{typedef.py_name}} = _fbthrift_iobuf.IOBuf
      {{#else if typedef.list?}}
          {{#let resolved = typedef.resolved}}
        {{#if python.generate_immutable_types?}}
if _fbthrift_python_container_typedefs is not None:
    class {{typedef.py_name}}(_fbthrift_python_container_typedefs._ListTypedefBase):
        __slots__ = ()
        _fbthrift_list_type_info = {{#partial m_types.typeinfo type=resolved.true_type.elem_type}}
else:
    {{typedef.py_name}} = _fbthrift_python_types.ListTypeFactory({{#partial m_types.typeinfo type=resolved.true_type.elem_type}})
        {{#else if python.generate_mutable_types?}}
class {{typedef.py_name}}(_fbthrift_python_mutable_containers._MutableListTypedefBase):
    __slots__ = ()
    _fbthrift_mutable_list_type_info = {{#partial m_types.typeinfo type=resolved.true_type.elem_type}}
        {{/if python.generate_immutable_types?}}
      {{#else if typedef.set?}}
          {{#let resolved = typedef.resolved}}
        {{#if python.generate_immutable_types?}}
if _fbthrift_python_container_typedefs is not None:
    class {{typedef.py_name}}(_fbthrift_python_container_typedefs._SetTypedefBase):
        __slots__ = ()
        _fbthrift_set_type_info = {{#partial m_types.typeinfo type=resolved.true_type.elem_type}}
else:
    {{typedef.py_name}} = _fbthrift_python_types.SetTypeFactory({{#partial m_types.typeinfo type=resolved.true_type.elem_type}})
        {{#else if python.generate_mutable_types?}}
class {{typedef.py_name}}(_fbthrift_python_mutable_containers._MutableSetTypedefBase):
    __slots__ = ()
    _fbthrift_mutable_set_type_info = {{#partial m_types.typeinfo type=resolved.true_type.elem_type}}
        {{/if python.generate_immutable_types?}}
      {{#else if typedef.map?}}
          {{#let resolved = typedef.resolved}}
          {{#let map = resolved.true_type}}
        {{#if python.generate_immutable_types?}}
if _fbthrift_python_container_typedefs is not None:
    class {{typedef.py_name}}(_fbthrift_python_container_typedefs._MapTypedefBase):
        __slots__ = ()
        _fbthrift_map_key_type_info = {{#partial m_types.typeinfo type=map.key_type}}
        _fbthrift_map_val_type_info = {{#partial m_types.typeinfo type=map.val_type}}
else:
    {{typedef.py_name}} = _fbthrift_python_types.MapTypeFactory({{#partial m_types.typeinfo type=map.key_type}}, {{#partial m_types.typeinfo type=map.val_type}})
        {{#else if python.generate_mutable_types?}}
class {{typedef.py_name}}(_fbthrift_python_mutable_containers._MutableMapTypedefBase):
    __slots__ = ()
    _fbthrift_mutable_map_key_type_info = {{#partial m_types.typeinfo type=map.key_type}}
    _fbthrift_mutable_map_val_type_info = {{#partial m_types.typeinfo type=map.val_type}}
        {{/if python.generate_immutable_types?}}
      {{#else}}
{{typedef.py_name}} = {{#partial python_type type=typedef.resolved}}
      {{/if typedef.has_adapter?}}
    {{/if (not typedef.enum?)}}
  {{/each}}
{{/if program.typedefs?}}
