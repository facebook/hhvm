{{#import "common/server" as server}}
{{#let export partial service_interface_functions |interface parent_service| captures |server|}}
  {{#each interface.functions as |function|}}
    {{#let function_comma = (if function.params.fields? ", " "")}}
    {{#if function.starts_interaction?}}
  virtual std::unique_ptr<{{function.created_interaction.name}}If> {{function.cpp_name}}();
    {{#else}}
      {{#if (not function.event_based?)}}
  virtual {{#partial server.sync_return_type function=function service=interface}} sync_{{function.cpp_name}}({{#partial server.sync_return_param function=function}}{{#partial server.function_param_list_commented_out function=function}});
  [[deprecated("Use sync_{{function.cpp_name}} instead")]] virtual {{#partial server.sync_return_type function=function service=interface}} {{function.cpp_name}}({{#partial server.sync_return_param function=function}}{{#partial server.function_param_list_commented_out function=function}});
        {{#if (not interface.interaction?)}}
  virtual folly::Future<{{#partial server.return_type_lift_unit function=function service=interface}}> future_{{function.cpp_name}}({{#partial server.function_param_list function=function}});
        {{/if (not interface.interaction?)}}
  virtual folly::SemiFuture<{{#partial server.return_type_lift_unit function=function service=interface}}> semifuture_{{function.cpp_name}}({{#partial server.function_param_list function=function}});
#if FOLLY_HAS_COROUTINES
  virtual folly::coro::Task<{{#partial server.return_type function=function service=interface}}> co_{{function.cpp_name}}({{#partial server.function_param_list function=function}});
  virtual folly::coro::Task<{{#partial server.return_type function=function service=interface}}> co_{{function.cpp_name}}(apache::thrift::RequestParams params{{function_comma}}{{#partial server.function_param_list function=function}});
#endif
      {{/if (not function.event_based?)}}
      {{#if function.oneway?}}
  virtual void async_{{#if function.event_based?}}eb{{#else}}tm{{/if}}_{{function.cpp_name}}(apache::thrift::HandlerCallbackOneWay::Ptr callback{{function_comma}}{{#partial server.function_param_list function=function}});
      {{#else}}
  virtual void async_{{#if function.event_based?}}eb{{#else}}tm{{/if}}_{{function.cpp_name}}(apache::thrift::HandlerCallbackPtr<{{#partial server.return_type function=function service=interface}}> callback{{function_comma}}{{#partial server.function_param_list function=function}});
      {{/if function.oneway?}}
    {{/if function.starts_interaction?}}
  {{/each}}
 private:
  {{#if (not interface.interaction?)}}
  static {{interface.qualified_name}}ServiceInfoHolder __fbthrift_serviceInfoHolder;
  {{/if (not interface.interaction?)}}
  {{#each interface.functions as |function|}}
    {{#if (not function.event_based?)}}
  std::atomic<apache::thrift::detail::si::InvocationType> __fbthrift_invocation_{{function.cpp_name}}{apache::thrift::detail::si::InvocationType::AsyncTm};
    {{/if (not function.event_based?)}}
  {{/each}}
{{/let partial}}
