  {{#let type = field.type}}
{{#partial custom_protocol.if_should_write field=field struct=struct}}
    xfer += prot_->serializedFieldSize("{{field.name}}", {{#partial types.protocol_type type=field.type}}, {{field.id}});
    {{#if field.lazy?}}
    if constexpr (Protocol_::kHasIndexSupport()) {
      if (prot_->protocolType() == __fbthrift_protocol_) {
        auto lock = std::shared_lock(__fbthrift_deserializationMutex_);
        if (__fbthrift_isDeserialized_.{{field.cpp_name}}.load() == ::apache::thrift::detail::LazyDeserializationState::UNTAINTED) {
          xfer += ({{#if field.lazy_ref?}}*{{/if}}__fbthrift_serializedData_.{{field.cpp_name}}).computeChainDataLength();
          goto written_lazy_field_{{field.cpp_name}};
        }
      }
    }
    std::as_const(*this).__fbthrift_read_field_{{field.cpp_name}}();
    {{/if field.lazy?}}
    {{#if field.non_opt_cpp_ref?}}
    if ({{#partial fields.member field=field struct=struct}}) {
      {{#if field.use_op_encode?}}
      xfer += ::apache::thrift::op::serialized_size<false, {{field.type_tag}}>(*prot_, {{#if field.cpp_ref?}}*{{/if}}{{#partial fields.member field=field struct=struct}});
      {{#else if (not field.cpp_exactly_one_adapter?)}}
      xfer += {{#partial custom_protocol.protocol_methods field=field}}::serializedSize<false>(*prot_, {{#partial custom_protocol.protocol_methods_value field=field struct=struct}});
      {{#else}}
      xfer += ::apache::thrift::adapt_detail::serializedSize<false, {{field.type_tag}}, {{field.cpp_first_adapter}}>(*prot_, {{#if field.cpp_ref?}}*{{/if}}{{#partial fields.member field=field struct=struct}}, [&] {return {{#partial custom_protocol.protocol_methods field=field}}::serializedSize<false>(*prot_, {{#partial custom_protocol.protocol_methods_value field=field struct=struct}});});
      {{/if field.use_op_encode?}}
      {{#if (or field.type.container? field.type.enum?)}}
    } else {
      xfer += prot_->serializedSize{{#partial custom_protocol.struct_field_type type=type}}Begin({{#partial custom_protocol.container_struct_type type=type}}, 0);
      xfer += prot_->serializedSize{{#partial custom_protocol.struct_field_type type=type}}End();
      {{/if (or field.type.container? field.type.enum?)}}
      {{#if field.type.structured?}}
    } else {
      xfer += prot_->serializedStructSize("{{field.type.name}}");
      xfer += prot_->serializedSizeStop();
      {{/if field.type.structured?}}
    }
    {{#else if field.use_op_encode?}}
    xfer += ::apache::thrift::op::serialized_size<false, {{field.type_tag}}>(*prot_, {{#if field.cpp_ref?}}*{{/if}}{{#partial fields.member field=field struct=struct}});
    {{#else if (not field.cpp_exactly_one_adapter?)}}
    xfer += {{#partial custom_protocol.protocol_methods field=field}}::serializedSize<false>(*prot_, {{#partial custom_protocol.protocol_methods_value field=field struct=struct}});
    {{#else}}
    xfer += ::apache::thrift::adapt_detail::serializedSize<false, {{field.type_tag}}, {{field.cpp_first_adapter}}>(*prot_, {{#if field.cpp_ref?}}*{{/if}}{{#partial fields.member field=field struct=struct}}, [&] {return {{#partial custom_protocol.protocol_methods field=field}}::serializedSize<false>(*prot_, {{#partial custom_protocol.protocol_methods_value field=field struct=struct}});});
    {{/if field.non_opt_cpp_ref?}}
    {{#if field.lazy?}}
    written_lazy_field_{{field.cpp_name}}:;
    {{/if field.lazy?}}
{{#partial custom_protocol.if_should_write_end struct=struct}}
