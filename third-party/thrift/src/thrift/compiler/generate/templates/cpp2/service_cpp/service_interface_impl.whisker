{{#import "common/rpc" as rpc}}
{{#import "common/server" as server}}

{{#let export partial service_interface_impl |interface parent_service| captures |rpc server|}}
  {{#if (not (array.empty? interface.functions))}}
//
// Service Methods
//

  {{/if (not (array.empty? interface.functions))}}
  {{#each interface.functions as |function|}}
    {{#let function_comma = (if function.params.fields? ", " "")}}
    {{#if (not function.starts_interaction?)}}
//
// Method '{{function.name}}'
//
      {{#if (not function.event_based?)}}

{{#partial server.sync_return_type function=function service=interface}} {{#partial server.service_class_name service=interface parent_service=parent_service}}::{{function.cpp_name}}({{#partial server.sync_return_param function=function}}{{#partial server.function_param_list_commented_out function=function}}) {
  apache::thrift::detail::si::throw_app_exn_unimplemented("{{function.name}}");
}

{{#partial server.sync_return_type function=function service=interface}} {{#partial server.service_class_name service=interface parent_service=parent_service}}::sync_{{function.cpp_name}}({{#if function.sync_returns_by_outparam?}}{{function.cpp_return_type}}& _return{{function_comma}}{{/if}}{{#partial server.function_param_list function=function}}) {
  return {{function.cpp_name}}({{#if function.sync_returns_by_outparam?}}_return{{function_comma}}{{/if}}{{#partial server.param_list_move function=function}});
}

folly::SemiFuture<{{#partial server.return_type_lift_unit function=function service=interface}}>
{{#partial server.service_class_name service=interface parent_service=parent_service}}::semifuture_{{function.cpp_name}}({{#partial server.function_param_list function=function}}) {
  auto expected{apache::thrift::detail::si::InvocationType::SemiFuture};
  __fbthrift_invocation_{{function.cpp_name}}.compare_exchange_strong(
      expected,
      apache::thrift::detail::si::InvocationType::Sync,
      std::memory_order_relaxed);
        {{#if (not function.sync_returns_by_outparam?)}}
          {{#if function.void?}}
  sync_{{function.cpp_name}}({{#partial server.param_list_move function=function}});
  return folly::makeSemiFuture();
          {{#else}}
  return sync_{{function.cpp_name}}({{#partial server.param_list_move function=function}});
          {{/if function.void?}}
        {{#else}}
          {{#if function.stack_arguments?}}
  {{function.return_type.cpp_type}} ret;
  sync_{{function.cpp_name}}(ret{{function_comma}}{{#partial server.param_list_move function=function}});
          {{#else}}
  auto ret = std::make_unique<{{function.return_type.cpp_type}}>();
  sync_{{function.cpp_name}}(*ret{{function_comma}}{{#partial server.param_list_move function=function}});
          {{/if function.stack_arguments?}}
  return folly::makeSemiFuture(std::move(ret));
        {{/if (not function.sync_returns_by_outparam?)}}
}
        {{#if (not interface.interaction?)}}

folly::Future<{{#partial server.return_type_lift_unit function=function service=interface}}>
{{#partial server.service_class_name service=interface parent_service=parent_service}}::future_{{function.cpp_name}}({{#partial server.function_param_list function=function}}) {
  auto expected{apache::thrift::detail::si::InvocationType::Future};
  __fbthrift_invocation_{{function.cpp_name}}.compare_exchange_strong(
      expected,
      apache::thrift::detail::si::InvocationType::SemiFuture,
      std::memory_order_relaxed);
  return apache::thrift::detail::si::future(
      semifuture_{{function.cpp_name}}({{#partial server.param_list_move function=function}}),
      getInternalKeepAlive());
}
        {{/if (not interface.interaction?)}}

#if FOLLY_HAS_COROUTINES
folly::coro::Task<{{#partial server.return_type function=function service=interface}}>
{{#partial server.service_class_name service=interface parent_service=parent_service}}::co_{{function.cpp_name}}({{#partial server.function_param_list function=function}}) {
  auto expected{apache::thrift::detail::si::InvocationType::Coro};
  __fbthrift_invocation_{{function.cpp_name}}.compare_exchange_strong(
      expected,
      apache::thrift::detail::si::InvocationType::{{#if interface.interaction?}}SemiFuture{{#else}}Future{{/if}},
      std::memory_order_relaxed);
          {{#if function.stack_arguments?}}
  apache::thrift::detail::si::ignore({{#partial server.param_list_move function=function}});
  folly::throw_exception(apache::thrift::detail::si::UnimplementedCoroMethod::
                             withoutCapturedArgs());
          {{#else}}
  folly::throw_exception(apache::thrift::detail::si::UnimplementedCoroMethod::
                             withCapturedArgs<{{#partial server.function_param_list_commented_out function=function}}>({{#partial server.param_list_move function=function}}));
          {{/if function.stack_arguments?}}
}

folly::coro::Task<{{#partial server.return_type function=function service=interface}}> {{#partial server.service_class_name service=interface parent_service=parent_service}}::co_{{function.cpp_name}}(
    apache::thrift::RequestParams /* params */{{function_comma}}{{#partial server.function_param_list function=function}}) {
  auto expected{apache::thrift::detail::si::InvocationType::CoroParam};
  __fbthrift_invocation_{{function.cpp_name}}.compare_exchange_strong(
      expected,
      apache::thrift::detail::si::InvocationType::Coro,
      std::memory_order_relaxed);
  return co_{{function.cpp_name}}({{#partial server.param_list_move function=function}});
}
#endif // FOLLY_HAS_COROUTINES
        {{#if function.oneway?}}

void {{#partial server.service_class_name service=interface parent_service=parent_service}}::async_tm_{{function.cpp_name}}(
    apache::thrift::HandlerCallbackOneWay::Ptr callback{{function_comma}}{{#partial server.function_param_list function=function}}) {
        {{#else}}

void {{#partial server.service_class_name service=interface parent_service=parent_service}}::async_tm_{{function.cpp_name}}(
    apache::thrift::HandlerCallbackPtr<{{#partial server.return_type function=function service=interface}}> callback{{function_comma}}{{#partial server.function_param_list function=function}}) {
        {{/if function.oneway?}}
  // It's possible the coroutine versions will delegate to a future-based
  // version. If that happens, we need the RequestParams arguments to be
  // available to the future through the thread-local backchannel, so we create
  // a RAII object that sets up RequestParams and clears them on destruction.
  apache::thrift::detail::si::AsyncTmPrep asyncTmPrep(this, callback.get());
#if FOLLY_HAS_COROUTINES
determineInvocationType:
#endif // FOLLY_HAS_COROUTINES
  auto invocationType =
      __fbthrift_invocation_{{function.cpp_name}}.load(std::memory_order_relaxed);
  try {
    switch (invocationType) {
      case apache::thrift::detail::si::InvocationType::AsyncTm: {
#if FOLLY_HAS_COROUTINES
        __fbthrift_invocation_{{function.cpp_name}}.compare_exchange_strong(
            invocationType,
            apache::thrift::detail::si::InvocationType::CoroParam,
            std::memory_order_relaxed);
        apache::thrift::RequestParams params{
            callback->getRequestContext(),
            callback->getThreadManager_deprecated(),
            callback->getEventBase(),
            callback->getHandlerExecutor()};
        auto task = co_{{function.cpp_name}}(params{{function_comma}}{{#partial server.param_list_move function=function}});
        apache::thrift::detail::si::async_tm_coro(
            std::move(callback), std::move(task));
        return;
#else // FOLLY_HAS_COROUTINES
          {{#if interface.interaction?}}
        __fbthrift_invocation_{{function.cpp_name}}.compare_exchange_strong(
            invocationType,
            apache::thrift::detail::si::InvocationType::SemiFuture,
            std::memory_order_relaxed);
          {{#else}}
        __fbthrift_invocation_{{function.cpp_name}}.compare_exchange_strong(
            invocationType,
            apache::thrift::detail::si::InvocationType::Future,
            std::memory_order_relaxed);
          {{/if interface.interaction?}}
        [[fallthrough]];
#endif // FOLLY_HAS_COROUTINES
      }
        {{#if (not interface.interaction?)}}
      case apache::thrift::detail::si::InvocationType::Future: {
        auto fut = future_{{function.cpp_name}}({{#partial server.param_list_move function=function}});
        apache::thrift::detail::si::async_tm_future(
            std::move(callback), std::move(fut));
        return;
      }
        {{/if (not interface.interaction?)}}
      case apache::thrift::detail::si::InvocationType::SemiFuture: {
        auto fut = semifuture_{{function.cpp_name}}({{#partial server.param_list_move function=function}});
        apache::thrift::detail::si::async_tm_semifuture(
            std::move(callback), std::move(fut));
        return;
      }
#if FOLLY_HAS_COROUTINES
      case apache::thrift::detail::si::InvocationType::CoroParam: {
        apache::thrift::RequestParams params{
            callback->getRequestContext(),
            callback->getThreadManager_deprecated(),
            callback->getEventBase(),
            callback->getHandlerExecutor()};
        auto task = co_{{function.cpp_name}}(params{{function_comma}}{{#partial server.param_list_move function=function}});
        apache::thrift::detail::si::async_tm_coro(
            std::move(callback), std::move(task));
        return;
      }
      case apache::thrift::detail::si::InvocationType::Coro: {
        auto task = co_{{function.cpp_name}}({{#partial server.param_list_move function=function}});
        apache::thrift::detail::si::async_tm_coro(
            std::move(callback), std::move(task));
        return;
      }
#endif // FOLLY_HAS_COROUTINES
      case apache::thrift::detail::si::InvocationType::Sync: {
        {{#if function.sync_returns_by_outparam?}}
        {{function.return_type.cpp_type}} _return;
        sync_{{function.cpp_name}}(_return{{function_comma}}{{#partial server.param_list_move function=function}});
        callback->result(std::move(_return));
        {{#else if function.void?}}
        sync_{{function.cpp_name}}({{#partial server.param_list_move function=function}});
          {{#if (not function.oneway?)}}
        callback->done();
          {{/if (not function.oneway?)}}
        {{#else}}
        callback->result(sync_{{function.cpp_name}}({{#partial server.param_list_move function=function}}));
        {{/if function.sync_returns_by_outparam?}}
        return;
      }
      default: {
        folly::assume_unreachable();
      }
    }
#if FOLLY_HAS_COROUTINES
  } catch (apache::thrift::detail::si::UnimplementedCoroMethod&{{#if (not function.stack_arguments?)}} ex{{/if}}) {
          {{#if (not function.stack_arguments?)}}
    std::tie({{#partial rpc.param_list function=function}}) = std::move(ex).restoreArgs<{{#partial server.function_param_list_commented_out function=function}}>();
          {{/if (not function.stack_arguments?)}}
    goto determineInvocationType;
#endif // FOLLY_HAS_COROUTINES
  } catch (...) {
    callback->exception(std::current_exception());
  }
}
      {{#else if function.oneway?}}

void {{#partial server.service_class_name service=interface parent_service=parent_service}}::async_eb_{{function.cpp_name}}(
    apache::thrift::HandlerCallbackOneWay::Ptr /*callback*/{{function_comma}}{{#partial server.function_param_list_commented_out function=function}}) {
  LOG(DFATAL) << "Function {{function.cpp_name}} is unimplemented";
}
      {{#else}}

void {{#partial server.service_class_name service=interface parent_service=parent_service}}::async_eb_{{function.cpp_name}}(
    apache::thrift::HandlerCallbackPtr<{{#partial server.return_type function=function service=interface}}> callback{{function_comma}}{{#partial server.function_param_list_commented_out function=function}}) {
  callback->exception(
      apache::thrift::detail::si::create_app_exn_unimplemented("{{function.name}}"));
}
      {{/if (not function.event_based?)}}
//
// End of Method '{{function.name}}'
//

    {{#else}}

std::unique_ptr<{{#partial server.service_class_name service=interface parent_service=parent_service}}::{{function.created_interaction.name}}If> {{#partial server.service_class_name service=interface parent_service=parent_service}}::{{function.cpp_name}}() {
  apache::thrift::detail::si::throw_app_exn_unimplemented("{{function.name}}");
}
//
// End of Method '{{function.name}}'
//

    {{/if (not function.starts_interaction?)}}
  {{/each}}
  {{#if (not (array.empty? interface.functions))}}
//
// End of Service Methods
//
  {{/if (not (array.empty? interface.functions))}}
{{/let partial}}
