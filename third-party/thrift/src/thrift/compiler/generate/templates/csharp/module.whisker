{{#import "types/enum" as enum_tmpl}}
{{#import "types/struct" as struct_tmpl}}
{{#import "types/union" as union_tmpl}}
{{> common/file_header}}

#nullable enable
using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;
using FBThrift;
{{#each root_program.includes_for_codegen as |inc|}}
{{#if inc.is_useful_alias?}}
using {{inc.alias}} = {{inc.csharp_namespace}};
{{/if inc.is_useful_alias?}}
{{/each}}

namespace {{root_program.csharp_namespace}}
{
{{#each root_program.enums as |enum|}}
    {{#partial enum_tmpl.enum_type enum=enum}}

{{/each}}
{{#each root_program.structured_definitions as |structured|}}
{{#if structured.union?}}
    {{#partial union_tmpl.union_type structured=structured}}
{{#else}}
    {{#partial struct_tmpl.struct_type structured=structured}}
{{/if structured.union?}}

{{/each}}
{{#if root_program.constants?}}
{{> types/const}}
{{/if root_program.constants?}}
    /// <summary>
    /// Registers all generated types from this module that have a thrift_uri.
    /// Each module generates a uniquely-named registry class to avoid
    /// conflicts when multiple modules share the same namespace.
    /// </summary>
    public static class {{root_program.csharp_name}}TypeRegistry
    {
        public static void RegisterTypes(Action<string, Func<IThriftSerializable>> register)
        {
{{#each root_program.structured_definitions as |structured|}}
{{#if (not (string.empty? structured.uri))}}
            register("{{structured.uri}}", () => new {{structured.csharp_name}}());
{{/if (not (string.empty? structured.uri))}}
{{/each}}
        }
    }
}
