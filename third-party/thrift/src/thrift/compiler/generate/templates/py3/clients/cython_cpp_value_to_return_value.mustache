}}{{!

Used in cython client callbacks to convert the returned cpp value type
to a python type.

}}
{{#pragma ignore-newlines}}
{{#if function.return_type.iobuf?}}_fbthrift_iobuf.from_unique_ptr(result.value().clone())
{{#else if function.return_type.iobufRef?}}_fbthrift_iobuf.from_unique_ptr(move_iobuf(result.value()))
{{#else if function.return_type.flexibleBinary?}}(<const char*>result.value().data())[:result.value().size()]
{{#else if function.stream?}}{{#partial clients.stream_response_class_name function=function}}._fbthrift_create(result.value(), options)
{{#else if function.return_type.customBinaryType?}}{{! no output for custom binary types that are iobuf/iobufRef/flexibleBinary }}
{{#else if function.return_type.bool?}}<bint>result.value()
{{#else if function.return_type.void?}}None
{{#else if function.return_type.string?}}result.value().data().decode('UTF-8')
{{#else if function.return_type.primitive?}}result.value()
{{#else if function.return_type.container?}}{{#partial types.container_from_cpp type=function.return_type}}(cmove(result.value()))
{{#else if function.return_type.enum?}}{{#partial types.python_type type=function.return_type}}(<int> result.value())

  {{#else if (and function.return_type.structured? program.inplace_migrate?)}}
{{#partial types.python_type type=function.return_type}}.from_python(
{{function.return_type.capi_converter_path}}.{{function.return_type.true_type.name}}_from_cpp(
__deref_const[{{#partial types.cython_cpp_type type=function.return_type}}](result.value())))

  {{#else if function.return_type.structured?}}
{{#partial types.cython_python_type type=function.return_type}}._create_FBTHRIFT_ONLY_DO_NOT_USE(
make_shared[{{#partial types.cython_cpp_type type=function.return_type}}](
cmove(result.value())))

{{/if function.return_type.iobuf?}}
