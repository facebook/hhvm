<?hh

<<file:
  __EnableUnstableFeatures(
    'expression_trees',
    'expression_tree_subscript',
  )>>

function test_vec(): void {
  ExampleDsl::makeTree(
    darray[
      "path" => __FILE__,
      "start_line" => 6,
      "end_line" => 6,
      "start_column" => 13,
      "end_column" => 67,
    ],
    darray[
      "splices" => dict[],
      "functions" => vec[],
      "static_methods" => vec[],
      "variables" => vec[],
      "lexically_enclosing_tree" => NULL,
    ],
    (
      (ExampleDsl $v) ==> {
        return $v->visitLambda(
          darray[
            "path" => __FILE__,
            "start_line" => 6,
            "end_line" => 6,
            "start_column" => 13,
            "end_column" => 67,
          ],
          vec["$arr", "$idx"],
          vec[
            $v->visitReturn(
              darray[
                "path" => __FILE__,
                "start_line" => 6,
                "end_line" => 6,
                "start_column" => 57,
                "end_column" => 67,
              ],
              $v->visitSubscript(
                darray[
                  "path" => __FILE__,
                  "start_line" => 6,
                  "end_line" => 6,
                  "start_column" => 57,
                  "end_column" => 67,
                ],
                $v->visitLocal(
                  darray[
                    "path" => __FILE__,
                    "start_line" => 6,
                    "end_line" => 6,
                    "start_column" => 57,
                    "end_column" => 61,
                  ],
                  "$arr",
                ),
                $v->visitLocal(
                  darray[
                    "path" => __FILE__,
                    "start_line" => 6,
                    "end_line" => 6,
                    "start_column" => 62,
                    "end_column" => 66,
                  ],
                  "$idx",
                ),
              ),
            ),
          ],
        );
      }
    ),
  );
}

