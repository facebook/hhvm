{{#import "common/client" as client}}

{{#let export partial received_wrapped |interface parent_service function| captures |client|}}
  {{#let service_cpp_name=(if interface.interaction? parent_service.cpp_name interface.cpp_name)}}
  {{#if function.cpp_recv_arg?}}
folly::exception_wrapper {{#partial client.client_class_name service=interface parent_service=parent_service}}::recv_wrapped_{{function.cpp_name}}({{#partial client.return_type_no_handle function=function}}& _return, ::apache::thrift::ClientReceiveState& state) {
  {{#else}}
folly::exception_wrapper {{#partial client.client_class_name service=interface parent_service=parent_service}}::recv_wrapped_{{function.cpp_name}}(::apache::thrift::ClientReceiveState& state) {
  {{/if function.cpp_recv_arg?}}
    if (auto ew = apache::thrift::detail::ac::check_recv_state(state)) {
    return ew;
  }

  using result = ::{{interface.cpp_qualified_namespace}}::{{service_cpp_name}}_{{function.prefixed_name}}_presult;
  return apache::thrift::detail::ac::withProtocolReader(state.protocolId(), [&](auto&& reader) {
    return apache::thrift::detail::ac::recv_wrapped<result>(
        &reader, state{{#if function.cpp_recv_arg?}}, _return{{/if}});
  });
}
{{/let partial}}
