{{#import "common/ttype" as ttype}}
{{#import "common/types" as types}}

{{! Struct deserialization. Starts from `init()` defaults, then overwrites each
    recognized field. Values are read via the field type's ThriftReadable
    conformance (`thriftRead`); unknown/mismatched fields are skipped. }}
{{#let export partial struct_read |structured| captures |ttype types|}}
public init<R: ProtocolReader>(from reader: R) throws {
    self.init()
    while true {
        let (fieldType, fieldId) = try reader.readFieldBegin()
        if fieldType == .stop {
            break
        }
        switch fieldId {
{{#each structured.fields as |field|}}
        case {{field.id}}:
            if fieldType == {{#partial ttype.swift_ttype type=field.type}} {
                self.{{field.swift_property_name}} = try {{#partial types.swift_type type=field.type}}.thriftRead(from: reader)
            } else {
                try reader.skip(fieldType)
            }
{{/each}}
        default:
            try reader.skip(fieldType)
        }
    }
}
{{/let partial}}
