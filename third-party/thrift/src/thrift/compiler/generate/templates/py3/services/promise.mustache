}}{{!

Included from CythonServices.pyx, it defines a Python wrapper for each type
of C++ promise that needs to be returned to C++. Cython doesn't support
templating on Python classes. This file is necessary primarily because the
cPromise shared_ptr needs to point to a promise that wraps a specific return
type in C++. The Python wrapper then gets passed into a coroutine where the
promise can have it's value set after the handler coroutine has finished
executing.

}}

{{#each program.unique_functions_by_return_type as |function|}}

@cython.auto_pickle(False)
cdef class {{#partial services.promise_name function=function}}:
    cdef cFollyPromise[{{!
            }}{{#partial services.cython_return_type_cpp_type function=function}}{{!
        }}]* cPromise

    def __cinit__(self):
        self.cPromise = new cFollyPromise[{{!
            }}{{#partial services.cython_return_type_cpp_type function=function}}{{!
        }}](cFollyPromise[{{!
            }}{{#partial services.cython_return_type_cpp_type function=function}}{{!
        }}].makeEmpty())

    def __dealloc__(self):
        del self.cPromise

    @staticmethod
    cdef _fbthrift_create(cFollyPromise[{{!
            }}{{#partial services.cython_return_type_cpp_type function=function}}{{!
        }}] cPromise):
        cdef {{#partial services.promise_name function=function}} inst = {{#partial services.promise_name function=function}}.__new__({{!
        }}{{#partial services.promise_name function=function}})
        inst.cPromise[0] = cmove(cPromise)
        return inst
{{/each}}
