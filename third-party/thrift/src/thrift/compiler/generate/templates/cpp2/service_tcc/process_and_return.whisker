  return {serializeResponse("{{#partial rpc.function_name service=interface function=function}}", &prot, ctx, result), std::move(bidiStreamFactory)};
          {{/if function.initial_response?}}
        {{#else if function.stream?}}
  {{service_cpp_name}}_{{function.prefixed_name}}_presult::InitialResponsePResultType result;
