{{! A Thrift enum becomes a Swift enum with an added `unknown(Int32)` case so
    that an i32 with no declared case is preserved on round-trip rather than
    rejected (guide 1.2.13). `init(rawValue:)` is total; the intrinsic default is
    `.init(rawValue: 0)` (guide 1.2.12). Case names keep their Thrift spelling. }}
{{#let export partial enum_type |enum|}}
/// Auto-generated from {{enum.name}}
public enum {{enum.swift_name}}: ThriftEnum {
{{#each enum.values as |ev|}}
    case {{ev.swift_name}}
{{/each}}
    /// An i32 with no declared case, preserved for forward compatibility.
    case unknown(Int32)

    public init(rawValue: Int32) {
        switch rawValue {
{{#each enum.values as |ev|}}
        case {{ev.value}}: self = .{{ev.swift_name}}
{{/each}}
        default: self = .unknown(rawValue)
        }
    }

    public var rawValue: Int32 {
        switch self {
{{#each enum.values as |ev|}}
        case .{{ev.swift_name}}: return {{ev.value}}
{{/each}}
        case .unknown(let value): return value
        }
    }

    /// The declared case name, or "unknown(<n>)" for an unrecognized value.
    public var name: String {
        switch self {
{{#each enum.values as |ev|}}
        case .{{ev.swift_name}}: return "{{ev.name}}"
{{/each}}
        case .unknown(let value): return "unknown(\(value))"
        }
    }

    /// Looks up a declared case by its Thrift name.
    public init?(name: String) {
        switch name {
{{#each enum.values as |ev|}}
        case "{{ev.name}}": self = .{{ev.swift_name}}
{{/each}}
        default: return nil
        }
    }
}
{{/let partial}}
