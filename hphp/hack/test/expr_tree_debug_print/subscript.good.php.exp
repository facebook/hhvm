function test_subscript_assign(): void {
  ExampleDsl::makeTree(
    darray[
      "path" => __FILE__,
      "start_line" => 82,
      "end_line" => 84,
      "start_column" => 13,
      "end_column" => 3,
    ],
    darray[
      "splices" => dict[],
      "functions" => vec[],
      "static_methods" => vec[],
      "variables" => vec[],
      "lexically_enclosing_tree" => NULL,
    ],
    (
      (ExampleDsl $v) ==> {
        return $v->visitLambda(
          darray[
            "path" => __FILE__,
            "start_line" => 82,
            "end_line" => 84,
            "start_column" => 13,
            "end_column" => 3,
          ],
          vec["$arr", "$idx", "$val"],
          vec[
            $v->visitSubscriptAssign(
              darray[
                "path" => __FILE__,
                "start_line" => 83,
                "end_line" => 83,
                "start_column" => 4,
                "end_column" => 21,
              ],
              $v->visitLocal(
                darray[
                  "path" => __FILE__,
                  "start_line" => 83,
                  "end_line" => 83,
                  "start_column" => 4,
                  "end_column" => 8,
                ],
                "$arr",
              ),
              vec[
                $v->visitLocal(
                  darray[
                    "path" => __FILE__,
                    "start_line" => 83,
                    "end_line" => 83,
                    "start_column" => 9,
                    "end_column" => 13,
                  ],
                  "$idx",
                ),
              ],
              $v->visitLocal(
                darray[
                  "path" => __FILE__,
                  "start_line" => 83,
                  "end_line" => 83,
                  "start_column" => 17,
                  "end_column" => 21,
                ],
                "$val",
              ),
            ),
          ],
        );
      }
    ),
  );
}

