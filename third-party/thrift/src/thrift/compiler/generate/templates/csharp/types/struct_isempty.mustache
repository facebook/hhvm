{{#import "common/types" as types}}

{{#let export partial struct_isempty |struct| captures |types|}}
public bool __fbthrift_is_empty()
{
{{#each struct.fields as |field|}}
{{#if field.optional?}}
    if ({{field.csharp_property_name}} != null) { return false; }
{{#else if field.type.list?}}
    if ({{field.csharp_property_name}} != null && {{field.csharp_property_name}}.Count != 0) { return false; }
{{#else if field.type.set?}}
    if ({{field.csharp_property_name}} != null && {{field.csharp_property_name}}.Count != 0) { return false; }
{{#else if field.type.map?}}
    if ({{field.csharp_property_name}} != null && {{field.csharp_property_name}}.Count != 0) { return false; }
{{#else if field.type.string?}}
    if ({{field.csharp_property_name}} != null && {{field.csharp_property_name}}.Length != 0) { return false; }
{{#else if field.type.binary?}}
    if ({{field.csharp_property_name}} != null && {{field.csharp_property_name}}.Length != 0) { return false; }
{{#else if field.type.structured?}}
    if ({{field.csharp_property_name}} != null && !{{field.csharp_property_name}}.__fbthrift_is_empty()) { return false; }
{{#else}}
    if ({{field.csharp_property_name}} != default) { return false; }
{{/if field.optional?}}
{{/each}}
    return true;
}
{{/let partial}}
