{{! Renders the neutral WireType enum-case literal for a Thrift type,
    used in field and collection headers. Protocol-agnostic: the concrete
    Compact/Binary codec maps this to its own on-wire ids. }}
{{#let export partial swift_ttype |type|}}
  {{#pragma ignore-newlines}}
{{#if type.void?}}.stop
{{#else if type.bool?}}.bool
{{#else if type.byte?}}.byte
{{#else if type.i16?}}.i16
{{#else if type.i32?}}.i32
{{#else if type.i64?}}.i64
{{#else if type.float?}}.float
{{#else if type.double?}}.double
{{#else if type.string?}}.string
{{#else if type.binary?}}.string
{{#else if type.list?}}.list
{{#else if type.set?}}.set
{{#else if type.map?}}.map
{{#else if type.enum?}}.i32
{{#else if type.structured?}}.struct
{{#else}}.stop
{{/if type.void?}}
{{/let partial}}
