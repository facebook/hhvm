//! Thrift constant definitions for `{{program.name}}`.

  {{#each program.consts as |constant|}}
    {{#if constant.docs?}}
#[doc = {{constant.docs}}]
    {{/if constant.docs?}}
    {{#if constant.lazy?}}
{{#partial lazy_constant constant=constant}}

    {{#else if constant.type.string?}}
pub const {{constant.rust_name}}: &::std::primitive::str = {{(rust_quote constant.value.string_value)}};
    {{#else}}
pub const {{constant.rust_name}}: {{#partial types.type_name type=constant.type}} = {{#partial constants.const_value value=constant.value}};
    {{/if constant.lazy?}}

  {{/each}}
  {{#if program.has_const_tests?}}
/// These are here to ensure adapted consts do not panic with `from_thrift`.
#[cfg(test)]
mod tests {
    {{#each program.consts_for_test as |constant|}}
    #[test]
    fn test_const_{{constant.name}}_force_does_not_panic() {
        let _ = ::std::sync::LazyLock::force(&super::{{constant.name}});
    }
    {{/each}}
}

