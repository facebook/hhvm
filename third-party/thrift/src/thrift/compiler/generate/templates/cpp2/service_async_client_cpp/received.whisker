{{#import "common/client" as client}}

{{#let export partial received |interface parent_service function| captures |client|}}
  {{#if function.sync_returns_by_outparam?}}
void {{#partial client.client_class_name service=interface parent_service=parent_service}}::recv_{{function.cpp_name}}({{function.cpp_return_type}}& _return, ::apache::thrift::ClientReceiveState& state) {
  auto ew = recv_wrapped_{{function.cpp_name}}(_return, state);
  {{#else}}
{{#partial client.return_type_no_handle function=function}} {{#partial client.client_class_name service=interface parent_service=parent_service}}::recv_{{function.cpp_name}}(::apache::thrift::ClientReceiveState& state) {
    {{#if function.cpp_recv_arg?}}
  {{#partial client.return_type_no_handle function=function}} _return;
  auto ew = recv_wrapped_{{function.cpp_name}}(_return, state);
    {{#else}}
  auto ew = recv_wrapped_{{function.cpp_name}}(state);
    {{/if function.cpp_recv_arg?}}
  {{/if function.sync_returns_by_outparam?}}
  if (ew) {
    ew.throw_exception();
  }
  {{#if (and (not function.sync_returns_by_outparam?) function.cpp_recv_arg?)}}
  return _return;
  {{/if (and (not function.sync_returns_by_outparam?) function.cpp_recv_arg?)}}
}
{{/let partial}}
