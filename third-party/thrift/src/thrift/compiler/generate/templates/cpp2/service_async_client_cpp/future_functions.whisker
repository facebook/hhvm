folly::Future<std::pair<{{#partial client.return_type_lift_unit function=function service=interface}}, std::unique_ptr<apache::thrift::transport::THeader>>> {{#partial client.client_class_name service=interface parent_service=parent_service}}::header_future_{{function.cpp_name}}(apache::thrift::RpcOptions& rpcOptions{{function_comma}}{{#partial client.function_param_list function=function}}) {
  using CallbackHelper = apache::thrift::detail::FutureCallbackHelper<std::pair<{{#partial client.return_type_lift_unit function=function service=interface}}, std::unique_ptr<apache::thrift::transport::THeader>>>;
  folly::Promise<CallbackHelper::PromiseResult> promise;
  auto future = promise.getFuture();
  auto callback = std::make_unique<apache::thrift::HeaderFutureCallback<{{#partial client.return_type_lift_unit function=function service=interface}}>>(std::move(promise), recv_wrapped_{{function.cpp_name}}, channel_);
  {{function.cpp_name}}(rpcOptions, std::move(callback){{function_comma}}{{#partial rpc.param_list function=function}});
  return std::move(future).thenValue(CallbackHelper::processClientInterceptorsAndExtractResult);
}

    {{/if (not function.stream?)}}
folly::SemiFuture<std::pair<{{#partial client.return_type_lift_unit function=function service=interface}}, std::unique_ptr<apache::thrift::transport::THeader>>> {{#partial client.client_class_name service=interface parent_service=parent_service}}::header_semifuture_{{function.cpp_name}}(apache::thrift::RpcOptions& rpcOptions{{function_comma}}{{#partial client.function_param_list function=function}}) {
