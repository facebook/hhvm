{{#import "common/client" as client}}
{{#import "common/rpc" as rpc}}

{{#let export partial templated_received |interface parent_service| captures |client rpc|}}
  {{#each interface.functions as |function|}}
    {{#let in_or_creates_interaction? = (or interface.interaction? function.creates_interaction?)}}
    {{#if (not function.starts_interaction?)}}
template <typename RpcOptions>
void {{#partial client.client_class_name service=interface parent_service=parent_service}}::fbthrift_send_{{function.cpp_name}}(apache::thrift::SerializedRequest&& request, RpcOptions&& rpcOptions, std::shared_ptr<apache::thrift::transport::THeader> header, {{#partial client.callback_type function=function}} callback, std::unique_ptr<folly::IOBuf> interceptorFrameworkMetadata{{#if function.creates_interaction?}}, const apache::thrift::InteractionHandle& handle{{/if}}) {
      {{#if in_or_creates_interaction?}}
  apache::thrift::RpcOptions rpcOpts(std::forward<RpcOptions>(rpcOptions));
  setInteraction({{#if function.creates_interaction?}}handle, {{/if}}rpcOpts);
      {{/if in_or_creates_interaction?}}

  static ::apache::thrift::MethodMetadata::Data* methodMetadata =
        new ::apache::thrift::MethodMetadata::Data(
                "{{#partial rpc.function_name service=interface function=function}}",
                ::apache::thrift::FunctionQualifier::{{function.qualifier}},
                "{{#if (string.empty? interface.uri)}}{{#if interface.interaction?}}{{parent_service.name}}{{#else}}{{interface.name}}{{/if}}{{#else}}{{interface.uri}}{{/if}}"{{#if function.creates_interaction?}},
                ::apache::thrift::InteractionMethodPosition::Factory,
                "{{function.created_interaction.cpp_name}}"{{/if function.creates_interaction?}}{{#if interface.interaction?}},
                ::apache::thrift::InteractionMethodPosition::Member,
                "{{interface.name}}"{{/if interface.interaction?}});
  apache::thrift::clientSendT<{{#partial rpc.function_kind function=function}}>(std::move(request), {{!
    }}{{#if in_or_creates_interaction?}}std::move(rpcOpts){{#else}}std::forward<RpcOptions>(rpcOptions){{/if}}{{!
    }}, std::move(callback), std::move(header), channel_.get(), ::apache::thrift::MethodMetadata::from_static(methodMetadata), std::move(interceptorFrameworkMetadata));
}

    {{/if (not function.starts_interaction?)}}
  {{/each}}

{{/let partial}}
