}}{{#each def.fields as |field|}}
  FROZEN_CTOR_FIELD{{#partial module_layouts.frozen2_union_field_suffix field=field}}({{field.cpp_name}}, {{field.id}}){{!
}}{{/each}})

FROZEN_MAXIMIZE({{def.cpp_fullname}},{{!
}}
  FROZEN_MAXIMIZE_FIELD(fbthrift_type_);{{!
}}{{#each def.fields as |field|}}
