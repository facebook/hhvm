}}{{!

Python wrappers of the structs defined in the services files. This file is
compiled into it's own module to be included by clients and services and
end-user code. It's one of the more complicated files, as it has to map
Pythonic APIs to C++ objects and back.

One of the nastier things in this file is the definition of containers.
A separate container wrapper has to be defined for each type of contained
attribute because Cython can't template C++ classes. So, for example, we need
a List__int16 or a List__string or a Map__string_mystruct instance for each
container/type combination. Consider that containers can contain other containers
or structs that contain containers and you realize how messy this can get.
Further, we'd prefer to have the end user freed from having to know about these
container types, so we'll need to define factories for them based on what they
want to include.

}}
{{#import "common/types" as types}}
{{! Base class name for py3 auto-migrate flat-name containers }}
{{#let partial container_base |type|}}
{{#pragma ignore-newlines}}
{{#if type.list?}}List{{#else if type.set?}}Set{{#else if type.map?}}Map{{/if}}
{{/let partial}}{{!

}}
{{> common/auto_generated_py}}
{{#if program.auto_migrate?}}
{{! Note this is needed even if IDL defines no types, in the case where service has arguments that are container<primitive>}}
_fbthrift__py3_module_name = "{{program.module_path}}.types"
  {{#if program.has_types?}}
from {{program.module_path}}.thrift_types import (
    {{#each program.structured_definitions as |struct|}}
    {{struct.name}},
    {{/each}}
    {{#each program.enums as |enum|}}
    {{enum.name}},
    {{/each}}
    {{#each program.consts as |constant|}}
    {{constant.name}},
    {{/each}}
    {{#each program.typedefs as |typedef|}}
    {{typedef.name}},
    {{/each}}
)
  {{/if program.has_types?}}
  {{#if program.has_container_types?}}
import importlib
import thrift.python.types as _fbthrift_python_types
import {{program.module_path}}.thrift_types as {{!
}}{{program.module_path_for_alias}}_thrift_types
    {{#each program.includeNamespaces as |include|}}
      {{#if include.program.has_types?}}
import {{include.program.module_path}}.thrift_types as {{include.program.module_path_for_alias}}_thrift_types
      {{/if include.program.has_types?}}
    {{/each}}
  {{/if program.has_container_types?}}
{{!

py3-container "flat name" name aliases for backwards-compatibility

}}
  {{#if program.has_container_types?}}
def get_types_reflection():
    return importlib.import_module(
        "{{program.module_path}}.types_reflection"
    )
  {{/if program.has_container_types?}}
  {{#each program.container_types as |type|}}
    {{#if type.container?}}
class {{type.flat_name}}__Meta(type):
    def _fbthrift_type_info(cls):
        return (
          {{#if (or type.list? type.set?)}}
            {{#partial types.typeinfo type=type.true_type.elem_type}},
          {{#else if type.map?}}
            {{#partial types.typeinfo type=type.true_type.key_type}},
            {{#partial types.typeinfo type=type.true_type.val_type}},
          {{/if (or type.list? type.set?)}}
        )

    def __instancecheck__(cls, instance):
        return (
            isinstance(instance, _fbthrift_python_types.{{#partial container_base type=type}}) and
            instance._fbthrift_same_type(*cls._fbthrift_type_info())
        )

class {{type.flat_name}}(_fbthrift_python_types.{{#partial container_base type=type}}, metaclass={{type.flat_name}}__Meta):
    __module__ = _fbthrift__py3_module_name
    __slots__ = ()

    def __init__(self, *args, **kwargs):
        if not args and not kwargs:
            args = {{#if type.map?}}({},){{#else}}((),){{/if}}
        super().__init__(
            *{{type.flat_name}}._fbthrift_type_info(),
            *args,
            **kwargs,
        )

    @staticmethod
    def __get_reflection__():
        return get_types_reflection().get_reflection__{{type.flat_name}}()

    {{/if type.container?}}
  {{/each}}
{{/if program.auto_migrate?}}
