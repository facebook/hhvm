{{#let export partial method_metadata |interface|}}
// From {{interface.program.name}}.{{interface.name}}:
  {{#if interface.interaction?}}
// Interaction's method names are never queried directly.
// They are always queried from the "main" processor.
  {{#else}}
    {{#each interface.functions as |function|}}
      {{#if (not function.starts_interaction?)}}
::fbthrift::processor::MethodMetadata{
  interaction_type: ::fbthrift::processor::InteractionType::None,
        {{#if function.bidirectional_stream?}}
  rpc_kind: ::fbthrift::processor::RpcKind::BIDIRECTIONAL_STREAM,
        {{#else if function.stream?}}
  rpc_kind: ::fbthrift::processor::RpcKind::SINGLE_REQUEST_STREAMING_RESPONSE,
        {{#else if function.sink?}}
  rpc_kind: ::fbthrift::processor::RpcKind::SINK,
        {{#else if function.oneway?}}
  rpc_kind: ::fbthrift::processor::RpcKind::SINGLE_REQUEST_NO_RESPONSE,
        {{#else}}
  rpc_kind: ::fbthrift::processor::RpcKind::SINGLE_REQUEST_SINGLE_RESPONSE,
        {{/if function.bidirectional_stream?}}
  name: "{{function.name}}",
  starts_interaction: {{#if function.creates_interaction?}}true{{#else}}false{{/if}},
  interaction_name: {{#if function.creates_interaction?}}Some("{{function.interaction_name}}"){{#else}}None{{/if}},
},
      {{/if (not function.starts_interaction?)}}
    {{/each}}
    {{#each interface.interactions as |interaction|}}
      {{#each interaction.functions as |function|}}
::fbthrift::processor::MethodMetadata{
  interaction_type: ::fbthrift::processor::InteractionType::InteractionV1,
        {{#if function.bidirectional_stream?}}
  rpc_kind: ::fbthrift::processor::RpcKind::BIDIRECTIONAL_STREAM,
        {{#else if function.stream?}}
  rpc_kind: ::fbthrift::processor::RpcKind::SINGLE_REQUEST_STREAMING_RESPONSE,
        {{#else if function.sink?}}
  rpc_kind: ::fbthrift::processor::RpcKind::SINK,
        {{#else if function.oneway?}}
  rpc_kind: ::fbthrift::processor::RpcKind::SINGLE_REQUEST_NO_RESPONSE,
        {{#else}}
  rpc_kind: ::fbthrift::processor::RpcKind::SINGLE_REQUEST_SINGLE_RESPONSE,
        {{/if function.bidirectional_stream?}}
  name: "{{interaction.name}}.{{function.name}}",
  starts_interaction: false,
  interaction_name: Some("{{interaction.name}}"),
},
      {{/each}}
    {{/each}}
    {{#if (object.notnull? interface.extends)}}

{{#partial method_metadata interface=interface.extends}}
    {{/if (object.notnull? interface.extends)}}
  {{/if interface.interaction?}}
{{/let partial}}
