}}{{!
Reflection spec functions for thrift-python services.
Each get_reflection__<ServiceName>() returns a ServiceSpec (or None if the
reflection library is unavailable).
}}
{{#import "common/common" as m_common}}
{{#import "common/types" as m_types}}

{{! Map a Thrift type to its ThriftType enum name }}
{{#let partial thrift_type_name |type|}}
{{#pragma ignore-newlines}}
{{#if type.void?}}_ThriftType.VOID
{{#else if type.bool?}}_ThriftType.BOOL
{{#else if type.byte?}}_ThriftType.BYTE
{{#else if type.i16?}}_ThriftType.I16
{{#else if type.i32?}}_ThriftType.I32
{{#else if type.i64?}}_ThriftType.I64
{{#else if type.float?}}_ThriftType.FLOAT
{{#else if type.double?}}_ThriftType.DOUBLE
{{#else if type.string?}}_ThriftType.STRING
{{#else if type.binary?}}_ThriftType.BINARY
{{#else if type.list?}}_ThriftType.LIST
{{#else if type.set?}}_ThriftType.SET
{{#else if type.map?}}_ThriftType.MAP
{{#else if type.enum?}}_ThriftType.ENUM
{{#else if type.union?}}_ThriftType.UNION
{{#else if type.structured?}}_ThriftType.STRUCT
{{/if type.void?}}
{{/let partial}}

{{! Map a Thrift type to its Python type class reference }}
{{#let partial python_type_class |type| captures |m_types|}}
{{#pragma ignore-newlines}}
{{#if type.bool?}}bool
{{#else if type.byte?}}int
{{#else if type.i16?}}int
{{#else if type.i32?}}int
{{#else if type.i64?}}int
{{#else if type.float?}}float
{{#else if type.double?}}float
{{#else if type.string?}}str
{{#else if type.binary?}}bytes
{{#else if type.enum?}}{{type.module_mangle}}.{{type.true_type.py_name}}
{{#else if type.structured?}}{{type.module_mangle}}.{{#partial m_types.unadapted_name type=type.true_type}}
{{#else if (and type.typedef? type.container?)}}{{#if type.owning_need_module_path?}}{{type.owning_module_mangle}}.{{/if}}{{type.py_name}}
{{/if type.bool?}}
{{/let partial}}

{{! Local variable name for an anonymous container typedef for a function arg }}
{{#let partial arg_container_var |function field|}}
{{#pragma ignore-newlines}}
_fbthrift_{{function.name}}_arg_{{#if (int.lt? field.id 0)}}minus{{(int.neg field.id)}}{{#else}}{{field.id}}{{/if}}_type
{{/let partial}}

{{! Local variable name for an anonymous container typedef for a return type }}
{{#let partial ret_container_var |function|}}
{{#pragma ignore-newlines}}
_fbthrift_{{function.name}}_return_type
{{/let partial}}

{{! Local variable name for an anonymous container typedef for a stream element type }}
{{#let partial stream_elem_container_var |function|}}
{{#pragma ignore-newlines}}
_fbthrift_{{function.name}}_stream_elem_type
{{/let partial}}

{{! Local variable name for an anonymous container typedef for a sink payload type }}
{{#let partial sink_payload_container_var |function|}}
{{#pragma ignore-newlines}}
_fbthrift_{{function.name}}_sink_payload_type
{{/let partial}}

{{! Local variable name for an anonymous container typedef for a sink final response type }}
{{#let partial sink_final_resp_container_var |function|}}
{{#pragma ignore-newlines}}
_fbthrift_{{function.name}}_sink_final_resp_type
{{/let partial}}

{{#partial m_common.auto_generated_py}}


try:
    from thrift.python.reflection.types_reflection import (
        ThriftType as _ThriftType,
        Qualifier as _Qualifier,
    )
    from thrift.python.reflection.services_reflection import (
        ArgumentSpec as _ArgumentSpec,
        ExceptionSpec as _ExceptionSpec,
        FunctionSpec as _FunctionSpec,
        ServiceSpec as _ServiceSpec,
        SinkSpec as _SinkSpec,
        StreamSpec as _StreamSpec,
    )
    from thrift.python.reflection_enums import (
        FunctionQualifier as _FunctionQualifier,
    )
    from thrift.python.reflection.constants_reflection import (
        ConstantSpec as _ConstantSpec,
        ConstantStructSpec as _ConstantStructSpec,
        ConstantUnionSpec as _ConstantUnionSpec,
        ConstantEnumSpec as _ConstantEnumSpec,
        ConstantMapSpec as _ConstantMapSpec,
        ConstantListSpec as _ConstantListSpec,
        ConstantSetSpec as _ConstantSetSpec,
    )
    import thrift.python.container_typedefs as _fbthrift_python_container_typedefs
    _QUALIFIER_MAP = {
        "Unspecified": _FunctionQualifier.UNSPECIFIED,
        "OneWay": _FunctionQualifier.ONE_WAY,
        "Idempotent": _FunctionQualifier.IDEMPOTENT,
        "ReadOnly": _FunctionQualifier.READ_ONLY,
    }
    _HAS_REFLECTION = True
except ImportError:
    _HAS_REFLECTION = False

import thrift.python.types as _fbthrift_python_types

import {{program.module_path}}.thrift_types as {{program.module_mangle}}__thrift_types
{{#each program.include_namespaces as |include|}}
  {{#if include.has_types?}}
import {{include.included_module_path}}.thrift_types as {{include.included_module_mangle}}__thrift_types
  {{/if include.has_types?}}
  {{#if include.has_services?}}
import {{include.included_module_path}}.thrift_services_reflection as {{include.included_module_mangle}}__thrift_services_reflection
  {{/if include.has_services?}}
{{/each}}


{{#each program.services as |service|}}

def get_reflection__{{service.name}}():
    if not _HAS_REFLECTION:
        return None
  {{#each service.reflection_import_types as |type|}}
    import {{type.module_name}} as {{type.module_mangle}}  # noqa: F811
  {{/each}}
  {{#each service.supported_functions as |function|}}
    {{#each function.params.fields as |field|}}
      {{#if (and field.type.container? (not field.type.typedef?))}}
        {{#if field.type.list?}}
    class {{#partial arg_container_var function=function field=field}}(_fbthrift_python_container_typedefs._ListTypedefBase):
        __slots__ = ()
        __name__ = "List__{{service.name}}_{{function.name}}_{{field.py_name}}"
        __qualname__ = "List__{{service.name}}_{{function.name}}_{{field.py_name}}"
        __module__ = "{{program.module_path}}.thrift_types"
        _fbthrift_list_type_info = {{#partial m_types.typeinfo type=field.type.true_type.elem_type}}
        {{#else if field.type.set?}}
    class {{#partial arg_container_var function=function field=field}}(_fbthrift_python_container_typedefs._SetTypedefBase):
        __slots__ = ()
        __name__ = "Set__{{service.name}}_{{function.name}}_{{field.py_name}}"
        __qualname__ = "Set__{{service.name}}_{{function.name}}_{{field.py_name}}"
        __module__ = "{{program.module_path}}.thrift_types"
        _fbthrift_set_type_info = {{#partial m_types.typeinfo type=field.type.true_type.elem_type}}
        {{#else if field.type.map?}}
    class {{#partial arg_container_var function=function field=field}}(_fbthrift_python_container_typedefs._MapTypedefBase):
        __slots__ = ()
        __name__ = "Map__{{service.name}}_{{function.name}}_{{field.py_name}}"
        __qualname__ = "Map__{{service.name}}_{{function.name}}_{{field.py_name}}"
        __module__ = "{{program.module_path}}.thrift_types"
        _fbthrift_map_key_type_info = {{#partial m_types.typeinfo type=field.type.true_type.key_type}}
        _fbthrift_map_val_type_info = {{#partial m_types.typeinfo type=field.type.true_type.val_type}}
        {{/if field.type.list?}}
      {{/if (and field.type.container? (not field.type.typedef?))}}
    {{/each}}
    {{#if (and (not function.return_type.void?) function.return_type.container? (not function.return_type.typedef?))}}
      {{#if function.return_type.list?}}
    class {{#partial ret_container_var function=function}}(_fbthrift_python_container_typedefs._ListTypedefBase):
        __slots__ = ()
        __name__ = "List__{{service.name}}_{{function.name}}_return"
        __qualname__ = "List__{{service.name}}_{{function.name}}_return"
        __module__ = "{{program.module_path}}.thrift_types"
        _fbthrift_list_type_info = {{#partial m_types.typeinfo type=function.return_type.true_type.elem_type}}
      {{#else if function.return_type.set?}}
    class {{#partial ret_container_var function=function}}(_fbthrift_python_container_typedefs._SetTypedefBase):
        __slots__ = ()
        __name__ = "Set__{{service.name}}_{{function.name}}_return"
        __qualname__ = "Set__{{service.name}}_{{function.name}}_return"
        __module__ = "{{program.module_path}}.thrift_types"
        _fbthrift_set_type_info = {{#partial m_types.typeinfo type=function.return_type.true_type.elem_type}}
      {{#else if function.return_type.map?}}
    class {{#partial ret_container_var function=function}}(_fbthrift_python_container_typedefs._MapTypedefBase):
        __slots__ = ()
        __name__ = "Map__{{service.name}}_{{function.name}}_return"
        __qualname__ = "Map__{{service.name}}_{{function.name}}_return"
        __module__ = "{{program.module_path}}.thrift_types"
        _fbthrift_map_key_type_info = {{#partial m_types.typeinfo type=function.return_type.true_type.key_type}}
        _fbthrift_map_val_type_info = {{#partial m_types.typeinfo type=function.return_type.true_type.val_type}}
      {{/if function.return_type.list?}}
    {{/if (and (not function.return_type.void?) function.return_type.container? (not function.return_type.typedef?))}}
    {{#if function.stream?}}
      {{#if (and function.stream.elem_type.container? (not function.stream.elem_type.typedef?))}}
        {{#if function.stream.elem_type.list?}}
    class {{#partial stream_elem_container_var function=function}}(_fbthrift_python_container_typedefs._ListTypedefBase):
        __slots__ = ()
        __name__ = "List__{{service.name}}_{{function.name}}_stream_elem"
        __qualname__ = "List__{{service.name}}_{{function.name}}_stream_elem"
        __module__ = "{{program.module_path}}.thrift_types"
        _fbthrift_list_type_info = {{#partial m_types.typeinfo type=function.stream.elem_type.true_type.elem_type}}
        {{#else if function.stream.elem_type.set?}}
    class {{#partial stream_elem_container_var function=function}}(_fbthrift_python_container_typedefs._SetTypedefBase):
        __slots__ = ()
        __name__ = "Set__{{service.name}}_{{function.name}}_stream_elem"
        __qualname__ = "Set__{{service.name}}_{{function.name}}_stream_elem"
        __module__ = "{{program.module_path}}.thrift_types"
        _fbthrift_set_type_info = {{#partial m_types.typeinfo type=function.stream.elem_type.true_type.elem_type}}
        {{#else if function.stream.elem_type.map?}}
    class {{#partial stream_elem_container_var function=function}}(_fbthrift_python_container_typedefs._MapTypedefBase):
        __slots__ = ()
        __name__ = "Map__{{service.name}}_{{function.name}}_stream_elem"
        __qualname__ = "Map__{{service.name}}_{{function.name}}_stream_elem"
        __module__ = "{{program.module_path}}.thrift_types"
        _fbthrift_map_key_type_info = {{#partial m_types.typeinfo type=function.stream.elem_type.true_type.key_type}}
        _fbthrift_map_val_type_info = {{#partial m_types.typeinfo type=function.stream.elem_type.true_type.val_type}}
        {{/if function.stream.elem_type.list?}}
      {{/if (and function.stream.elem_type.container? (not function.stream.elem_type.typedef?))}}
    {{/if function.stream?}}
    {{#if function.sink?}}
      {{#if (and function.sink.elem_type.container? (not function.sink.elem_type.typedef?))}}
        {{#if function.sink.elem_type.list?}}
    class {{#partial sink_payload_container_var function=function}}(_fbthrift_python_container_typedefs._ListTypedefBase):
        __slots__ = ()
        __name__ = "List__{{service.name}}_{{function.name}}_sink_payload"
        __qualname__ = "List__{{service.name}}_{{function.name}}_sink_payload"
        __module__ = "{{program.module_path}}.thrift_types"
        _fbthrift_list_type_info = {{#partial m_types.typeinfo type=function.sink.elem_type.true_type.elem_type}}
        {{#else if function.sink.elem_type.set?}}
    class {{#partial sink_payload_container_var function=function}}(_fbthrift_python_container_typedefs._SetTypedefBase):
        __slots__ = ()
        __name__ = "Set__{{service.name}}_{{function.name}}_sink_payload"
        __qualname__ = "Set__{{service.name}}_{{function.name}}_sink_payload"
        __module__ = "{{program.module_path}}.thrift_types"
        _fbthrift_set_type_info = {{#partial m_types.typeinfo type=function.sink.elem_type.true_type.elem_type}}
        {{#else if function.sink.elem_type.map?}}
    class {{#partial sink_payload_container_var function=function}}(_fbthrift_python_container_typedefs._MapTypedefBase):
        __slots__ = ()
        __name__ = "Map__{{service.name}}_{{function.name}}_sink_payload"
        __qualname__ = "Map__{{service.name}}_{{function.name}}_sink_payload"
        __module__ = "{{program.module_path}}.thrift_types"
        _fbthrift_map_key_type_info = {{#partial m_types.typeinfo type=function.sink.elem_type.true_type.key_type}}
        _fbthrift_map_val_type_info = {{#partial m_types.typeinfo type=function.sink.elem_type.true_type.val_type}}
        {{/if function.sink.elem_type.list?}}
      {{/if (and function.sink.elem_type.container? (not function.sink.elem_type.typedef?))}}
      {{#if (not function.bidirectional_stream?)}}
        {{#if (and function.sink.final_response_type.container? (not function.sink.final_response_type.typedef?))}}
          {{#if function.sink.final_response_type.list?}}
    class {{#partial sink_final_resp_container_var function=function}}(_fbthrift_python_container_typedefs._ListTypedefBase):
        __slots__ = ()
        __name__ = "List__{{service.name}}_{{function.name}}_sink_final_resp"
        __qualname__ = "List__{{service.name}}_{{function.name}}_sink_final_resp"
        __module__ = "{{program.module_path}}.thrift_types"
        _fbthrift_list_type_info = {{#partial m_types.typeinfo type=function.sink.final_response_type.true_type.elem_type}}
          {{#else if function.sink.final_response_type.set?}}
    class {{#partial sink_final_resp_container_var function=function}}(_fbthrift_python_container_typedefs._SetTypedefBase):
        __slots__ = ()
        __name__ = "Set__{{service.name}}_{{function.name}}_sink_final_resp"
        __qualname__ = "Set__{{service.name}}_{{function.name}}_sink_final_resp"
        __module__ = "{{program.module_path}}.thrift_types"
        _fbthrift_set_type_info = {{#partial m_types.typeinfo type=function.sink.final_response_type.true_type.elem_type}}
          {{#else if function.sink.final_response_type.map?}}
    class {{#partial sink_final_resp_container_var function=function}}(_fbthrift_python_container_typedefs._MapTypedefBase):
        __slots__ = ()
        __name__ = "Map__{{service.name}}_{{function.name}}_sink_final_resp"
        __qualname__ = "Map__{{service.name}}_{{function.name}}_sink_final_resp"
        __module__ = "{{program.module_path}}.thrift_types"
        _fbthrift_map_key_type_info = {{#partial m_types.typeinfo type=function.sink.final_response_type.true_type.key_type}}
        _fbthrift_map_val_type_info = {{#partial m_types.typeinfo type=function.sink.final_response_type.true_type.val_type}}
          {{/if function.sink.final_response_type.list?}}
        {{/if (and function.sink.final_response_type.container? (not function.sink.final_response_type.typedef?))}}
      {{/if (not function.bidirectional_stream?)}}
    {{/if function.sink?}}
  {{/each}}
    functions = {}
  {{#each service.supported_functions as |function|}}
    _fbthrift_args = []
    {{#each function.params.fields as |field|}}
    _fbthrift_args.append(
        _ArgumentSpec(
            id={{field.id}},
            name="{{field.name}}",
            py_name="{{field.py_name}}",
            type={{!
                }}{{#if (and field.type.container? (not field.type.typedef?))}}{{!
                    }}{{#partial arg_container_var function=function field=field}}{{!
                }}{{#else}}{{!
                    }}{{#partial python_type_class type=field.type}}{{!
                }}{{/if (and field.type.container? (not field.type.typedef?))}},
            thrift_type={{#partial thrift_type_name type=field.type}},
            qualifier=_Qualifier.{{!
                }}{{#if field.required?}}REQUIRED{{!
                }}{{#else if field.optional?}}OPTIONAL{{!
                }}{{#else}}UNQUALIFIED{{/if field.required?}},
            structured_annotations={
                {{#each field.structured_annotations as |annotation|}}
                  {{#if annotation.type.structured?}}
                {{#annotation.value}}{{#value:type.true_type}}"{{type:program.name}}.{{> structs/unadapted_name}}"{{/value:type.true_type}}: {{> reflection/const_value }}{{/annotation.value}},
                  {{/if annotation.type.structured?}}
                {{/each}}
            },
        ),
    )
    {{/each}}
    _fbthrift_exceptions = []
    {{#each function.exceptions as |field|}}
    _fbthrift_exceptions.append(
        _ExceptionSpec(
            id={{field.id}},
            name="{{field.name}}",
            py_name="{{field.py_name}}",
            type={{#partial python_type_class type=field.type}},
            thrift_type={{#partial thrift_type_name type=field.type}},
            qualifier=_Qualifier.UNQUALIFIED,
            structured_annotations={},
        ),
    )
    {{/each}}
    functions["{{function.name}}"] = _FunctionSpec(
        name="{{function.name}}",
        arguments=_fbthrift_args,
  {{#if function.return_type.void?}}
        return_type=None,
        return_thrift_type=_ThriftType.VOID,
  {{#else}}
        return_type={{!
            }}{{#if (and function.return_type.container? (not function.return_type.typedef?))}}{{!
                }}{{#partial ret_container_var function=function}}{{!
            }}{{#else}}{{!
                }}{{#partial python_type_class type=function.return_type}}{{!
            }}{{/if (and function.return_type.container? (not function.return_type.typedef?))}},
        return_thrift_type={{#partial thrift_type_name type=function.return_type}},
  {{/if function.return_type.void?}}
        qualifier=_QUALIFIER_MAP["{{function.qualifier}}"],
        exceptions=_fbthrift_exceptions,
  {{#if function.stream?}}
        stream=_StreamSpec(
            elem_type={{!
                }}{{#if (and function.stream.elem_type.container? (not function.stream.elem_type.typedef?))}}{{!
                    }}{{#partial stream_elem_container_var function=function}}{{!
                }}{{#else}}{{!
                    }}{{#partial python_type_class type=function.stream.elem_type}}{{!
                }}{{/if (and function.stream.elem_type.container? (not function.stream.elem_type.typedef?))}},
            elem_thrift_type={{#partial thrift_type_name type=function.stream.elem_type}},
    {{#if function.stream_exceptions?}}
            exceptions=[
      {{#each function.stream.exceptions as |field|}}
                _ExceptionSpec(
                    id={{field.id}},
                    name="{{field.name}}",
                    py_name="{{field.py_name}}",
                    type={{#partial python_type_class type=field.type}},
                    thrift_type={{#partial thrift_type_name type=field.type}},
                    qualifier=_Qualifier.UNQUALIFIED,
                    structured_annotations={},
                ),
      {{/each}}
            ],
    {{/if function.stream_exceptions?}}
        ),
  {{/if function.stream?}}
  {{#if function.sink?}}
        sink=_SinkSpec(
            payload_type={{!
                }}{{#if (and function.sink.elem_type.container? (not function.sink.elem_type.typedef?))}}{{!
                    }}{{#partial sink_payload_container_var function=function}}{{!
                }}{{#else}}{{!
                    }}{{#partial python_type_class type=function.sink.elem_type}}{{!
                }}{{/if (and function.sink.elem_type.container? (not function.sink.elem_type.typedef?))}},
            payload_thrift_type={{#partial thrift_type_name type=function.sink.elem_type}},
    {{#if function.sink_exceptions?}}
            payload_exceptions=[
      {{#each function.sink.exceptions as |field|}}
                _ExceptionSpec(
                    id={{field.id}},
                    name="{{field.name}}",
                    py_name="{{field.py_name}}",
                    type={{#partial python_type_class type=field.type}},
                    thrift_type={{#partial thrift_type_name type=field.type}},
                    qualifier=_Qualifier.UNQUALIFIED,
                    structured_annotations={},
                ),
      {{/each}}
            ],
    {{/if function.sink_exceptions?}}
    {{#if (not function.bidirectional_stream?)}}
            final_response_type={{#partial python_type_class type=function.sink.final_response_type}},
            final_response_thrift_type={{#partial thrift_type_name type=function.sink.final_response_type}},
      {{#if function.sink_final_response_exceptions?}}
            final_response_exceptions=[
        {{#each function.sink.final_response_exceptions as |field|}}
                _ExceptionSpec(
                    id={{field.id}},
                    name="{{field.name}}",
                    py_name="{{field.py_name}}",
                    type={{#partial python_type_class type=field.type}},
                    thrift_type={{#partial thrift_type_name type=field.type}},
                    qualifier=_Qualifier.UNQUALIFIED,
                    structured_annotations={},
                ),
        {{/each}}
            ],
      {{/if function.sink_final_response_exceptions?}}
    {{/if (not function.bidirectional_stream?)}}
        ),
  {{/if function.sink?}}
        structured_annotations={
            {{#each function.structured_annotations as |annotation|}}
              {{#if annotation.type.structured?}}
            {{#annotation.value}}{{#value:type.true_type}}"{{type:program.name}}.{{> structs/unadapted_name}}"{{/value:type.true_type}}: {{> reflection/const_value }}{{/annotation.value}},
              {{/if annotation.type.structured?}}
            {{/each}}
        },
    )
  {{/each}}
  {{#let parent = (if service.interaction? null service.extends)}}
  {{#let has_parent = (object.notnull? parent)}}
    return _ServiceSpec(
        name="{{service.name}}",
        functions=functions,
  {{#if has_parent}}
        parent={{#if parent.external_program?}}{{parent.program.module_mangle}}__thrift_services_reflection.{{/if}}get_reflection__{{parent.name}}(),
  {{/if has_parent}}
        structured_annotations={
            {{#each service.structured_annotations as |annotation|}}
              {{#if annotation.type.structured?}}
            {{#annotation.value}}{{#value:type.true_type}}"{{type:program.name}}.{{> structs/unadapted_name}}"{{/value:type.true_type}}: {{> reflection/const_value }}{{/annotation.value}},
              {{/if annotation.type.structured?}}
