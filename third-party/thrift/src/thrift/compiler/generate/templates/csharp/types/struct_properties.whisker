{{#import "common/types" as types}}
{{#import "common/defaults" as defaults}}
{{#import "common/constants" as constants}}

{{#let export partial struct_properties |field structured| captures |types defaults constants|}}
/// <summary>Gets or sets the {{field.name}} field{{#if field.optional?}} (optional){{/if field.optional?}}.</summary>
  {{#if field.optional?}}
public {{#partial types.csharp_type type=field.type}}? {{field.csharp_property_name}} { get; set; }
  {{#else if field.type.nullable?}}
private {{#partial types.csharp_type type=field.type}} _{{field.name}} = {{!}}
    {{~ #if (object.notnull? field.default_value)}}{{#partial constants.csharp_const_value value=field.default_value}}{{#else}}{{#partial defaults.csharp_default_value type=field.type}}{{/if (object.notnull? field.default_value)}};
public {{#partial types.csharp_type type=field.type}} {{field.csharp_property_name}}
{
    get => _{{field.name}};
    set
    {
        ThriftNullGuard.ThrowIfNull(value, "{{field.name}}");
        _{{field.name}} = value;
    }
}
  {{#else if (object.notnull? field.default_value)}}
public {{#partial types.csharp_type type=field.type}} {{field.csharp_property_name}} { get; set; } = {{#partial constants.csharp_const_value value=field.default_value}};
  {{#else}}
public {{#partial types.csharp_type type=field.type}} {{field.csharp_property_name}} { get; set; }
  {{/if field.optional?}}
{{/let partial}}
