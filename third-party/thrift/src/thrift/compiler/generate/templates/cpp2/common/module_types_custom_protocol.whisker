{{#import "common/fields" as fields}}
{{#import "common/types" as types}}

{{! The field member/pointer access expression for deserialization. }}
{{#let export partial member_or_ptr |field struct| captures |fields|}}
{{#pragma ignore-newlines}}
  {{#if field.cpp_ref?}}
    {{#if field.intern_boxed_ref?}}
ptr.mut()
    {{#else}}
*ptr
    {{/if field.intern_boxed_ref?}}
  {{#else}}
{{#partial fields.member field=field struct=struct}}
  {{/if field.cpp_ref?}}
{{/let partial}}

{{! The instance of protocol methods to use. }}
{{#let export partial protocol_methods |field|}}
{{#pragma ignore-newlines}}
::apache::thrift::detail::pm::protocol_methods<{{field.type.type_class}}, {{field.cpp_standard_type}}>
{{/let partial}}

{{! The field value to use with protocol methods. }}
{{#let export partial protocol_methods_value |field struct| captures |fields|}}
{{#pragma ignore-newlines}}
{{#if (object.notnull? field.type.cpp_adapter)}}{{field.type.cpp_adapter}}::toThrift({{/if}}
{{#if (object.notnull? field.cpp_adapter)}}{{field.cpp_adapter}}::toThrift({{/if}}
{{#if field.cpp_ref?}}*{{/if}}{{#partial fields.member field=field struct=struct}}
{{#if (object.notnull? field.cpp_adapter)}}){{/if}}
{{#if (object.notnull? field.type.cpp_adapter)}}){{/if}}
{{/let partial}}

{{! The container type arguments for struct field begin/end calls. }}
{{#let export partial container_struct_type |type| captures |types|}}
{{#pragma ignore-newlines}}
{{#if type.map?}}{{#partial types.protocol_type type=type.true_type.key_type}}, {{#partial types.protocol_type type=type.true_type.val_type}}
{{#else if (or type.list? type.set?)}}{{#partial types.protocol_type type=type.true_type.elem_type}}
  {{/if type.map?}}
{{/let partial}}

{{! The protocol struct/container field type name (e.g. Map, List, Struct). }}
{{#let export partial struct_field_type |type|}}
{{#pragma ignore-newlines}}
{{#if type.void?}}Void
{{#else if type.string?}}String
{{#else if type.binary?}}Binary
{{#else if type.bool?}}Bool
{{#else if type.byte?}}Byte
{{#else if type.i16?}}I16
{{#else if type.i32?}}I32
{{#else if type.i64?}}I64
{{#else if type.double?}}Double
{{#else if type.float?}}Float
{{#else if type.set?}}Set
{{#else if type.map?}}Map
{{#else if type.list?}}List
{{/if type.void?}}
{{/let partial}}

{{! Opening conditional for field serialization (union case/terse/optional guard). }}
{{#let export partial if_should_write |field struct| captures |fields|}}
  {{#if struct.union?}}
  case {{struct.cpp_underlying_name}}::Type::{{field.cpp_name}}:
  {
  {{#else if field.optional?}}
  if ({{#partial fields.optional_has_value field=field struct=struct}}) {
  {{#else if field.deprecated_terse_writes?}}
  if ({{#if field.lazy?}}!(__fbthrift_isDeserialized_.{{field.cpp_name}} & ::apache::thrift::detail::LazyDeserializationState::DESERIALIZED) ||
      {{/if field.lazy?}}{{#partial fields.deprecated_terse_has_value field=field struct=struct}}) {
  {{#else if field.terse?}}
  if ({{#if field.lazy?}}!(__fbthrift_isDeserialized_.{{field.cpp_name}} & ::apache::thrift::detail::LazyDeserializationState::DESERIALIZED) ||
      {{/if field.lazy?}}!({{#partial fields.terse_has_no_value field=field struct=struct}})) {
  {{#else}}
  {
  {{/if struct.union?}}
{{/let partial}}

{{! Closing brace/break for field serialization. }}
{{#let export partial if_should_write_end |struct|}}
  {{#if struct.union?}}
    break;
  }
  {{#else}}
  }
  {{/if struct.union?}}
{{/let partial}}
