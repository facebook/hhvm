{{#import "common/types" as types}}

{{!
This is the equivalent of cython_cpp_type, for use as part of an identifier
(like in the name of a Promise class), not as a standalone type.
Uses '_' separators instead of '.' for cbinding paths, and '__' for container
type argument separators.
}}
{{#let export partial cython_cpp_type_ident |type| captures |types|}}
{{#pragma ignore-newlines}}
  {{#if type.customCppType?}}
    {{#if type.iobuf?}}
__iobuf_cIOBuf
    {{#else if type.iobufRef?}}
unique_ptr__iobuf_cIOBuf
    {{#else}}
{{#if type.need_cbinding_path?}}{{type.cbinding_path}}_{{/if}}{{type.cythonCustomType}}
    {{/if type.iobuf?}}
{{#else if type.bool?}}cbool
{{#else if type.void?}}cFollyUnit
{{#else if type.byte?}}cint8_t
{{#else if type.i16?}}cint16_t
{{#else if type.i32?}}cint32_t
{{#else if type.i64?}}cint64_t
{{#else if type.double?}}double
{{#else if type.float?}}float
{{#else if type.string?}}string
{{#else if type.binary?}}binary
  {{#else if (or type.structured? type.enum?)}}
    {{#let ttype = type.true_type}}
{{#if ttype.need_cbinding_path?}}{{ttype.cbinding_path}}_{{/if}}{{!
}}{{#partial types.c_binding node=ttype}}
  {{#else if type.container?}}
    {{#let ttype = type.true_type}}
{{#if (and (not type.defaultTemplate?) type.need_cbinding_path?)}}{{type.cbinding_path}}_{{/if}}
    {{#if type.map?}}
{{type.cythonTemplate}}__{{#partial cython_cpp_type_ident type=ttype.key_type}}_{{#partial cython_cpp_type_ident type=ttype.val_type}}
    {{#else}}
{{type.cythonTemplate}}__{{#partial cython_cpp_type_ident type=ttype.elem_type}}
    {{/if type.map?}}
  {{/if type.customCppType?}}
{{/let partial}}

{{!
This constructs the identifier for a function's return type, suitable for use
in Promise/Stream class names. For non-stream functions, it's just the type ident.
For stream functions, it includes the stream prefix and element type.
}}
{{#let export partial cython_cpp_return_type_ident |function| captures |types cython_cpp_type_ident|}}
{{#pragma ignore-newlines}}
  {{#if (not function.stream?)}}
{{#partial cython_cpp_type_ident type=function.return_type}}
  {{#else}}
    {{#if function.stream_has_first_response?}}
cResponseAndServerStream__{{#partial cython_cpp_type_ident type=function.return_type}}_
    {{#else}}
cServerStream__
    {{/if function.stream_has_first_response?}}
{{#partial cython_cpp_type_ident type=function.stream.elem_type}}
  {{/if (not function.stream?)}}
{{/let partial}}

{{!
Called specifically when setting the result on a promise. It casts the Python
value returned by the coroutine into the appropriate format to be returned
to the client.
}}
{{#let export partial cython_return_value |function| captures |types cython_cpp_type_ident|}}
{{#pragma ignore-newlines}}
  {{#let type = function.return_type}}
  {{#if type.iobuf?}}
{{#if function.stack_arguments?}}deref{{/if}}((<_fbthrift_iobuf.IOBuf>result).c_clone())

  {{#else if type.iobufRef?}}
{{#if (not function.stack_arguments?)}}make_unique[unique_ptr[_fbthrift_iobuf.cIOBuf]]({{/if}}
((<_fbthrift_iobuf.IOBuf>result).c_clone())
{{#if (not function.stack_arguments?)}}){{/if}}

  {{#else if type.flexibleBinary?}}
{{#if function.stack_arguments?}}{{#partial types.cython_cpp_type type=type}}
{{#else}}make_unique[{{#partial types.cython_cpp_type type=type}}]{{/if function.stack_arguments?}}
(cmove(<string>result))

  {{#else if function.stream?}}
    {{#if function.stream_has_first_response?}}
createResponseAndServerStream[
{{#partial types.cython_cpp_type type=function.return_type}},
{{#partial types.cython_cpp_type type=function.stream.elem_type}}](
(<{{#partial types.cython_cpp_type type=function.return_type}}?> {{#partial types.cython_python_to_cpp_item type=function.return_type}}), {{!}}
    {{/if function.stream_has_first_response?}}
cmove(deref((<ServerStream_{{#partial cython_cpp_type_ident type=function.stream.elem_type}}?>result).cStream))
{{#if function.stream_has_first_response?}}){{/if}}

{{#else if type.customBinaryType?}}{{! By design: no output, just avoids a nesting level }}
{{#else if type.bool?}}<cbool> result
{{#else if type.void?}}c_unit
{{#else if type.byte?}}<cint8_t> result
{{#else if type.i16?}}<cint16_t> result
{{#else if type.i32?}}<cint32_t> result
{{#else if type.i64?}}<cint64_t> result
{{#else if type.double?}}<double> result
{{#else if type.float?}}<float> result
{{#else if type.enum?}}<{{#partial types.cython_cpp_type type=type}}><int>result

  {{#else if type.string?}}
{{#if (not function.stack_arguments?)}}make_unique[{{#partial types.cython_cpp_type type=type}}]({{/if}}
<string?> result.encode('UTF-8')
{{#if (not function.stack_arguments?)}}){{/if}}

  {{#else if type.binary?}}
{{#if (not function.stack_arguments?)}}make_unique[{{#partial types.cython_cpp_type type=type}}]({{/if}}
<string?> result
{{#if (not function.stack_arguments?)}}){{/if}}

  {{#else if type.structured?}}
    {{#let ttype = type.true_type}}
{{#if (not function.stack_arguments?)}}make_unique[{{#partial types.cython_cpp_type type=type}}]({{/if}}
    {{#if root_program.inplace_migrate?}}
{{type.capi_converter_path}}.{{ttype.name}}_convert_to_cpp(result._to_python())
    {{#else}}
deref((<{{#partial types.cython_python_type type=type}}?> result).{{#partial types.cpp_obj}})
    {{/if root_program.inplace_migrate?}}
{{#if (not function.stack_arguments?)}}){{/if}}

    {{#else if type.container?}}
{{#if (not function.stack_arguments?)}}make_unique[{{#partial types.cython_cpp_type type=type}}]({{/if}}
{{#partial types.container_to_cpp type=type}}(result)
{{#if (not function.stack_arguments?)}}){{/if}}

  {{/if type.iobuf?}}
{{/let partial}}
