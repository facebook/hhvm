{{!
Shared container __make_instance .pyx implementation
between types.pyx (default mode) and converters.pyx (auto-migrate mode)
}}
{{#let export partial make_instance |type| captures |pep484 cython_cpp_type cython_python_type cython_python_to_cpp_item python_is_instance_type python_type cython_python_to_cpp_key|}}
    cdef {{#partial cython_cpp_type type=type}} c_inst
  {{#if type.set?}}
    cdef {{#partial cython_cpp_type type=type.true_type.elem_type}} c_item
  {{#else if type.map?}}
    cdef {{#partial cython_cpp_type type=type.true_type.key_type}} c_key
  {{/if type.set?}}
    if items is None:
        return cmove(c_inst)
  {{#if (not type.map?)}}
    {{#if type.containerOfString?}}
    if isinstance(items, str):
        raise TypeError("If you really want to pass a string into a {{#partial pep484.type_name type=type}} field, explicitly convert it first.")
    {{/if type.containerOfString?}}
    for item in items:
  {{/if (not type.map?)}}
  {{#if type.list?}}
    {{#let elem_type=type.true_type.elem_type}}
    {{#if elem_type.container?}}
        if item is None:
            raise TypeError("None is not of the type {{#partial pep484.type_name type=elem_type}}")
        if not isinstance(item, {{#partial python_type type=elem_type}}):
            item = {{#partial python_type type=elem_type}}(item)
    {{#else}}
        if not isinstance(item, {{#partial python_is_instance_type type=elem_type}}):
            raise TypeError(f"{item!r} is not of type {{#partial pep484.type_name type=elem_type}}")
      {{#if elem_type.integer?}}
        {{! inject cython int overflow checks }}
        item = <{{#partial cython_python_type type=elem_type}}> item
      {{/if elem_type.integer?}}
    {{/if elem_type.container?}}
        c_inst.push_back({{#partial cython_python_to_cpp_item type=elem_type}})
  {{#else if type.set?}}
    {{!
      TODO(hchok): This is very similar to the list branch.W e can likely consolidate a bunch of this,
      but it's preserved as-is while converting the template to a partial, so we can rely on codegen
      output parity as a correctness signal. The consolidation will be split into its own change,
      alongside corresponding fixture changes.
    }}
    {{#let elem_type=type.true_type.elem_type}}
    {{#if elem_type.container?}}
        if item is None:
            raise TypeError("None is not of type {{#partial pep484.type_name type=elem_type}}")
        if not isinstance(item, {{#partial python_type type=elem_type}}):
            item = {{#partial python_type type=elem_type}}(item)
    {{#else}}
        if not isinstance(item, {{#partial python_is_instance_type type=elem_type}}):
            raise TypeError(f"{item!r} is not of type {{#partial pep484.type_name type=elem_type}}")
      {{#if elem_type.integer?}}
        {{! inject cython int overflow checks }}
        c_item = <{{#partial cython_python_type type=elem_type}}> item
      {{/if elem_type.integer?}}
    {{/if elem_type.container?}}
    {{#if (not elem_type.integer?)}}
        c_item = {{#partial cython_python_to_cpp_item type=elem_type}}
    {{/if (not elem_type.integer?)}}
        c_inst.insert(c_item)
  {{#else if type.map?}}
    for key, item in items.items():
    {{#let key_type=type.true_type.key_type}}
    {{#if key_type.container?}}
        if key is None:
            raise TypeError("None is not of type {{#partial pep484.type_name type=key_type}}")
        if not isinstance(key, {{#partial python_type type=key_type}}):
            key = {{#partial python_type type=key_type}}(key)
    {{#else}}
        if not isinstance(key, {{#partial python_is_instance_type type=key_type}}):
            raise TypeError(f"{key!r} is not of type {{#partial pep484.type_name type=key_type}}")
      {{#if key_type.integer?}}
        {{! inject cython int overflow checks }}
        c_key = <{{#partial cython_python_type type=key_type}}> key
      {{/if key_type.integer?}}
    {{/if key_type.container?}}
    {{#if (not key_type.integer?)}}
        c_key = {{#partial cython_python_to_cpp_key type=key_type}}
    {{/if (not key_type.integer?)}}
    {{#let val_type=type.true_type.val_type}}
    {{#if val_type.container?}}
        if item is None:
            raise TypeError("None is not of type {{#partial pep484.type_name type=val_type}}")
        if not isinstance(item, {{#partial python_type type=val_type}}):
            item = {{#partial python_type type=val_type}}(item)
    {{#else}}
        if not isinstance(item, {{#partial python_is_instance_type type=val_type}}):
            raise TypeError(f"{item!r} is not of type {{#partial pep484.type_name type=val_type}}")
      {{#if val_type.integer?}}
        {{! inject cython int overflow checks }}
        item = <{{#partial cython_python_type type=val_type}}> item
      {{/if val_type.integer?}}
    {{/if val_type.container?}}

        c_inst[c_key] = {{#partial cython_python_to_cpp_item type=val_type}}
  {{/if type.list?}}
    return cmove(c_inst)
{{/let partial}}


