{{#import "common/types" as types}}

{{! Renders a primitive C# const value expression. }}
{{#let partial primitive_const_value |value| captures |types|}}
{{#pragma ignore-newlines}}
  {{#if value.type.bool?}}
{{#if value.nonzero?}}true{{#else}}false{{/if}}
  {{#else if value.type.byte?}}
(sbyte){{value.integer_value}}
  {{#else if value.type.i16?}}
(short){{value.integer_value}}
  {{#else if value.type.i32?}}
{{value.integer_value}}
  {{#else if value.type.i64?}}
{{value.integer_value}}L
  {{#else if value.type.float?}}
(float){{#if value.double?}}{{value.double_string}}{{#else}}{{value.integer_value}}.0{{/if}}
  {{#else if value.type.double?}}
{{#if value.double?}}{{value.double_string}}{{#else}}{{value.integer_value}}.0{{/if}}
  {{#else if value.type.string?}}
"{{value.string_value}}"
  {{#else if value.type.binary?}}
new byte[] { {{#each (array.enumerate value.byte_array_elements with_first=true) as |i elem first?|}}{{#if (not first?)}} {{/if}}{{elem}},{{/each}} }
  {{#else if value.type.enum?}}
{{#if value.enum_value?}}{{#partial types.csharp_type type=value.type}}.{{value.enum_value.csharp_name}}{{#else}}({{#partial types.csharp_type type=value.type}}){{value.integer_value}}{{/if value.enum_value?}}
  {{/if value.type.bool?}}
{{/let partial}}

{{! Renders a C# const value expression for any Thrift type.
    Handles primitives, enums, lists, sets, maps, and struct literals.

    The following const value properties are provided by the base generator:
      value.type          - the Thrift type of the const value
      value.integer_value - integer literal (for numeric types)
      value.double_value  - double literal (for float/double)
      value.string_value  - string literal
      value.bool_value    - boolean literal
      value.nonzero?      - whether numeric value is non-zero
      value.double?       - whether value is stored as double
      value.enum_value    - enum value reference (if known)
      value.enum_value?   - whether enum_value is available
      value.list_elements - list of values (for list/set)
      value.map_elements  - list of {key, value} pairs (for map)
      value.structured_elements - list of {field, value} pairs (for struct) }}
{{#let export partial csharp_const_value |value| captures |types primitive_const_value|}}
{{#if (or value.type.primitive? value.type.enum?)}}
{{#partial primitive_const_value value=value}}{{!
}}{{#else if value.type.structured?}}
new {{#partial types.csharp_type type=value.type}}()
{
  {{#if (object.notnull? value.map_elements)}}
    {{#each value.map_elements as |entry|}}
  {{entry.key.string_value}} = {{#partial csharp_const_value value=entry.value}},
    {{/each}}
  {{/if (object.notnull? value.map_elements)}}
}{{!
}}{{#else if value.type.map?}}
new {{#partial types.csharp_type type=value.type}}()
{
  {{#if (object.notnull? value.map_elements)}}
    {{#each value.map_elements as |elem|}}
  { {{#partial csharp_const_value value=elem.key}}, {{#partial csharp_const_value value=elem.value}} },
    {{/each}}
  {{/if (object.notnull? value.map_elements)}}
}{{!
}}{{#else if value.type.container?}}{{!
    List or set }}
new {{#partial types.csharp_type type=value.type}}()
{
  {{#if (object.notnull? value.list_elements)}}
    {{#each value.list_elements as |elem|}}
  {{#partial csharp_const_value value=elem}},
    {{/each}}
  {{/if (object.notnull? value.list_elements)}}
}{{!
}}{{/if (or value.type.primitive? value.type.enum?)}}{{!
}}{{/let partial}}
