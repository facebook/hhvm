{{#import "common/types" as types}}
{{#import "common/constants" as constants}}

{{#let export partial struct_ctor |struct| captures |types constants|}}
public {{struct.csharp_name}}()
{
{{#each struct.fields as |field|}}
  {{#if (not field.optional?)}}
    {{#if (object.notnull? field.default_value)}}
    {{field.csharp_property_name}} = {{#partial constants.csharp_const_value value=field.default_value}};
    {{#else if field.type.list?}}
    {{field.csharp_property_name}} = new {{#partial types.csharp_type type=field.type}}();
    {{#else if field.type.set?}}
    {{field.csharp_property_name}} = new {{#partial types.csharp_type type=field.type}}();
    {{#else if field.type.map?}}
    {{field.csharp_property_name}} = new {{#partial types.csharp_type type=field.type}}();
    {{#else if field.type.string?}}
    {{field.csharp_property_name}} = string.Empty;
    {{#else if field.type.binary?}}
    {{field.csharp_property_name}} = Array.Empty<byte>();
    {{#else if field.type.structured?}}
    {{field.csharp_property_name}} = new {{#partial types.csharp_type type=field.type}}();
    {{/if (object.notnull? field.default_value)}}
  {{/if (not field.optional?)}}
{{/each}}
}
{{/let partial}}
