function test_keyset(): void {
  ExampleDsl::makeTree(
    darray[
      "path" => __FILE__,
      "start_line" => 25,
      "end_line" => 25,
      "start_column" => 13,
      "end_column" => 49,
    ],
    darray[
      "splices" => dict[],
      "functions" => vec[],
      "static_methods" => vec[],
      "variables" => vec[],
      "lexically_enclosing_tree" => NULL,
    ],
    (
      (ExampleDsl $v) ==> {
        return $v->visitLambda(
          darray[
            "path" => __FILE__,
            "start_line" => 25,
            "end_line" => 25,
            "start_column" => 13,
            "end_column" => 49,
          ],
          vec["$x"],
          vec[
            $v->visitReturn(
              darray[
                "path" => __FILE__,
                "start_line" => 25,
                "end_line" => 25,
                "start_column" => 33,
                "end_column" => 49,
              ],
              $v->visitKeyset(
                darray[
                  "path" => __FILE__,
                  "start_line" => 25,
                  "end_line" => 25,
                  "start_column" => 33,
                  "end_column" => 49,
                ],
                vec[
                  $v->visitLocal(
                    darray[
                      "path" => __FILE__,
                      "start_line" => 25,
                      "end_line" => 25,
                      "start_column" => 40,
                      "end_column" => 42,
                    ],
                    "$x",
                  ),
                  $v->visitInt(
                    darray[
                      "path" => __FILE__,
                      "start_line" => 25,
                      "end_line" => 25,
                      "start_column" => 44,
                      "end_column" => 45,
                    ],
                    1,
                  ),
                  $v->visitInt(
                    darray[
                      "path" => __FILE__,
                      "start_line" => 25,
                      "end_line" => 25,
                      "start_column" => 47,
                      "end_column" => 48,
                    ],
                    2,
                  ),
                ],
              ),
            ),
          ],
        );
      }
    ),
  );
}

