  auto encodedStream = apache::thrift::detail::ap::encode_server_stream<ProtocolOut_, StreamPResultType>(std::move(returnStream), std::move(executor));
  return {serializeResponse("{{#partial rpc.function_name service=interface function=function}}", &prot, ctx, result), std::move(encodedStream)};
        {{#else if function.sink?}}
  {{service_cpp_name}}_{{function.prefixed_name}}_presult::InitialResponsePResultType result;
