# pyre-strict

from enum import Enum

class NumberType(Enum):
    NOT_A_NUMBER: NumberType = ...
    BYTE: NumberType = ...
    I08: NumberType = ...
    I16: NumberType = ...
    I32: NumberType = ...
    I64: NumberType = ...
    FLOAT: NumberType = ...
    DOUBLE: NumberType = ...

class Qualifier(Enum):
    UNQUALIFIED: Qualifier = ...
    REQUIRED: Qualifier = ...
    OPTIONAL: Qualifier = ...

class StructType(Enum):
    STRUCT: StructType = ...
    UNION: StructType = ...
    EXCEPTION: StructType = ...
