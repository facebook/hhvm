{{#import "common/types" as types}}
{{#import "common/defaults" as defaults}}
{{#import "common/constants" as constants}}
{{#import "codec/write" as wr}}
{{#import "codec/read" as rd}}

{{! A Thrift struct/exception becomes a Swift value type. Hashable is
    synthesized (and refines Equatable, so `==` is available too). Exceptions
    additionally conform to Error. }}
{{#let export partial struct_type |structured| captures |types defaults constants wr rd|}}
/// Auto-generated from {{structured.name}}
public struct {{structured.swift_name}}: ThriftSerializable, Hashable{{#if structured.exception?}}, Error{{/if structured.exception?}} {
{{#each structured.fields as |field|}}
{{#if field.optional?}}
    public var {{field.swift_property_name}}: {{#partial types.swift_type type=field.type}}?
{{#else if (object.notnull? field.default_value)}}
    public var {{field.swift_property_name}}: {{#partial types.swift_type type=field.type}} = {{#partial constants.swift_const_value value=field.default_value}}
{{#else}}
    public var {{field.swift_property_name}}: {{#partial types.swift_type type=field.type}} = {{#partial defaults.swift_default_value type=field.type}}
{{/if field.optional?}}
{{/each}}

    public init() {}

    /// Resets every field to its intrinsic (standard) default, per the Object
    /// Model `clear()` (guide 2.1.22). Unlike `init()`, this ignores custom
    /// IDL defaults: optional fields become nil, others their type's zero value.
    public mutating func clear() {
{{#each structured.fields as |field|}}
{{#if field.optional?}}
        self.{{field.swift_property_name}} = nil
{{#else}}
        self.{{field.swift_property_name}} = {{#partial defaults.swift_default_value type=field.type}}
{{/if field.optional?}}
{{/each}}
    }

    {{#partial wr.struct_write structured=structured}}

    {{#partial rd.struct_read structured=structured}}
}
{{/let partial}}
