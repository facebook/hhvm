      FinalResponsePResultType>({{#if function.sink_has_first_response?}}std::move(_return.sinkConsumer),{{#else}}std::move(_return), {{/if}}std::move(executor));

  return {serializeResponse("{{#partial rpc.function_name service=interface function=function}}", &prot, ctx, result), std::move(sinkConsumerImpl)};
        {{#else}}
