{{#let export partial param_type |type|}}
{{#pragma ignore-newlines}}
{{#if type.resolves_to_complex_return?}}const {{type.cpp_type}}&{{#else}}{{type.cpp_type}}{{/if}}
{{/let partial}}

{{#let export partial return_type_no_handle |function|}}
{{#pragma ignore-newlines}}
  {{#if function.bidirectional_stream?}}
    {{#if function.sink_has_first_response?}}
apache::thrift::ResponseAndBidirectionalStream<{{function.return_type.cpp_type}}, {{function.sink.elem_type.cpp_type}}, {{function.stream.elem_type.cpp_type}}>
    {{#else}}
apache::thrift::BidirectionalStream<{{function.sink.elem_type.cpp_type}}, {{function.stream.elem_type.cpp_type}}>
    {{/if function.sink_has_first_response?}}
  {{#else if function.stream?}}
    {{#if function.stream_has_first_response?}}
apache::thrift::ResponseAndClientBufferedStream<{{function.return_type.cpp_type}},{{function.stream.elem_type.cpp_type}}>
    {{#else}}
apache::thrift::ClientBufferedStream<{{function.stream.elem_type.cpp_type}}>
    {{/if function.stream_has_first_response?}}
  {{#else if function.sink?}}
    {{#if function.sink_has_first_response?}}
apache::thrift::ResponseAndClientSink<{{function.return_type.cpp_type}}, {{function.sink.elem_type.cpp_type}}, {{function.sink.final_response_type.cpp_type}}>
    {{#else}}
apache::thrift::ClientSink<{{function.sink.elem_type.cpp_type}}, {{function.sink.final_response_type.cpp_type}}>
    {{/if function.sink_has_first_response?}}
  {{#else}}
{{function.cpp_return_type}}
  {{/if function.bidirectional_stream?}}
{{/let partial}}

{{#let export partial return_type_no_handle_lift_unit |function| captures |return_type_no_handle|}}
{{#pragma ignore-newlines}}
{{#if (and function.return_type.void? (not function.sink_or_stream?))}}folly::Unit{{#else}}{{#partial return_type_no_handle function=function}}{{/if}}
{{/let partial}}

{{#let export partial return_type |function service| captures |return_type_no_handle|}}
{{#pragma ignore-newlines}}
  {{#if (not function.creates_interaction?)}}
{{#partial return_type_no_handle function=function}}
  {{#else if (or function.stream? (and (not function.sink?) function.initial_response?))}}
std::pair<apache::thrift::Client<{{service.qualified_name}}>::{{function.created_interaction.cpp_name}}, {{#partial return_type_no_handle function=function}}>
  {{#else}}
apache::thrift::Client<{{service.qualified_name}}>::{{function.created_interaction.cpp_name}}
  {{/if (not function.creates_interaction?)}}
{{/let partial}}

{{#let export partial return_type_lift_unit |function service| captures |return_type|}}
{{#pragma ignore-newlines}}
{{#if function.void?}}folly::Unit{{#else}}{{#partial return_type function=function service=service}}{{/if}}
{{/let partial}}

{{#let export partial function_param_list |function| captures |param_type|}}
{{#pragma ignore-newlines}}
  {{#each (array.enumerate function.params.fields with_first=true) as |i field is_first?|}}
{{#if (not is_first?)}}, {{/if}}{{#partial param_type type=field.type}} p_{{field.cpp_name}}
  {{/each}}
{{/let partial}}

{{#let export partial client_class_name |service parent_service|}}
{{#pragma ignore-newlines}}
apache::thrift::Client
{{#if service.interaction?}}<{{parent_service.qualified_name}}>::{{service.name}}{{#else}}<{{service.qualified_name}}>{{/if}}
{{/let partial}}

{{#let export partial callback_type |function|}}
{{#pragma ignore-newlines}}
apache::thrift::
{{#if function.bidirectional_stream?}}BiDiClientCallback*
{{#else if function.sink?}}SinkClientCallback*
{{#else if function.stream?}}StreamClientCallback*
{{#else}}RequestClientCallback::Ptr
{{/if function.bidirectional_stream?}}
{{/let partial}}
