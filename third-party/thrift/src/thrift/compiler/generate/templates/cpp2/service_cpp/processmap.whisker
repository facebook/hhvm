}}const {{service.cpp_name}}AsyncProcessor::ProcessMap& {{service.cpp_name}}AsyncProcessor::getOwnProcessMap() {
  return kOwnProcessMap_;
}

  {{#if (array.empty? service.functions)}}
const {{service.cpp_name}}AsyncProcessor::ProcessMap {{service.cpp_name}}AsyncProcessor::kOwnProcessMap_ {};
  {{#else}}
const {{service.cpp_name}}AsyncProcessor::ProcessMap {{service.cpp_name}}AsyncProcessor::kOwnProcessMap_ {
    {{#each service.functions as |function|}}
      {{#if (not function.starts_interaction?)}}
  {"{{function.name}}",
    {&{{service.cpp_name}}AsyncProcessor::setUpAndProcess_{{function.cpp_name}}<apache::thrift::CompactProtocolReader, apache::thrift::CompactProtocolWriter>,
     &{{service.cpp_name}}AsyncProcessor::setUpAndProcess_{{function.cpp_name}}<apache::thrift::BinaryProtocolReader, apache::thrift::BinaryProtocolWriter>,
     &{{service.cpp_name}}AsyncProcessor::executeRequest_{{function.cpp_name}}<apache::thrift::CompactProtocolReader, apache::thrift::CompactProtocolWriter>,
     &{{service.cpp_name}}AsyncProcessor::executeRequest_{{function.cpp_name}}<apache::thrift::BinaryProtocolReader, apache::thrift::BinaryProtocolWriter>}},
      {{/if (not function.starts_interaction?)}}
    {{/each}}
    {{#each service.interactions as |interaction|}}
      {{#each interaction.functions as |function|}}
  {"{{interaction.name}}.{{function.name}}",
    {&{{service.cpp_name}}AsyncProcessor::setUpAndProcess_{{interaction.name}}_{{function.cpp_name}}<apache::thrift::CompactProtocolReader, apache::thrift::CompactProtocolWriter>,
     &{{service.cpp_name}}AsyncProcessor::setUpAndProcess_{{interaction.name}}_{{function.cpp_name}}<apache::thrift::BinaryProtocolReader, apache::thrift::BinaryProtocolWriter>,
     &{{service.cpp_name}}AsyncProcessor::executeRequest_{{interaction.name}}_{{function.cpp_name}}<apache::thrift::CompactProtocolReader, apache::thrift::CompactProtocolWriter>,
     &{{service.cpp_name}}AsyncProcessor::executeRequest_{{interaction.name}}_{{function.cpp_name}}<apache::thrift::BinaryProtocolReader, apache::thrift::BinaryProtocolWriter>}},
      {{/each}}
    {{/each}}
};
  {{/if (array.empty? service.functions)}}

apache::thrift::ServiceRequestInfoMap const& {{service.cpp_name}}ServiceInfoHolder::requestInfoMap() const {
  static folly::Indestructible<apache::thrift::ServiceRequestInfoMap> requestInfoMap{staticRequestInfoMap()};
  return *requestInfoMap;
}

apache::thrift::ServiceRequestInfoMap {{service.cpp_name}}ServiceInfoHolder::staticRequestInfoMap() {
  apache::thrift::ServiceRequestInfoMap requestInfoMap = {
    {{#each service.functions as |function|}}
      {{#if (not function.starts_interaction?)}}
  {"{{function.name}}",
    { {{#if function.event_based?}}true{{#else}}false{{/if}},
     {{#partial rpc.function_kind function=function}},
     "{{service.name}}.{{#partial rpc.function_name service=service function=function}}",
     std::nullopt,
     apache::thrift::concurrency::{{function.priority}},
     {{#if function.creates_interaction?}}"{{function.created_interaction.cpp_name}}"{{#else}}std::nullopt{{/if}},
     ::apache::thrift::detail::getFunctionNode<{{service.qualified_name}}>("{{function.name}}")}},
      {{/if (not function.starts_interaction?)}}
    {{/each}}
    {{#each service.interactions as |interaction|}}
      {{#each interaction.functions as |function|}}
  {"{{interaction.name}}.{{function.name}}",
    { {{#if function.event_based?}}true{{#else}}false{{/if}},
     {{#partial rpc.function_kind function=function}},
     "{{service.name}}.{{#partial rpc.function_name service=interaction function=function}}",
     "{{interaction.name}}",
     apache::thrift::concurrency::{{function.priority}},
     std::nullopt,
     ::apache::thrift::detail::getInteractionFunctionNode<{{service.qualified_name}}>("{{interaction.name}}", "{{function.name}}")}},
      {{/each}}
    {{/each}}
  };
  {{#if (object.notnull? service.extends)}}
  apache::thrift::ServiceRequestInfoMap parentMap = ::{{service.extends.cpp_qualified_namespace}}::{{service.extends.cpp_name}}ServiceInfoHolder::staticRequestInfoMap();
  requestInfoMap.insert(std::begin(parentMap), std::end(parentMap));
  {{/if (object.notnull? service.extends)}}

  return requestInfoMap;
}
