cdef api void call_cy_{{service.name}}_{{function.name}}(
    object self,
    Cpp2RequestContext* ctx,
    cFollyPromise[{{#partial services.cython_return_type_cpp_type function=function}}]{{!
    }} cPromise{{#each function.params.fields as |param|}},
    {{#if function.stack_arguments?}}{{#partial types.cython_cpp_type type=param.type}}{{#else}}{{#partial cython_field_type param=param}}{{/if}} {{param.py_name}}{{/each}}
) noexcept:{{! Gets called from a python Executor }}
    cdef {{#partial services.promise_name function=function}} __promise = {{#partial services.promise_name function=function}}._fbthrift_create(cmove(cPromise))
      {{#each function.params.fields as |param|}}
    arg_{{param.py_name}} = {{#if function.stack_arguments?}}{{#partial cython_cpp_value_to_python param=param}}{{#else}}{{#partial cython_cpp_to_python param=param}}{{/if}}
      {{/each}}
    __context = RequestContext._fbthrift_create(ctx)
    __prev_context_token = __THRIFT_REQUEST_CONTEXT.set(__context)
    try:
      asyncio.get_event_loop().create_task(
          {{service.name}}_{{function.name}}_coro(
              self,
              __promise{{#each function.params.fields as |param|}},
              arg_{{param.py_name}}{{/each}}
          )
      )
    finally:
      __THRIFT_REQUEST_CONTEXT.reset(__prev_context_token)
    {{/each}}
