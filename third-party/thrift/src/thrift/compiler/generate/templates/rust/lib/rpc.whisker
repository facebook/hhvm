{{#import "lib/types" as types}}

{{!
  Renders the inner type name for a function argument.
  - Strings become ::std::primitive::str (for &str when borrowed)
  - Lists become [ElemType] (for &[ElemType] when borrowed)
  - Everything else: full type name
}}
{{#let export partial arg_inner |field| captures |types|}}
{{#pragma ignore-newlines}}
{{#if field.type.string?}}::std::primitive::str
{{#else if field.type.list?}}[{{#partial types.type_name type=field.type.true_type.elem_type}}]
{{#else}}{{#partial types.type_name type=field.type}}
{{/if field.type.string?}}
{{/let partial}}


{{! Renders a function argument type with & for non-primitives. }}
{{#let export partial arg |field| captures |arg_inner|}}
{{#pragma ignore-newlines}}
{{#if (not field.primitive?)}}&{{/if}}{{#partial arg_inner field=field}}
{{/let partial}}


{{! Renders a function argument type with &'a for non-primitives. }}
{{#let export partial arg_life |field| captures |arg_inner|}}
{{#pragma ignore-newlines}}
{{#if (not field.primitive?)}}&'a {{/if}}{{#partial arg_inner field=field}}
{{/let partial}}


{{!
  ====
  If we ever add a type here which may not have a Send or Sync impl, the
  unsafe impls in structimpl.whisker need to be revisited.
  ====

  Renders the inner return value type for client-side RPCs.
  Handles bidirectional stream, stream, sink, and regular RPCs.
}}
{{#let export partial return_type |function service| captures |types|}}
{{#pragma ignore-newlines}}
  {{! Sink result emits new lines, so we use a nested partial to allow usage of `#pragma ignore-newlines` for the rest }}
  {{#let partial sink_result captures |types function service|}}
::fbthrift::SinkResult<
    {{#if function.sink_has_first_response?}}{{#partial types.type_name type=function.return_type}}{{#else}}(){{/if}},
    {{#partial types.type_name type=function.sink.elem_type}},
    {{root_program.crate}}::errors::{{service.snake}}::{{function.upcamel}}SinkError,
    {{#partial types.type_name type=function.sink.final_response_type}},
    {{root_program.crate}}::errors::{{service.snake}}::{{function.upcamel}}SinkFinalError,
>{{!
}}{{/let partial}}

  {{#if function.bidirectional_stream?}}
(::futures::stream::BoxStream<'static, ::std::result::Result<
{{#partial types.type_name type=function.stream.elem_type}}, {{!}}
{{root_program.crate}}::errors::{{service.snake}}::{{function.upcamel}}StreamError
>>, Box<dyn ::std::ops::FnOnce(::futures::stream::BoxStream<'static, ::std::result::Result<{{#partial types.type_name type=function.sink.elem_type}}, {{!}}
{{root_program.crate}}::errors::{{service.snake}}::{{function.upcamel}}SinkError>>) -> ::futures::future::BoxFuture<'static, ::std::result::Result<(), {{!}}
{{root_program.crate}}::errors::{{service.snake}}::{{function.upcamel}}SinkError>> + ::std::marker::Send>)

  {{#else if function.stream?}}
{{#if function.stream_has_first_response?}}({{#partial types.type_name type=function.return_type}}, {{/if}}
::futures::stream::BoxStream<'static, ::std::result::Result<{{#partial types.type_name type=function.stream.elem_type}}, {{!}}
{{root_program.crate}}::errors::{{service.snake}}::{{function.upcamel}}StreamError>>
{{#if function.stream_has_first_response?}}){{/if}}

{{#else if function.sink?}}{{#partial sink_result}}
{{#else}}{{#partial types.type_name type=function.return_type}}
{{/if function.bidirectional_stream?}}
{{/let partial}}


{{! Renders the full client-side return type: BoxFuture<'static, Result<Ok, Error>>. }}
{{#let export partial client_return_type |function service| captures |return_type|}}
{{#pragma ignore-newlines}}
::futures::future::BoxFuture<'static, ::std::result::Result<
  {{#if (not function.creates_interaction?)}}
{{#partial return_type function=function service=service}}
  {{#else if (or function.sink_or_stream? (not function.return_type.void?))}}
({{root_program.crate}}::client::{{function.interaction_name}}Client, {{#partial return_type function=function service=service}})
  {{#else}}
{{root_program.crate}}::client::{{function.interaction_name}}Client
  {{/if (not function.creates_interaction?)}}
, {{root_program.crate}}::errors::{{service.snake}}::{{function.upcamel}}Error
>>
{{/let partial}}


{{!
  Renders the inner Ok type for server-side return types.
  Uses server-side exception types (StreamExn, SinkExn) instead of client-side errors.
}}
{{#let export partial server_ok_type |function service| captures |types return_type|}}
{{#if function.bidirectional_stream?}}{{#if function.sink_has_first_response?}}(
    {{#partial types.type_name type=function.return_type}},
    ::futures::stream::BoxStream<'static, ::std::result::Result<{{#partial types.type_name type=function.stream.elem_type}}, {{root_program.crate}}::services::{{service.snake}}::{{function.upcamel}}StreamExn>>,
    ::std::boxed::Box<dyn ::std::ops::FnOnce(
        ::futures::stream::BoxStream<'static, ::std::result::Result<{{#partial types.type_name type=function.sink.elem_type}}, {{root_program.crate}}::services::{{service.snake}}::{{function.upcamel}}SinkExn>>
    ) -> ::futures::future::BoxFuture<'static, ()> + Send>
){{#else}}(
    ::futures::stream::BoxStream<'static, ::std::result::Result<{{#partial types.type_name type=function.stream.elem_type}}, {{root_program.crate}}::services::{{service.snake}}::{{function.upcamel}}StreamExn>>,
    ::std::boxed::Box<dyn ::std::ops::FnOnce(
        ::futures::stream::BoxStream<'static, ::std::result::Result<{{#partial types.type_name type=function.sink.elem_type}}, {{root_program.crate}}::services::{{service.snake}}::{{function.upcamel}}SinkExn>>
    ) -> ::futures::future::BoxFuture<'static, ()> + Send>
){{/if function.sink_has_first_response?}}{{!
}}{{#else if function.stream?}}
{{#if function.stream_has_first_response?}}
(
    {{#partial types.type_name type=function.return_type}},
{{/if function.stream_has_first_response?}}
    ::futures::stream::BoxStream<'static, ::std::result::Result<{{#partial types.type_name type=function.stream.elem_type}}, {{root_program.crate}}::services::{{service.snake}}::{{function.upcamel}}StreamExn>>
{{#if function.stream_has_first_response?}}
)
{{/if function.stream_has_first_response?}}{{!
}}{{#else if function.sink?}}{{root_program.crate}}::services::{{service.snake}}::{{function.upcamel}}SinkResult{{!
}}{{#else}}{{#partial return_type function=function service=service}}{{/if function.bidirectional_stream?}}{{!
}}{{/let partial}}


{{! Renders the full server-side return type: Result<Ok, Exn>. }}
{{#let export partial server_return_type |function service| captures |server_ok_type|}}
{{#pragma ignore-newlines}}
::std::result::Result<
  {{#if (not function.creates_interaction?)}}
{{#partial server_ok_type function=function service=service}}
  {{#else if (and (not function.sink_or_stream?) function.return_type.void?)}}
::std::boxed::Box<dyn {{function.interaction_name}}>
  {{#else}}
(::std::boxed::Box<dyn {{function.interaction_name}}>, {{#partial server_ok_type function=function service=service}})
  {{/if (not function.creates_interaction?)}}
, {{root_program.crate}}::services::{{service.snake}}::{{function.upcamel}}Exn
>
{{/let partial}}


{{! Renders the supertrait bound for a service that extends another. }}
{{#let export partial super |service|}}
{{#pragma ignore-newlines}}
  {{#let parent = service.extends}}
  {{#if (object.notnull? parent)}}
{{parent.server_package}}::{{parent.rust_name}}{{#if parent.requestContext?}}<RequestContext = R>{{/if}}
  {{/if (object.notnull? parent)}}
{{/let partial}}
