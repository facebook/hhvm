  return future_{{function.cpp_name}}(rpcOptions{{function_comma}}{{#partial rpc.param_list function=function}});
}

folly::Future<{{#partial client.return_type_lift_unit function=function service=interface}}> {{#partial client.client_class_name service=interface parent_service=parent_service}}::future_{{function.cpp_name}}(apache::thrift::RpcOptions& rpcOptions{{function_comma}}{{#partial client.function_param_list function=function}}) {
      {{#if function.oneway?}}
  using CallbackType = apache::thrift::OneWayFutureCallback;
      {{#else}}
  using CallbackType = apache::thrift::FutureCallback<{{#partial client.return_type_lift_unit function=function service=interface}}>;
      {{/if function.oneway?}}
  return fbthrift_semifuture_{{function.cpp_name}}<CallbackType>(rpcOptions{{function_comma}}{{#partial rpc.param_list function=function}}).toUnsafeFuture();
}

  {{/if (and (not interface.reduced_client?) (not function.creates_interaction?) (not function.stream?))}}
folly::SemiFuture<{{#partial client.return_type_lift_unit function=function service=interface}}> {{#partial client.client_class_name service=interface parent_service=parent_service}}::semifuture_{{function.cpp_name}}({{#partial client.function_param_list function=function}}) {
  ::apache::thrift::RpcOptions rpcOptions;
