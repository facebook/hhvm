{{#import "common/types" as types}}
{{#import "common/ttype" as ttype}}
{{#import "common/write_expr" as write}}
{{#import "common/read_expr" as read}}

{{#let partial union_write |structured| captures |ttype types write|}}
public void __fbthrift_write(IThriftProtocolWriter writer)
{
    switch (_type)
    {
{{#each structured.fields as |field|}}
        case Type.{{field.csharp_property_name}}:
                writer.WriteFieldBegin({{#partial ttype.csharp_ttype_name type=field.type}}, {{field.id}});
{{#if field.type.structured?}}
                writer.WriteStruct((IThriftSerializable)_value!);
{{#else if field.type.enum?}}
                writer.WriteI32((int)({{#partial types.csharp_type type=field.type}})_value!);
{{#else if field.type.list?}}
                {
                    var _list = ({{#partial types.csharp_type type=field.type}})_value!;
                    writer.WriteListBegin({{#partial ttype.csharp_ttype_name type=field.type.true_type.elem_type}}, _list.Count);
                    foreach (var _elem in _list)
                    {
                        {{#partial write.csharp_write_expr type=field.type.true_type.elem_type value="_elem"}};
                    }
                }
{{#else if field.type.set?}}
                {
                    var _set = ({{#partial types.csharp_type type=field.type}})_value!;
                    writer.WriteSetBegin({{#partial ttype.csharp_ttype_name type=field.type.true_type.elem_type}}, _set.Count);
                    foreach (var _elem in _set)
                    {
                        {{#partial write.csharp_write_expr type=field.type.true_type.elem_type value="_elem"}};
                    }
                }
{{#else if field.type.map?}}
                {
                    var _map = ({{#partial types.csharp_type type=field.type}})_value!;
                    writer.WriteMapBegin({{#partial ttype.csharp_ttype_name type=field.type.true_type.key_type}}, {{#partial ttype.csharp_ttype_name type=field.type.true_type.val_type}}, _map.Count);
                    foreach (var _entry in _map)
                    {
                        {{#partial write.csharp_write_expr type=field.type.true_type.key_type value="_entry.Key"}};
                        {{#partial write.csharp_write_expr type=field.type.true_type.val_type value="_entry.Value"}};
                    }
                }
{{#else}}
                writer.WriteValue(({{#partial types.csharp_type type=field.type}})_value!);
{{/if field.type.structured?}}
            break;
{{/each}}
    }
    writer.WriteFieldStop();
}
{{/let partial}}

{{#let partial union_read |structured| captures |ttype read|}}
public void __fbthrift_read(IThriftProtocolReader reader)
{
    __fbthrift_clear();
    bool _fieldSeen = false;
    while (true)
    {
        var (fieldType, fieldId) = reader.ReadFieldBegin();
        if (fieldType == ThriftWireType.Stop)
        {
            break;
        }

        if (_fieldSeen)
        {
            throw new ThriftProtocolException("Union cannot have multiple fields set");
        }
        _fieldSeen = true;

        switch (fieldId)
        {
{{#each structured.fields as |field|}}
            case {{field.id}}: // {{field.name}}
                if (fieldType == {{#partial ttype.csharp_ttype_name type=field.type}})
                {
                    _type = Type.{{field.csharp_property_name}};
                    _value = {{#partial read.csharp_read_expr type=field.type}};
                }
                else
                {
                    reader.Skip(fieldType);
                }
                break;
{{/each}}
            default:
                reader.Skip(fieldType);
                break;
        }
    }
}
{{/let partial}}

{{#let export partial union_type |structured| captures |types union_write union_read|}}
    /// <summary>
    /// Auto-generated union from {{structured.name}}
    /// </summary>
    public class {{structured.csharp_name}} : IThriftSerializable
    {
{{#if (not (string.empty? structured.uri))}}
        /// <summary>The Thrift URI for this type, used for type registration.</summary>
        public static readonly string __fbthrift_uri = "{{structured.uri}}";
{{/if (not (string.empty? structured.uri))}}
        /// <summary>
        /// Enum indicating which field is currently set in this union
        /// </summary>
        public enum Type
        {
            Empty = 0,
{{#each structured.fields as |field|}}
            {{field.csharp_property_name}} = {{field.id}},
{{/each}}
        }

        private Type _type = Type.Empty;
        private object? _value;

        /// <summary>
        /// Gets the type of the currently set field
        /// </summary>
        public Type GetUnionType() => _type;

        /// <summary>
        /// Returns true if this union has no value set
        /// </summary>
        public bool __fbthrift_is_empty() => _type == Type.Empty;

        /// <summary>
        /// Clears the union value
        /// </summary>
        public void __fbthrift_clear()
        {
            _type = Type.Empty;
            _value = null;
        }

{{#each structured.fields as |field|}}
        /// <summary>
        /// Gets or sets the {{field.name}} field.
        /// Setting this field clears any previously set field.
        /// Returns null if a different field is currently set.
        /// </summary>
        public {{#partial types.csharp_type type=field.type}}? {{field.csharp_property_name}}
        {
            get => _type == Type.{{field.csharp_property_name}} ? ({{#partial types.csharp_type type=field.type}})_value! : null;
            set
            {
                ThriftNullGuard.ThrowIfNullUnion(value, "{{field.name}}");
                _type = Type.{{field.csharp_property_name}};
                _value = value;
            }
        }

{{/each}}
        {{#partial union_write structured=structured}}

        {{#partial union_read structured=structured}}

        public override bool Equals(object? obj)
        {
            if (obj is not {{structured.csharp_name}} other)
            {
                return false;
            }
            if (_type != other._type)
            {
                return false;
            }
            return Equals(_value, other._value);
        }

        public override int GetHashCode()
        {
            return HashCode.Combine(_type, _value);
        }

        public override string ToString()
        {
            return $"{{structured.name}}({_type}={_value})";
        }
    }
{{/let partial}}
