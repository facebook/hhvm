{{! Renders the ThriftWireType enum name for a given Thrift type.
    Used in serialization code to identify wire types. }}
{{#let export partial csharp_ttype_name |type|}}
  {{#pragma ignore-newlines}}
{{#if type.void?}}ThriftWireType.Stop
{{#else if type.bool?}}ThriftWireType.Bool
{{#else if type.byte?}}ThriftWireType.Byte
{{#else if type.i16?}}ThriftWireType.I16
{{#else if type.i32?}}ThriftWireType.I32
{{#else if type.i64?}}ThriftWireType.I64
{{#else if type.float?}}ThriftWireType.Float
{{#else if type.double?}}ThriftWireType.Double
{{#else if type.string?}}ThriftWireType.String
{{#else if type.binary?}}ThriftWireType.String
{{#else if type.list?}}ThriftWireType.List
{{#else if type.set?}}ThriftWireType.Set
{{#else if type.map?}}ThriftWireType.Map
{{#else if type.enum?}}ThriftWireType.I32
{{#else if type.structured?}}ThriftWireType.Struct
{{#else}}ThriftWireType.Stop
{{/if type.void?}}
{{/let partial}}
