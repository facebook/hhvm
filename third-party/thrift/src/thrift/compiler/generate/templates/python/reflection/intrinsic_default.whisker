}}{{!
Renders the zero/default value for an unqualified field without an explicit default.
Context: a t_field (accessed via field.type properties).
Produces a value whose Python type matches the field's .type.
}}{{#pragma ignore-newlines}}
{{#if field.type.bool?}}
  False
{{#else if (or field.type.byte? field.type.i16? field.type.i32? field.type.i64?)}}
  0
{{#else if (or field.type.float? field.type.double?)}}
  0.0
{{#else if field.type.string?}}
  ""
{{#else if field.type.binary?}}
  b""
{{#else}}
  None
{{/if field.type.bool?}}
