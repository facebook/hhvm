class A {
  <<__Sealed(B::class)>>
  public function foo(): void {}
}

class B extends A {
  <<__Override>>
  public function foo(): void {}  // OK: B is named in A::foo's seal list
}

class C extends B {
  <<__Override>>
  public function foo(): void {}  // OK: B::foo is not sealed, so C can override it
}
