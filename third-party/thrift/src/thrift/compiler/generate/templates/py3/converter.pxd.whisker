{{#import "common/types" as types}}
{{> common/auto_generated_py}}

{{#if program.gen_legacy_container_converters?}}
{{> types/cimport_std }}

cimport {{program.module_path}}.cbindings as {{program.module_path_for_alias}}_cbindings
{{#each program.includeNamespaces as |include|}}
  {{#if include.program.has_types?}}
cimport {{include.program.module_path}}.cbindings as {{include.program.module_path_for_alias}}_cbindings
  {{/if include.program.has_types?}}
{{/each}}
{{#else}}
from libcpp.memory cimport shared_ptr
{{/if program.gen_legacy_container_converters?}}

cimport {{program.module_path}}.cbindings as _fbthrift_cbindings


{{#each program.py3_visible_structured_definitions as |struct|}}
cdef shared_ptr[_fbthrift_cbindings.{{#partial types.c_binding node=struct}}] {{struct.name}}_convert_to_cpp(object inst) except*
cdef object {{struct.name}}_from_cpp(const shared_ptr[_fbthrift_cbindings.{{#partial types.c_binding node=struct}}]& c_struct)

{{/each}}
{{#if program.gen_legacy_container_converters?}}
  {{#each program.container_types as |type|}}
cdef {{#partial types.cython_cpp_type type=type}} {{type.flat_name}}__make_instance(object items) except *
  {{/each}}
{{/if program.gen_legacy_container_converters?}}
