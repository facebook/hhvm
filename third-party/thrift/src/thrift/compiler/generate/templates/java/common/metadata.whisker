{{! Builds a Java ThriftType expression for metadata registration.
    Resolves through all typedefs, then maps the true type to
    the corresponding ThriftType factory call. Recurses into containers. }}
{{#let export partial thrift_type_expression |type|}}
  {{#pragma ignore-newlines}}
{{#if type.typedef?}}{{#partial thrift_type_expression type=type.true_type}}
{{#else if type.void?}}ThriftType.fromTPrimitive(ThriftPrimitiveType.THRIFT_VOID_TYPE)
{{#else if type.bool?}}ThriftType.fromTPrimitive(ThriftPrimitiveType.THRIFT_BOOL_TYPE)
{{#else if type.byte?}}ThriftType.fromTPrimitive(ThriftPrimitiveType.THRIFT_BYTE_TYPE)
{{#else if type.i16?}}ThriftType.fromTPrimitive(ThriftPrimitiveType.THRIFT_I16_TYPE)
{{#else if type.i32?}}ThriftType.fromTPrimitive(ThriftPrimitiveType.THRIFT_I32_TYPE)
{{#else if type.i64?}}ThriftType.fromTPrimitive(ThriftPrimitiveType.THRIFT_I64_TYPE)
{{#else if type.float?}}ThriftType.fromTPrimitive(ThriftPrimitiveType.THRIFT_FLOAT_TYPE)
{{#else if type.double?}}ThriftType.fromTPrimitive(ThriftPrimitiveType.THRIFT_DOUBLE_TYPE)
{{#else if type.string?}}ThriftType.fromTPrimitive(ThriftPrimitiveType.THRIFT_STRING_TYPE)
{{#else if type.binary?}}ThriftType.fromTPrimitive(ThriftPrimitiveType.THRIFT_BINARY_TYPE)
  {{#else if type.list?}}
ThriftType.fromTList(new ThriftListType.Builder().setValueType(
{{#partial thrift_type_expression type=type.elem_type}}
).build())
  {{#else if type.set?}}
ThriftType.fromTSet(new ThriftSetType.Builder().setValueType(
{{#partial thrift_type_expression type=type.elem_type}}
).build())
  {{#else if type.map?}}
ThriftType.fromTMap(new ThriftMapType.Builder().setKeyType(
{{#partial thrift_type_expression type=type.key_type}}
).setValueType(
{{#partial thrift_type_expression type=type.val_type}}
).build())
  {{#else if type.enum?}}
ThriftType.fromTEnum(new ThriftEnumType.Builder().setName(
"{{type.program.javaPackage}}.{{type.javaCapitalName}}"
).build())
  {{#else if type.structured?}}
ThriftType.fromTStruct(new ThriftStructType.Builder().setName(
"{{type.program.javaPackage}}.{{type.javaCapitalName}}"
).build())
  {{/if type.typedef?}}
{{/let partial}}

{{! Like thrift_type_expression but resolves through typedefs for containers,
    struct, and enum using type.true_type to access elem_type/key_type/val_type
    and package/name. }}
{{#let export partial thrift_type_expression_metadata |type|}}
  {{#pragma ignore-newlines}}
{{#if type.binary?}}ThriftType.fromTPrimitive(ThriftPrimitiveType.THRIFT_BINARY_TYPE)
{{#else if type.void?}}ThriftType.fromTPrimitive(ThriftPrimitiveType.THRIFT_VOID_TYPE)
{{#else if type.bool?}}ThriftType.fromTPrimitive(ThriftPrimitiveType.THRIFT_BOOL_TYPE)
{{#else if type.byte?}}ThriftType.fromTPrimitive(ThriftPrimitiveType.THRIFT_BYTE_TYPE)
{{#else if type.i16?}}ThriftType.fromTPrimitive(ThriftPrimitiveType.THRIFT_I16_TYPE)
{{#else if type.i32?}}ThriftType.fromTPrimitive(ThriftPrimitiveType.THRIFT_I32_TYPE)
{{#else if type.i64?}}ThriftType.fromTPrimitive(ThriftPrimitiveType.THRIFT_I64_TYPE)
{{#else if type.float?}}ThriftType.fromTPrimitive(ThriftPrimitiveType.THRIFT_FLOAT_TYPE)
{{#else if type.double?}}ThriftType.fromTPrimitive(ThriftPrimitiveType.THRIFT_DOUBLE_TYPE)
{{#else if type.string?}}ThriftType.fromTPrimitive(ThriftPrimitiveType.THRIFT_STRING_TYPE)
{{#else if type.list?}}
ThriftType.fromTList(new ThriftListType.Builder().setValueType(
{{#partial thrift_type_expression_metadata type=type.true_type.elem_type}}
).build())
{{#else if type.set?}}
ThriftType.fromTSet(new ThriftSetType.Builder().setValueType(
{{#partial thrift_type_expression_metadata type=type.true_type.elem_type}}
).build())
{{#else if type.map?}}
ThriftType.fromTMap(new ThriftMapType.Builder().setKeyType(
{{#partial thrift_type_expression_metadata type=type.true_type.key_type}}
).setValueType(
{{#partial thrift_type_expression_metadata type=type.true_type.val_type}}
).build())
{{#else if type.enum?}}
ThriftType.fromTEnum(new ThriftEnumType.Builder().setName(
"{{type.true_type.program.javaPackage}}.{{type.true_type.javaCapitalName}}"
).build())
{{#else if type.structured?}}
ThriftType.fromTStruct(new ThriftStructType.Builder().setName(
"{{type.true_type.program.javaPackage}}.{{type.true_type.javaCapitalName}}"
).build())
{{/if type.binary?}}
{{/let partial}}

{{! Renders a ThriftFunction metadata entry for a given t_function object.
    Uses whisker properties on t_function rather than mstch metaFunction:* properties.
    Exception fields use synthetic names (exception_<id>) matching legacy behavior. }}
{{#let export partial thrift_function |func| captures |thrift_type_expression|}}
    {
      List<ThriftField> args = new ArrayList<>();
      {{#if func.params.fields?}}
      {{#each func.params.fields as |field|}}
      args.add(new ThriftField.Builder()
          .setId({{field.id}})
          .setType({{#partial thrift_type_expression type=field.type}})
          .setName("{{field.name}}")
          .setIsOptional({{#if field.optional?}}true{{#else}}false{{/if field.optional?}})
          .build());
      {{/each}}
      {{/if func.params.fields?}}

      List<ThriftField> exceptions = new ArrayList<>();
      {{#if func.exceptions?}}
      {{#each func.exceptions as |field|}}
      exceptions.add(new ThriftField.Builder()
          .setId({{field.id}})
          .setType({{#partial thrift_type_expression type=field.type}})
          .setName("exception_{{field.id}}")
          .setIsOptional(false)
          .build());
      {{/each}}
      {{/if func.exceptions?}}

      functions.add(new ThriftFunction.Builder()
          .setName("{{func.name}}")
          .setReturnType({{#partial thrift_type_expression type=func.return_type}})
          .setArguments(args)
          .setExceptions(exceptions)
          .setIsOneway({{#if func.oneway?}}true{{#else}}false{{/if func.oneway?}})
          .build());
    }
{{/let partial}}
