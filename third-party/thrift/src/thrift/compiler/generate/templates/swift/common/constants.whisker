{{#import "common/types" as types}}

{{! Renders a primitive/enum Swift const value expression. Consts are emitted
    with an explicit type annotation, so bare integer literals are sufficient
    for byte/i16/i32/i64 and leading-dot syntax is sufficient for enums. }}
{{#let partial primitive_const_value |value| captures |types|}}
{{#pragma ignore-newlines}}
  {{#if value.type.bool?}}
{{#if value.nonzero?}}true{{#else}}false{{/if}}
  {{#else if value.type.byte?}}
{{value.integer_value}}
  {{#else if value.type.i16?}}
{{value.integer_value}}
  {{#else if value.type.i32?}}
{{value.integer_value}}
  {{#else if value.type.i64?}}
{{value.integer_value}}
  {{#else if value.type.float?}}
{{#if value.double?}}{{(float_to_string value.double_value)}}{{#else}}{{value.integer_value}}.0{{/if}}
  {{#else if value.type.double?}}
{{#if value.double?}}{{(float_to_string value.double_value)}}{{#else}}{{value.integer_value}}.0{{/if}}
  {{#else if value.type.string?}}
"{{value.swift_string_value}}"
  {{#else if value.type.binary?}}
Data([{{#each value.byte_array_elements as |elem|}}{{elem}}, {{/each}}])
  {{#else if value.type.enum?}}
{{#if value.enum_value?}}.{{value.enum_value.swift_name}}{{#else}}{{#partial types.swift_type type=value.type}}(rawValue: {{value.integer_value}}){{/if value.enum_value?}}
  {{#else}}
{{! Unreachable for valid Thrift (consts are always a known primitive/enum);
    emit an invalid token that fails Swift compilation loudly if a future type
    is added without a branch here. }}
UNSUPPORTED_SWIFT_CONST /* {{value.type.full_name}} */
  {{/if value.type.bool?}}
{{/let partial}}

{{! Renders a Swift const value expression for any Thrift type. Struct-literal
    consts are emitted as a default-initialized value only (field initializers
    are out of scope for the spike; the test fixtures do not use them). }}
{{#let export partial swift_const_value |value| captures |types primitive_const_value|}}
{{#if (or value.type.primitive? value.type.enum?)}}
{{#partial primitive_const_value value=value}}
{{~ #else if value.type.map? ~}}
{{#if (object.notnull? value.map_elements)}}{{#if (array.empty? value.map_elements)}}[:]{{#else}}[{{#each value.map_elements as |elem|}}{{#partial swift_const_value value=elem.key}}: {{#partial swift_const_value value=elem.value}}, {{/each}}]{{/if (array.empty? value.map_elements)}}{{#else}}[:]{{/if (object.notnull? value.map_elements)}}
{{~ #else if value.type.container? ~}}
[{{#if (object.notnull? value.list_elements)}}{{#each value.list_elements as |elem|}}{{#partial swift_const_value value=elem}}, {{/each}}{{/if (object.notnull? value.list_elements)}}]
{{~ #else if value.type.structured? ~}}
{{#partial types.swift_type type=value.type}}()
{{~ #else ~}}
{{! Unreachable for valid Thrift; fail loudly rather than emitting nothing
    (which would produce `let foo: T = ` with no value). }}
UNSUPPORTED_SWIFT_CONST /* {{value.type.full_name}} */
{{~ /if (or value.type.primitive? value.type.enum?) ~}}
{{/let partial}}
