pub static {{constant.rust_name}}: ::std::sync::LazyLock<
{{#if constant.type.type:has_adapter?}}{{constant.type.type:adapter_qualified}}::AdaptedType{{#else}}{{#partial types.type_name type=constant.type}}{{/if}}
> = ::std::sync::LazyLock::new(|| {{!}}
{{#if constant.type.type:has_adapter?}}{{constant.type.type:adapter_qualified}}::from_thrift({{/if}}
{{#partial constants.const_value value=constant.value}}
{{#if constant.type.type:has_adapter?}}).expect("constant Thrift value should adapt without error"){{/if}}
);
  {{/let partial}}
