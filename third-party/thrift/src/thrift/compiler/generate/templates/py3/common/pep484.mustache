{{!
This is for pep 484 typing

This is useful for typing call patterns since it allows python container types OR
thrift-py3 specific container types.
}}
{{#let export partial type_name |type|}}
{{#pragma ignore-newlines}}
{{#if type.bool?}}bool
{{#else if type.byte?}}int
{{#else if type.i16?}}int
{{#else if type.i32?}}int
{{#else if type.i64?}}int
{{#else if type.double?}}float
{{#else if type.float?}}float
{{#else if type.string?}}str
{{#else if type.void?}}None
{{#else if type.binary?}}{{#if type.iobufWrapper?}}_fbthrift_iobuf.IOBuf{{#else}}bytes{{/if}}
{{#else if (or type.structured? type.enum?)}}{{#if type.need_module_path?}}{{type.true_type.program.module_path_for_alias}}_types.{{/if}}{{type.true_type.name}}
{{#else if type.list?}}_typing.Sequence[{{#partial type_name type=type.true_type.elem_type}}]
{{#else if type.set?}}_typing.AbstractSet[{{#partial type_name type=type.true_type.elem_type}}]
{{#else if type.map?}}_typing.Mapping[{{#partial type_name type=type.true_type.key_type}}, {{#partial type_name type=type.true_type.val_type}}]
{{/if type.bool?}}
{{/let partial}}


{{! pep 484 typing but with period separated module path }}
{{#let export partial type_period_separated |type| captures |type_name|}}
{{#pragma ignore-newlines}}
{{#if (or type.structured? type.enum?)}}{{#if type.need_module_path?}}{{type.true_type.program.module_path}}.types.{{/if}}{{type.true_type.name}}
{{#else if type.list?}}_typing.Sequence[{{#partial type_period_separated type=type.true_type.elem_type}}]
{{#else if type.set?}}_typing.AbstractSet[{{#partial type_period_separated type=type.true_type.elem_type}}]
{{#else if type.map?}}_typing.Mapping[{{#partial type_period_separated type=type.true_type.key_type}}, {{#partial type_period_separated type=type.true_type.val_type}}]
{{#else}}{{#partial type_name type=type}}
{{/if (or type.structured? type.enum?)}}
{{/let partial}}


{{! Override for stream return types }}
{{#let export partial return_type |function| captures |type_name|}}
{{#pragma ignore-newlines}}
  {{#if function.stream?}}
{{#if function.stream_has_first_response?}}_typing.Tuple[{{#partial type_name type=function.return_type}}, {{/if}}
_typing.Union[_typing.Awaitable[_typing.AsyncGenerator[{{#partial type_name type=function.stream.elem_type}}, None]],
_typing.AsyncGenerator[{{#partial type_name type=function.stream.elem_type}}, None]]
{{#if function.stream_has_first_response?}}]{{/if}}
  {{#else}}
{{#partial type_name type=function.return_type}}
  {{/if function.stream?}}
{{/let partial}}


{{! The field's thrift-py3 python type, for type annotation purposes only }}
{{#let export partial field_type |field| captures |type_name|}}
{{#pragma ignore-newlines}}
  {{#if (not field.hasDefaultValue?)}}
_typing.Optional[{{#partial type_name type=field.type}}]
  {{#else}}
{{#partial type_name type=field.type}}
  {{/if (not field.hasDefaultValue?)}}
{{/let partial}}
