}}{{!

Definitions for constant values. These are included from the struct.pyx file
and define Python objects that can be imported from the end-user's Python
file.

}}
{{#let export partial constant_value |value typeinfo|}}
{{#pragma ignore-newlines}}
  {{#if (or value.bool? (and value.integer? value.type.bool?))}}
{{(py_bool value.nonzero?)}}
  {{#else if value.integer?}}
{{value.integer_value}}{{#if value.type.floating_point?}}.0{{/if}}
  {{#else if value.double?}}
float({{(float_to_string value.double_value)}})
  {{#else if value.string?}}
    {{#if value.type.binary?}}
b"{{value.string_value}}"
    {{#else}}
"{{value.unicode_value}}"
    {{/if value.type.binary?}}
  {{#else if value.structured?}}
{{#if value.type.true_type.need_module_path?}}{{value.type.true_type.module_name}}.{{/if}}{{#if value.type.true_type.has_adapter?}}_fbthrift_unadapted_{{/if}}{{value.type.true_type.py_name}}
(
    {{#each value.structured_elements as |elem| separator=", "}}
{{elem.field.py_name}}={{#partial constant_value value=elem.value typeinfo=typeinfo}}
    {{/each}}
)
  {{#else if value.map?}}
_fbthrift_python_types.Map(
{{#partial typeinfo type=value.type.true_type.key_type}}, {{!}}
{{#partial typeinfo type=value.type.true_type.val_type}}, { {{! purposeful open brace}}
    {{#each value.map_elements as |map_elem| separator=", "}}
{{#partial constant_value value=map_elem.key typeinfo=typeinfo}}: {{!}}
{{#partial constant_value value=map_elem.value typeinfo=typeinfo}}
    {{/each}}{{! purposeful close brace [next line] }}
})
  {{#else if value.list?}}
    {{#if value.type.set?}}
_fbthrift_python_types.Set(
    {{#else}}
_fbthrift_python_types.List(
    {{/if value.type.set?}}
{{#partial typeinfo type=value.type.true_type.elem_type}}, (
    {{#each value.list_elements as |elem|}}
{{#partial constant_value value=elem typeinfo=typeinfo}}, {{!}}
    {{/each}}
))

  {{#else if value.enum?}}
    {{#let bad_enum = (not value.enum_value?)}}
    {{#if bad_enum}}
_fbthrift_python_types.BadEnum(
    {{/if bad_enum}}

{{#if value.type.true_type.need_module_path?}}{{value.type.true_type.module_name}}.{{/if}}
{{value.enum_name}}

    {{#if bad_enum}}
      {{! Close BadEnum }}
, {{value.integer_value}})
    {{#else}}
.{{value.py3_enum_value_name}}
    {{/if bad_enum}}
  {{/if (or value.bool? (and value.integer? value.type.bool?))}}
{{/let partial}}
