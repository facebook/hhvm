{{! Renders a fully-qualified C# type name for use in 'using' alias directives.
    Unlike csharp_type, this uses System.* qualified names (e.g. "System.Int32")
    because C# using alias directives require fully-qualified type names.
    Binary types (byte[]) are not valid in using aliases and should be
    filtered out at the call site. }}
{{#let export partial csharp_typedef_type |type|}}
  {{#pragma ignore-newlines}}
{{#if type.typedef?}}{{#partial csharp_typedef_type type=type.true_type}}
{{#else if type.void?}}System.Void
{{#else if type.bool?}}System.Boolean
{{#else if type.byte?}}System.SByte
{{#else if type.i16?}}System.Int16
{{#else if type.i32?}}System.Int32
{{#else if type.i64?}}System.Int64
{{#else if type.float?}}System.Single
{{#else if type.double?}}System.Double
{{#else if type.string?}}System.String
{{#else if type.binary?}}byte[]
  {{#else if type.list?}}
    {{#let elem = type.true_type.elem_type}}
System.Collections.Generic.List<{{#partial csharp_typedef_type type=elem}}>
  {{#else if type.set?}}
    {{#let elem = type.true_type.elem_type}}
System.Collections.Generic.HashSet<{{#partial csharp_typedef_type type=elem}}>
  {{#else if type.map?}}
    {{#let map = type.true_type}}
System.Collections.Generic.Dictionary<{{#partial csharp_typedef_type type=map.key_type}}, {{#partial csharp_typedef_type type=map.val_type}}>
{{#else if type.enum?}}{{type.true_type.csharp_qualified_name}}
{{#else if type.structured?}}{{type.true_type.csharp_qualified_name}}
{{/if type.typedef?}}
{{/let partial}}
