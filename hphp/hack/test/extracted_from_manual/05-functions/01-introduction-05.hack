function greet(string $greeting, string $name, int $times): void {
  for ($i = 0; $i < $times; $i++) {
    echo $greeting.' '.$name."\n";
  }
}

function call_mixed(): void {
  $rest = tuple('Alice', 3);
  greet('Hello', ...$rest);
}
